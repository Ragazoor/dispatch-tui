-- allium: 3
-- pr-workflow.allium
--
-- Scope: PR creation, polling, merge detection, wrap-up flows, and the
--        rebase/merge finish paths for tasks.
-- Excludes: Task creation and kanban lifecycle (see tasks.allium);
--           dispatch (see dispatch.allium); split pane (see split-pane.allium);
--           epic wrap-up (see epics.allium).

use "./core.allium" as core

------------------------------------------------------------
-- Rules
------------------------------------------------------------

-- == PR Workflow ==

rule CreatePr {
    when: CreatePr(task)

    requires: task.status = running or task.status = review
    requires: task.worktree != null

    ensures: task.url != null and task.url.url_type = pr
    ensures: task.status = review
    ensures: task.sub_status = core/SubStatus.default_for(review)
    ensures: task.updated_at = now
    ensures: PrCreated(base: task.base_branch, head: task.worktree.branch)

    @guidance
        -- The PR-creation transition. The url (with url_type = pr) is
        -- supplied by the agent (via update_task) after the agent runs
        -- `gh pr create --draft`. Dispatch no longer drives the push
        -- or the gh invocation — see WrapUpPr for the rationale and
        -- the agent-side command sequence. The task always transitions
        -- to review with sub_status = awaiting_review regardless of
        -- the starting status (Running or Review).
}

rule PrLearningsGate {
    when: PrLearningsGateCheck(task)

    ensures:
        if task.pr_learnings_gate_shown_at = null:
            task.pr_learnings_gate_shown_at = now
            PrCreateBlocked(task: task)
        else:
            PrCreateAllowed(task: task)

    @guidance
        -- Fires from a Claude Code PreToolUse hook (pr-learnings-hook)
        -- that matches `gh pr create` Bash commands and calls
        -- `dispatch pr-gate <id>`. The first attempt per task is blocked
        -- with a reminder to consult PR-tagged learnings via
        -- query_learnings; the flag persists so subsequent attempts and
        -- resumed sessions pass. One-time reminder, not enforcement —
        -- dispatch does not verify query_learnings actually ran.
}

rule PollPrStatus {
    when: Tick()

    for task in core/Tasks where status = review and url != null and url.url_type = pr:

        -- Branch on GitHub's reported PR state:
        --   Merged -> fire PrMerged; no sub_status update
        --   Closed -> fire PrClosed; task moves to done
        --   Open   -> refresh sub_status from review_decision
        -- Only pr-typed urls are polled; tasks carrying a security_alert,
        -- issue, or other url are never polled for PR merge/close.
        ensures:
            let status = check_pr_status(task.url.url)
            if status.state = merged:
                PrMerged(task: task)
            else if status.state = closed:
                PrClosed(task: task)
            else if status.state = open and task.sub_status != conflict:
                let new_sub =
                    if status.review_decision = approved:
                        core/SubStatus.approved
                    else if status.review_decision = changes_requested:
                        core/SubStatus.changes_requested
                    else:
                        core/SubStatus.awaiting_review
                if task.sub_status != new_sub:
                    task.sub_status = new_sub

    @guidance
        -- Runs during each tick for review tasks whose url is pr-typed
        -- (url.url_type = pr). Tasks with a non-pr url (security_alert,
        -- issue, other) or no url are skipped entirely. Polls
        -- GitHub every pr_poll_interval (30s) via `gh pr view` to check
        -- merge status and review decision.
        -- Merged PRs: fire PrMerged which transitions the task to done.
        -- Open PRs: update sub_status to reflect the current review
        -- decision (approved | changes_requested | awaiting_review).
        -- Tasks currently in sub_status = conflict are NOT overwritten
        -- by the review-decision update, so conflict state persists
        -- across polls until the user resolves it.
        -- Closed-without-merge PRs: fire PrClosed which transitions the
        -- task to done, mirroring PrMerged but with distinct notification
        -- copy ("PR closed" vs "PR merged").
}

rule PrMerged {
    when: PrMerged(task)

    requires: task.status = review

    ensures: task.status = done
    ensures: task.sub_status = core/SubStatus.default_for(done)
    ensures: task.tmux_window = null
    ensures: task.updated_at = now
    ensures:
        if notifications_enabled:
            DesktopNotification(task: task, urgency: normal, about: pr_merged)

    @guidance
        -- This is an automatic transition triggered by PR status polling.
        -- It bypasses the ConfirmDone human confirmation because the PR
        -- merge itself is the human confirmation (via GitHub review process).
        -- The Review Board UI has been removed; no board cleanup side effect fires.
        -- Like other status-changing rules, the underlying patch flow
        -- (src/service/tasks/crud.rs) triggers EpicStatusRecalculation on
        -- the parent epic when the task belongs to one.
}

rule PrClosed {
    when: PrClosed(task)

    requires: task.status = review

    ensures: task.status = done
    ensures: task.sub_status = core/SubStatus.default_for(done)
    ensures: task.tmux_window = null
    ensures: task.updated_at = now
    ensures:
        if notifications_enabled:
            DesktopNotification(task: task, urgency: normal, about: pr_closed)

    @guidance
        -- Fires when PR status polling detects a closed (not merged) PR.
        -- Bypasses ConfirmDone automatically: a PR closed by a human on
        -- GitHub is treated as sufficient intent to conclude the task.
        -- Identical lifecycle to PrMerged — task moves to done, tmux
        -- window is detached — but with distinct notification copy:
        -- title "PR closed", body "<PR label> closed: <task title>".
        -- Status bar shows "<PR label> closed — task #<id> moved to Done".
        -- Tasks in sub_status = conflict are moved to done by this rule —
        -- unlike the open-PR poll branch, there is no conflict guard here.
        -- A closed PR is a terminal GitHub event that overrides conflict state.
        -- Like other status-changing rules, the underlying patch flow
        -- (src/service/tasks/crud.rs) triggers EpicStatusRecalculation on
        -- the parent epic when the task belongs to one.
}

-- == Wrap Up ==

rule WrapUpRebase {
    when: WrapUp(task, rebase)

    -- Available from any running or review task with a worktree.
    requires: task.status = review or task.status = running
    requires: task.worktree != null

    let branch = task.worktree.branch

    ensures:
        if task.sub_status = conflict:
            task.sub_status = core/SubStatus.default_for(task.status)
    ensures: BranchRebased(branch: branch, onto: task.base_branch)
    ensures: task.updated_at = now

    @guidance
        -- WrapUpRebase is the rebase mechanic only — it does NOT change
        -- task.status or kill the tmux window. The Done transition for
        -- the MCP path is owned by ExitSession (the agent must call
        -- exit_session to close its session, which marks the task done
        -- and kills tmux). The TUI path (W then r) emits FinishTask and
        -- is governed by FinishTaskSuccess, which keeps its own Done
        -- transition independent of this rule.
        --
        -- Optimistically clears conflict sub_status before attempting the
        -- rebase, so the task is no longer visually flagged while the
        -- rebase runs in the background.
        -- Steps (all via finish_task in dispatch.rs):
        --   1. Verify the repo root is on task.base_branch; abort if not.
        --   2. If origin remote exists, `git pull origin <base_branch>`
        --      in the repo root (skipped when no remote is configured).
        --   3. `git rebase <base_branch>` from the task's worktree.
        --      On conflict: abort the rebase and emit RebaseConflict.
        --   4. `git merge --ff-only <branch>` in the repo root to
        --      fast-forward the base branch to the rebased branch.
        -- The worktree is preserved after a successful rebase (cleaned
        -- up only on archive). The MCP wrap_up handler calls finish_task
        -- with tmux_window=None so the agent's session stays alive until
        -- it explicitly calls exit_session. The MCP wrap_up handler returns
        -- an exit token in its success response. The agent MUST pass this
        -- token to exit_session to close its session. The token records
        -- action = rebase, and the agent must call exit_session with
        -- action="rebase"; this action-recording is now symmetric across all
        -- three wrap-up actions (rebase, done, pr) — see ExitSession, which
        -- owns the Done transition for every action's MCP path.
        -- Available from both the TUI (W then r) and MCP (wrap_up tool with
        -- action "rebase").
        --
        -- Shared-worktree TUI fast-path: when the TUI Finish path (W+r)
        -- detects that another active task shares the same worktree,
        -- it bypasses rebase / fast-forward entirely. Instead it patches
        -- the task to clear worktree and tmux_window and emits
        -- FinishComplete, advancing the task directly to Done. The MCP
        -- wrap_up handler has no equivalent shared-worktree check —
        -- it always invokes finish_task and attempts the rebase. This
        -- asymmetry is intentional: the MCP path is agent-driven and
        -- expects an isolated worktree per task.
        --
        -- The wrap_up success response includes a "Verify before exiting:
        -- run `<c>`" sentence between the "session is NOT yet closed" line
        -- and the "call exit_session" line when task.repo_path has
        -- verify_command = Some(c). When verify_command is null, the
        -- response text is byte-for-byte identical to today.
        --
        -- On the MCP wrap_up(action="rebase") path, after the base branch
        -- is successfully fast-forwarded, the handler refreshes the repo's
        -- RAG index as a detached background task iff an index already
        -- exists at <repo_path>/.dispatch/rag.db. It never creates a new
        -- index. The re-index loops index_repo until files_remaining reaches
        -- zero. This is fire-and-forget: it does not block the exit-token
        -- response, does not change task status, and a failure is logged
        -- but never surfaced to the agent. The TUI Finish path (W+r) does
        -- not trigger a re-index.
        --
}

rule WrapUpPr {
    when: WrapUp(task, pr)

    -- Available from any running or review task with a worktree.
    requires: task.status = review or task.status = running
    requires: task.worktree != null

    ensures: task.updated_at = now
    ensures: PrCreated(base: task.base_branch, head: task.worktree.branch)

    @guidance
        -- Agent-driven PR creation. wrap_up(action="pr") no longer takes a
        -- pr_url and no longer mutates task.status or task.url. It leaves the
        -- task in status = running (its session is still alive) and issues an
        -- exit token that records action = pr. The pr-typed url and the review
        -- transition are applied later, atomically, by ExitSession — see the
        -- race-closure rationale on that rule.
        --
        -- The /wrap-up skill instructs the agent to inspect its own diff,
        -- draft a title and body that reflect the actual work, run
        --   git push -u origin <branch>
        --   gh pr create --draft --base <task.base_branch>
        --     --head <owner>:<branch> --repo <owner>/<repo>
        --     --title <agent-authored> --body <agent-authored>
        -- then call wrap_up(action="pr") (no pr_url), run the /retro skill,
        -- and finally call exit_session(token, action="pr", pr_url=<url>) using
        -- the URL that `gh pr create` printed. It is exit_session that records
        -- task.url (with url_type = pr) and moves the task to review. The
        -- --head uses the owner:branch format so `gh` resolves the branch in
        -- the same repo as --repo (rather than the authenticated user's
        -- namespace). The PR base is task.base_branch (not hardcoded "main").
        -- PR status polling (PollPrStatus) only takes over once ExitSession
        -- has recorded the pr-typed url.
        --
        -- Rationale: previously dispatch's Rust code ran `gh pr create`
        -- using task.title and task.description for the title and body.
        -- That body was set at task-creation time and rarely matched
        -- the work actually shipped. Letting the agent author the PR
        -- after implementation produces materially better PRs.
        --
        -- The TUI W+p shortcut and the epic-merge MergeAction::Pr have both
        -- been removed. Rebase remains as a TUI/MCP path (see WrapUpRebase).
        --
        -- The wrap_up success response (PR path) includes a "Verify before
        -- exiting: run `<c>`" instruction when task.repo_path has
        -- verify_command = Some(c), appearing before the exit_session
        -- instruction. When verify_command is null, that line is omitted. (This
        -- verify line was previously claimed here but missing from the PR
        -- branch's response; it is added as part of this consolidation.)
}

rule WrapUpDone {
    when: WrapUp(task, done)

    -- Available from any running or review task with a worktree.
    requires: task.status = review or task.status = running
    requires: task.worktree != null

    ensures: task.updated_at = now

    @guidance
        -- Closes a task without any git operations (no rebase, no push, no
        -- PR creation). Useful for tasks whose work requires no branch
        -- integration: research tasks, planning tasks, tasks that edit
        -- only the repo root (e.g., config files already on the base branch).
        --
        -- MCP path: wrap_up(action="done") no longer flips task.status to
        -- done. It leaves the task running (its session is still alive) and
        -- issues an exit token recording action = done, exactly like
        -- wrap_up(action="rebase"). The Done transition and the tmux_window
        -- teardown happen later, in the single ExitSession call. The agent
        -- runs the /retro skill between wrap_up and exit_session. This removes
        -- the old asymmetry where done flipped to Done immediately while
        -- rebase deferred to exit_session.
        --
        -- TUI path: W then d finishes directly via handle_finish_complete —
        -- the task moves to Done and the tmux window is killed in one step,
        -- with no exit-token round trip. This mirrors how the TUI rebase path
        -- (W then r) completes via FinishTaskSuccess rather than ExitSession;
        -- the running -> done transition for the MCP path is owned by
        -- ExitSession.
        --
        -- /wrap-up skill path: if task.wrap_up_mode = done (from get_task),
        -- or if the user selects "done" in Step 4, the skill calls
        -- wrap_up(action="done"), runs /retro, then exit_session(token,
        -- action="done") — no git commands.
}

rule ExitSession {
    when: ExitSession(task, token, action, pr_url?)

    requires: token = ExitToken.valid_for(task)
    requires: action = token.action
    requires: task.tmux_window != null
    requires:
        if action = pr: pr_url != null and pr_url != ""

    ensures:
        task.tmux_window = null
        ExitTokenConsumed(task: task)
        if action = pr:
            task.status = review
            task.sub_status = core/SubStatus.default_for(review)
            task.url = core/TaskUrl{url: pr_url, url_type: pr}
        else:
            task.status = done
            task.sub_status = core/SubStatus.default_for(done)
        task.updated_at = now

    @guidance
        -- Single-call session close. The old two-phase behaviour (first call
        -- returned a reflection prompt and set token.reflected, second call
        -- closed) is gone: the mandatory reflection is now the /retro skill,
        -- which the /wrap-up skill runs BEFORE exit_session is ever called.
        -- With /retro as the forcing function, the in-handler nudge is
        -- redundant, so the reflected flag and the first-call/second-call
        -- branch are removed.
        --
        -- ExitToken is issued by all three wrap-up actions (rebase, done, pr)
        -- and records which action issued it (token.action). It is stored in
        -- McpState.exit_tokens (in-memory HashMap).
        --
        -- Validation, in the order the handler applies it (all mutate nothing
        -- on failure):
        --   • token must equal the token issued for this task, else
        --     "invalid exit token"; a missing token → "no exit token — call
        --     wrap_up first".
        --   • the supplied action must equal the action recorded on the token.
        --     A missing action → "action is required". A mismatch (e.g. token
        --     issued for wrap_up(rebase) but the agent calls
        --     exit_session(action="pr")) is rejected with an error naming both
        --     actions — this stops an agent from doing one thing and closing as
        --     another.
        --   • task.tmux_window must be non-null. If it is already null, some
        --     other path (TUI, crash detection, a prior close) already tore the
        --     session down; the handler reports "task #<id> has no active
        --     session" and the /wrap-up skill treats it as success, not a
        --     retryable failure. (On a normal double-close the token has also
        --     been consumed, so a retry hits the "call wrap_up first" branch
        --     above before ever reaching this check.)
        --   • pr_url is required iff action = pr; it is rejected/ignored for
        --     rebase and done.
        --
        -- Terminal mutation, applied atomically with clearing tmux_window:
        --   • rebase / done → task.status = done
        --   • pr            → task.status = review, task.url = TaskUrl(pr_url,
        --                      url_type = pr)
        -- The token is consumed and task/epic-changed is notified for all three
        -- actions (this notify previously existed only for the rebase path; the
        -- done and pr status/url mutations moved out of wrap_up into this single
        -- closing mutation). The underlying patch flow (src/service/tasks/crud.rs)
        -- triggers EpicStatusRecalculation on the parent epic. Killing the tmux
        -- window is unchanged.
        --
        -- Why this closes the PR-merge race (not merely narrows it): previously
        -- wrap_up("pr") set status = review with a pr-typed url immediately,
        -- which armed PollPrStatus (it filters on status = review and
        -- url.url_type = pr). From the very next tick a merge/close could fire
        -- PrMerged/PrClosed and null tmux_window while the agent was still
        -- working. Now a PR task never enters review with a pr-typed url until
        -- the exact same call that also nulls tmux_window, so PollPrStatus can
        -- never observe it mid-session — the review-visible state and the
        -- session-ended state become true in the same instant.
}

-- == Finish (Merge) ==

rule FinishTaskSuccess {
    when: FinishTask(task)

    requires: task.status = review
    requires: task.worktree != null

    let branch = task.worktree.branch

    -- Preconditions verified at execution time:
    -- repo root must be on task.base_branch
    -- merge must succeed (no conflicts)

    ensures: BranchMerged(branch: branch, into: task.base_branch)
    ensures: task.tmux_window = null
    ensures: task.status = done
    ensures: task.sub_status = core/SubStatus.default_for(done)
    ensures: task.updated_at = now

    @guidance
        -- Same finish_task path as WrapUpRebase. The implementation
        -- rebases the task branch onto task.base_branch (after pulling
        -- latest from origin), then fast-forwards task.base_branch to
        -- the rebased branch, then kills the tmux window.
        -- Worktree is preserved after finish; it will be cleaned up
        -- when the task is archived. If another active task shares the
        -- same worktree, the worktree is detached from this task but
        -- not removed from disk (same shared-worktree logic as FinishTaskSuccess).
}

rule FinishTaskConflict {
    when: RebaseConflict(task)

    -- Fires when FinishTask's or WrapUpRebase's rebase encounters a conflict.
    -- The rebase is aborted and the task is marked with conflict sub_status.
    -- The task may be in either running or review status at this point,
    -- so conflict is a valid sub_status for both parent statuses.

    ensures: task.sub_status = conflict
    ensures: UserInformed(about: rebase_conflict, task: task)

    @guidance
        -- Conflict has the highest visual column priority (0, above
        -- crashed at 1). It appears in the Stale visual column alongside
        -- stale and crashed tasks.
        -- Conflict is valid for both running and review tasks: review
        -- tasks hit it during FinishTask (merge via TUI), running tasks
        -- hit it during WrapUpRebase.
        -- Staleness detection skips conflict tasks (they are not
        -- re-evaluated for inactivity).
        -- PR review polling skips overwriting conflict sub_status.
        -- Wrap-up rebase clears conflict optimistically before rebasing.
}
