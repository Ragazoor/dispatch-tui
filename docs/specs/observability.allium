-- allium: 3
-- observability.allium
--
-- Scope: Trajectory persistence — per-task audit log of MCP tool calls.
-- Includes: TrajectoryEntry value type, append-on-each-MCP-call rule,
--           fire-and-forget error handling.
-- Excludes: tmux pane capture, Claude lifecycle hooks (PreToolUse, Stop —
--           see agent-health.allium), dispatch-internal commands, reader UIs,
--           replay tooling.

use "./core.allium" as core

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

-- A single line in <dispatch_data_dir>/trajectories/<task_id>.jsonl.
-- Each MCP tool call from a dispatched-agent caller becomes one
-- TrajectoryEntry, serialised as a single JSON object on its own line.
-- Entries for a given task accumulate in a single per-task file named
-- by the task's integer ID. The centralized data dir (parent of the
-- SQLite database) holds all trajectory files so they outlive worktree
-- cleanup and remain queryable in a single location.
--
-- args and result are stored as opaque JSON strings to keep this spec free
-- of MCP payload shape; the schema_version field lets readers detect format
-- evolution.
value TrajectoryEntry {
    schema_version: String     -- semver string, e.g. "1.0.0"
    timestamp:      Timestamp  -- UTC, RFC 3339
    task_id:        String     -- stringified Task.id of the caller
    method:         String     -- MCP tool name (e.g. "update_task")
    args:           String     -- full tool arguments as received, JSON-encoded
    result:         String     -- response payload on success (JSON-encoded);
                               -- on failure, the JSON object {"error": "<msg>"}
    duration_ms:    Integer    -- wall-clock time from dispatch to response
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    trajectory_schema_version: String = "1.0.0"
    -- Subdirectory name within the dispatch data dir that holds trajectory files.
    trajectory_subdir: String = "trajectories"
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

-- == Append on MCP tool call ==

rule TrajectoryAppend {
    -- After every dispatched-agent MCP tool call, append a TrajectoryEntry
    -- to the per-task trajectory file in the centralized dispatch data dir.
    -- Session callers produce no entry.
    when: McpToolCall(caller_identity, method, args, result, duration_ms)

    -- Only Task-kind callers are logged. Session callers are silently dropped.
    requires: caller_identity.kind = task

    -- The caller's task must exist in the DB. Entries are written regardless
    -- of whether the task has a worktree — the write path is independent of
    -- the worktree field.
    requires: core/Task.exists(caller_identity.task_id)

    ensures: append_jsonl(
        path: dispatch_data_dir
              + "/" + config.trajectory_subdir
              + "/" + str(caller_identity.task_id) + ".jsonl",
        entry: TrajectoryEntry {
            schema_version: config.trajectory_schema_version,
            timestamp: now,
            task_id: str(caller_identity.task_id),
            method: method,
            args: args,
            result: result,
            duration_ms: duration_ms
        }
    )

    @guidance
        -- dispatch_data_dir is the parent directory of the SQLite database
        -- (e.g. ~/.local/share/dispatch/). It is not task-specific.
        -- append_jsonl opens the file in append mode (O_APPEND | O_CREAT),
        -- writes one JSON-encoded TrajectoryEntry followed by "\n", and closes
        -- the file. The trajectories/ subdirectory is created with
        -- create_dir_all if absent — unlike the old worktree-relative path,
        -- the parent directory is auto-created so there is no noop-on-missing-
        -- dir behaviour.
        -- Implementation lives behind the MCP handler dispatch boundary so
        -- that every tool call (create_task, update_task, query_learnings,
        -- propose_learning, report_usage, send_message, claim, dispatch,
        -- list_tasks, list_epics, …) is captured uniformly.
        -- The duration_ms field measures the wall-clock interval from the
        -- moment the handler receives the parsed JSON-RPC request to the
        -- moment it returns a response (success or error). The timestamp
        -- field records the start of the call (before dispatch_tool runs),
        -- not the time of writing.
        -- For failed handler invocations, the result string is the JSON
        -- object {"error": "<msg>"} where <msg> is the JSON-RPC error
        -- message; the duration_ms still reflects time-to-error.
}

-- == Fire-and-forget error handling ==

rule TrajectoryWriteFailureIsSilent {
    -- Trajectory writes are best-effort. File I/O errors (permission denied,
    -- disk full, …) must not propagate to the calling MCP handler or affect
    -- the handler's response.
    when: TrajectoryWriteFailed(task_id, error)

    ensures: TrajectoryWriteWarning(task_id: task_id, error: error)

    @guidance
        -- The implementation wraps the append in a fallible block; on error
        -- the error is forwarded to tracing::warn (target: "trajectory")
        -- with the task_id and error message, and the handler proceeds to
        -- return its normal response. There is no retry, no buffering, no
        -- dead-letter file.
        -- TrajectoryWriteWarning is observable via the standard tracing
        -- subscriber; it has no entity representation in this spec.
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

-- Every persisted TrajectoryEntry must carry the current schema version.
-- Readers use this field to dispatch between format versions; an entry
-- without a schema_version is unreadable.
invariant TrajectoryEntryHasSchemaVersion {
    for e in TrajectoryEntries:
        e.schema_version != ""
}

-- A trajectory entry's task_id must identify a real task. Entries are only
-- ever produced by TrajectoryAppend, which guards on Task.exists, so this
-- holds by construction.
invariant TrajectoryEntryReferencesRealTask {
    for e in TrajectoryEntries:
        core/Task.exists(e.task_id)
}

------------------------------------------------------------
-- Open Questions
------------------------------------------------------------

open question "Retention: <dispatch_data_dir>/trajectories/<task_id>.jsonl grows unbounded for long-lived tasks. Should there be a size cap, rotation policy, or a wrap-up-time truncation? Currently the file is left untouched for the life of the dispatch installation."

open question "Replay: should a future reader tool reconstruct task state from trajectory.jsonl, or is it write-only audit? The schema_version field is forward-looking but no reader is specified."

open question "Concurrency: when an agent and a runtime path both attempt MCP tool calls for the same task in the same instant, the JSONL append must remain line-atomic. Is single-process open(O_APPEND) sufficient, or is an explicit advisory lock required?"
