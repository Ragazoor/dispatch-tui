-- allium: 3
-- dispatch.allium
--
-- Scope: Dispatching tasks into worktrees and tmux sessions — repo-path
--        persistence, prompt augmentation, retry flows, and the surfaces
--        the user sees while a dispatch is in flight.
-- Excludes: Task creation and lifecycle (see tasks.allium); PR/wrap-up
--           flows (see pr-workflow.allium); split-pane behaviour
--           (see split-pane.allium); MCP dispatch tools (see
--           mcp-task-tools.allium); epic dispatch (see epics.allium);
--           learning prompt augmentation (see learnings.allium).

use "./core.allium" as core

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    -- Per-repo cap on remembered base branches. RecordBaseBranch prunes a
    -- repo's history down to the most-recently-used max_base_branches_per_repo
    -- entries on every write; callers never manage the cap (see the
    -- BranchHistoryCapped invariant).
    max_base_branches_per_repo: Integer = 10
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

-- == Repo Path ==

rule RecordRepoPath {
    when: RepoPathUsed(path)

    ensures: core/SavedRepoPath.created_or_updated(
        path: path,
        last_used: now
    )

    @guidance
        -- Fires whenever a repo path is used to create a task or epic
        -- through the TUI:
        --   - TUI task creation (after InputBaseBranch submission)
        --   - TUI quick-dispatch (Shift+D)
        --   - TUI epic creation
        --   - TUI task edit (EditTask) when repo_path changes to a
        --     non-empty value, so sibling feed items (e.g. other
        --     Dependabot PRs in the same repo) can be auto-resolved
        --     by resolve_feed_item_repo_paths on subsequent feed syncs
        -- The path is first expand_tilde'd. If a SavedRepoPath with
        -- the same path already exists, last_used is bumped to now;
        -- otherwise a new record is created.
        -- Not fired for MCP task creation (create_task tool) — that
        -- skips repo path persistence. (There is no CLI for task
        -- creation; tasks are created exclusively via MCP.) Cap
        -- enforcement (maximum stored paths) is an implementation
        -- detail and not specified here.
}

-- == Base Branch History ==

rule RecordBaseBranch {
    when: BaseBranchUsed(repo, branch)

    ensures: core/SavedRepoBranch.created_or_updated(
        repo_path: repo,
        branch: branch,
        last_used: now
    )
    -- Prune the repo's history down to the cap, dropping the least-recently-used
    -- rows so at most config.max_base_branches_per_repo remain for this repo.
    -- Pruning is part of this write; callers never manage the cap.
    ensures:
        let history = core/SavedRepoBranches where repo_path = repo
        for stale in history where rank_by_recency(stale, history) > config.max_base_branches_per_repo:
            not exists stale

    @guidance
        -- Records a base_branch into a repo's most-recently-used history so
        -- it can be offered by the BaseBranchPicker next time a task is
        -- created for the same repo. If a SavedRepoBranch with the same
        -- (repo_path, branch) already exists, last_used is bumped to now
        -- (upsert); otherwise a new row is created. After the upsert the
        -- repo's rows are pruned to the config.max_base_branches_per_repo
        -- most-recently-used, keeping the history bounded. This preserves the
        -- BranchHistoryCapped invariant as a property of the write itself, so
        -- no caller has to enforce the cap.
        --
        -- == Recording scope (deliberately narrow) ==
        -- BaseBranchUsed is emitted from EXACTLY ONE entry point: the manual
        -- TUI "new task" form, when it is finished (finish_task_creation),
        -- alongside the existing RepoPathUsed emission. It is NOT emitted by:
        --   - quick dispatch (CreateQuickTask / Shift+D), which resolves its
        --     base branch from origin/HEAD detection and bypasses the form; or
        --   - the MCP create_task tool, which never goes through the TUI form.
        -- This keeps the history a record of branches the user deliberately
        -- typed/selected, not an incidental log of every branch the system
        -- has ever targeted. The copy-task flow needs no special-casing: it
        -- flows through the same InputRepoPath -> InputBaseBranch ->
        -- finish_task_creation path, so it records for free.
        --
        -- On write failure the error is surfaced through the status bar (the
        -- same path RecordRepoPath uses), not silently swallowed.
        --
        -- rank_by_recency(row, history) is a black-box ranking helper: the
        -- 1-based position of row within history ordered by last_used
        -- descending (1 = most recent). Rows ranked beyond the cap are the
        -- least-recently-used and are removed.
}

-- == Dispatch ==

rule DispatchTask {
    when: DispatchTask(task)

    requires: task.status = backlog
    -- Tasks with a plan always dispatch. Tasks without a plan dispatch
    -- unless they carry the research tag (the only remaining tag that
    -- routes to a dedicated agent).
    requires: task.has_plan = true
              or task.tag != research

    ensures: task.status = running
    ensures: task.sub_status = core/SubStatus.default_for(running)
    ensures: task.last_pre_tool_use_at = now
    ensures: task.worktree = core/Worktree.created(
        path: task.repo_path + "/.worktrees/" + task.id + "-" + slugify(task.title),
        branch: task.id + "-" + slugify(task.title)
    )
    ensures: task.tmux_window = core/TmuxWindow.created(name: "task-" + task.id)
    ensures: AgentLaunched(task: task, mode: standard)

    @guidance
        -- Before creating the worktree, `git fetch origin <base_branch>` is
        -- run in the repo root to update the remote-tracking ref. On success,
        -- the worktree branch is created from `origin/<base_branch>` so the
        -- agent starts from the latest remote state. On fetch failure (no
        -- origin remote, network error), the step is skipped silently and the
        -- worktree falls back to the local base branch.
        -- Specifically: `git worktree add -B <branch> <path> origin/<base_branch>`.
        -- If the worktree directory already exists on disk (pre-created),
        -- the fetch and git worktree add steps are both skipped.
        --
        -- Review tasks (tag pr-review or dependabot) that carry a PR URL are a
        -- special case: their worktree is based on the PR's head branch instead
        -- of <base_branch>, so the agent sees the PR's code. The PR's head
        -- branch is resolved with `gh pr view <url> --json
        -- headRefName,isCrossRepository`; the worktree is then created from
        -- `origin/<headRefName>` (same fetch-then-base flow as above). This
        -- soft-falls back to <base_branch> on any gh failure, empty output, or a
        -- cross-repository (fork) PR whose head branch is not on origin.
        -- For these PR-based worktrees the {rebase_preamble} also targets the PR
        -- branch (`git fetch origin <headRefName>` + `git rebase
        -- origin/<headRefName>`) rather than the base branch, framed as an
        -- on-demand refresh so the agent can pull later pushes to the PR.
        -- The launched Claude command includes a plugin-dir flag so
        -- the agent discovers dispatch plugin skills (e.g. /wrap-up).
        -- The agent prompt is prepended with a `git rebase <base>`
        -- preamble so the agent picks up latest base changes on first
        -- run (also useful when an agent is resumed after time passes).
        -- Task-agent dispatches launch Claude in auto mode by default —
        -- i.e. without a --permission-mode flag — so agents can edit
        -- files without per-edit approval. The Research agent is the
        -- sole exception: it launches with --permission-mode plan so
        -- investigation stays read-only. The prompt content — not the
        -- permission flag — differentiates the other modes.

        -- == Unified prompt skeleton ==
        -- Every task-agent prompt produced by build_prompt /
        -- build_quick_dispatch_prompt / build_epic_planning_prompt has
        -- the same shape:
        --
        --   {rebase_preamble}              (git rebase <base> instruction)
        --   {worktree_preamble}            ("Always work from this
        --                                    worktree folder — do not
        --                                    `cd` to the parent repo
        --                                    or other directories.")
        --   {preamble}                     (one line, mode-specific)
        --   <blank>
        --   Task:                          (shared task_block, always)
        --     ID: ...
        --     Title: ...
        --     Description: ...
        --     EpicId: ...                  (only if task.epic != null)
        --   {epic sibling-communication}   (only if task.epic != null)
        --   <blank>
        --   {validated_knowledge}          (tiered learnings; see
        --                                    AugmentDispatchPromptWithLearnings)
        --   {mode_addendum}                (mode-specific block)
        --   <blank>
        --   {tdd_instruction}              (shared verbatim)
        --   {allium_instruction}           (shared verbatim)
        --   {mcp_tools_instruction}        (shared verbatim)
        --   {learning_tools_instruction}   (shared verbatim — one-line
        --                                    nudge to call query_learnings
        --                                    when uncertain, and use the
        --                                    /learnings skill to record or
        --                                    upvote entries)
        --   {wrap_up_instruction}          (shared verbatim, universal)
        --   {verification_section}         (optional; see below)
        --                                  Intentionally last: the agent reads
        --                                  this immediately before finishing,
        --                                  making it the final reminder before
        --                                  wrap-up.
        --
        -- When task.repo_path has a SavedRepoPath row with verify_command = Some(c),
        -- the dispatch prompt includes a "## Verification" section instructing the
        -- agent to run `c` in its worktree before declaring work complete. The
        -- command is rendered inside a quadruple-backtick fenced block so
        -- backticks in the command cannot escape. When verify_command is null,
        -- the section is absent.
        --
        -- DispatchTask emits one of two variants of build_prompt:
        --   * has_plan = false: preamble "Your task is:" and the addendum
        --     is plan_or_brainstorm_instruction (conditional: if vague
        --     use /brainstorming, else write the plan directly under
        --     docs/plans/ and attach via update_task).
        --   * has_plan = true: preamble "Your task is:" and the addendum
        --     references the plan path with a "review and ask permission
        --     before implementing" instruction.
        -- CreateQuickTask (build_quick_dispatch_prompt) is the exception:
        -- its preamble is "You are working interactively with the user."
        -- rather than "Your task is:" — quick dispatch begins as an
        -- interactive conversation where the agent elicits the goal
        -- before writing a plan.
        -- task_block does NOT include a Tag: line — tag is metadata for
        -- the kanban board, not for prompt context (it would invite the
        -- agent to over-fit on labels rather than the description).
        -- wrap_up_instruction is shared by every dispatched agent so the
        -- whole task lifecycle terminates the same way regardless of
        -- mode (the wording covers plan-attach, work-package-creation,
        -- and implementation completion).
        -- DispatchResearchTask is an exception to the unified trailing
        -- block: its prompt includes only {mcp_tools_instruction} and
        -- omits tdd, allium, learning_tools, and wrap_up. The research agent
        -- presents findings interactively and does not terminate via
        -- the standard wrap-up flow.
        -- Dependabot exception: when task.tag = dependabot, build_prompt
        -- replaces the plan_or_brainstorm addendum with a dependabot
        -- review runbook (vet the PR, classify the bump as patch/minor/
        -- major via semver, check CI, scan the changelog, auto-approve
        -- + merge if safe via `gh pr review --approve` and `gh pr merge
        -- --squash --auto`, else ask the user and set sub_status =
        -- needs_input). The trailing block is also reduced to just
        -- {mcp_tools_instruction} + {learning_tools_instruction} — no
        -- tdd, no allium, and explicitly NO wrap_up_instruction, because
        -- the dependabot task is auto-cleaned when its PR merges (or
        -- the user takes over). PrReview exception: when task.tag =
        -- pr_review, build_prompt replaces the plan_or_brainstorm
        -- addendum with a minimal PR review runbook (check diff size
        -- via `gh pr diff`, run /review for small PRs or /review-pr for
        -- large PRs, do not call /wrap-up). The trailing block is also
        -- reduced to just {mcp_tools_instruction} +
        -- {learning_tools_instruction} — no tdd, no allium, and
        -- explicitly NO wrap_up_instruction, because the PR review agent
        -- presents findings and waits for the user's instructions. The
        -- fix tag falls through to this rule and uses the full trailing
        -- block — it is purely a kanban-board label, not a routing key.
}

rule DispatchResearchTask {
    when: DispatchResearchTask(task)

    requires: task.status = backlog
    requires: task.has_plan = false
    requires: task.tag = research

    ensures: task.status = running
    ensures: task.sub_status = core/SubStatus.default_for(running)
    ensures: task.last_pre_tool_use_at = now
    ensures: task.worktree = core/Worktree.created(
        path: task.repo_path + "/.worktrees/" + task.id + "-" + slugify(task.title),
        branch: task.id + "-" + slugify(task.title)
    )
    ensures: task.tmux_window = core/TmuxWindow.created(name: "task-" + task.id)
    ensures: AgentLaunched(task: task, mode: research)

    @guidance
        -- Research mode: the agent investigates the topic in the task
        -- description by reading code, docs, and external resources.
        -- It presents findings to the user and waits for instructions.
        -- The agent makes no code changes and does not wrap up autonomously.
        -- Uses --permission-mode plan (same as other task dispatches).
        -- Prompt note: build_research_prompt emits a stripped-down
        -- trailing block — only {mcp_tools_instruction}, no tdd,
        -- allium, learning_tools, or wrap_up. The research agent
        -- presents findings interactively and does not terminate via
        -- the standard wrap-up flow.
}

rule ResumeTask {
    when: ResumeTask(task)

    requires: task.status in {running, review}
    requires: task.worktree != null
    requires: task.tmux_window = null

    ensures: task.tmux_window = core/TmuxWindow.created(name: "task-" + task.id)
    ensures: task.status = running
    ensures: task.sub_status = core/SubStatus.default_for(running)
    ensures: task.last_pre_tool_use_at = now
    ensures: AgentLaunched(task: task, mode: resume)
}

-- == Retry ==

rule RetryResume {
    when: RetryResume(task)

    requires: task.status = running
    requires: task.worktree != null

    ensures:
        if task.tmux_window != null:
            OldTmuxWindow.killed(window: task.tmux_window)
    ensures: task.sub_status = active
    ensures: task.last_pre_tool_use_at = now
    ensures: task.tmux_window = core/TmuxWindow.created(name: "task-" + task.id)
    ensures: AgentLaunched(task: task, mode: resume)

    @guidance
        -- If the task already has a tmux window (e.g. a crashed or stale
        -- session), the existing window is killed before creating a fresh
        -- one. This tears down the old process cleanly.
}

rule RetryFresh {
    when: RetryFresh(task)

    requires: task.status = running

    -- Destroys existing worktree, resets to backlog, then re-dispatches
    ensures:
        if task.worktree != null:
            not exists task.worktree
    ensures: task.worktree = null
    ensures: task.tmux_window = null
    ensures: task.status = backlog
    ensures: task.sub_status = core/SubStatus.default_for(backlog)
    ensures: AgentLaunched(task: task, mode: standard)

    @guidance
        -- RetryFresh dispatches directly via the standard dispatch
        -- path. The unified prompt skeleton handles both has_plan = true
        -- (review-and-implement) and has_plan = false (brainstorm-or-plan
        -- conditional) variants without any branch in this rule.
}

-- == Main Session ==
--
-- The main session is a single, task-independent tmux window (a fixed
-- constant name, "dispatch-main") running an interactive Claude Code session
-- rooted at a user-chosen directory. Its window identity is NOT persisted:
-- liveness is re-derived on each open via a live tmux check. Only the chosen
-- directory is remembered (under the "main_session.dir" setting) as the
-- default for the next open.

rule OpenMainSession {
    when: OpenMainSession(user)

    -- Liveness is checked live against tmux on the fixed window name, not read
    -- from any stored reference.
    let window_alive = main_session_window_alive()

    ensures:
        if window_alive:
            MainSessionFocused(user: user)
        else:
            ConfigureMainSessionDir(user)

    @guidance
        -- Bound to `:` in the TUI. When the main-session window is alive,
        -- focus (jump to) it — the user cannot reconfigure the directory while
        -- the session runs. When it is not alive, the shared RepoPathPicker is
        -- opened in MainSessionDir mode so the user (re)selects a directory
        -- before the session is created. There is no separate reconfigure key:
        -- reconfiguration happens implicitly on every open while no window is
        -- alive. Because the window name is a fixed constant,
        -- `main_session_window_alive` performs a live tmux check rather than
        -- consulting a persisted window reference.
}

rule ConfigureMainSessionDir {
    when: ConfigureMainSessionDir(user)

    ensures: MainSessionDirPickerShown(user: user)

    @guidance
        -- Opens the shared RepoPathPicker (see surface) in MainSessionDir
        -- mode. Confirming a non-empty path emits CreateMainSession with that
        -- path; confirming an empty selection cancels and nothing happens.
}

rule CreateMainSession {
    when: CreateMainSession(user, dir)

    requires: dir != ""

    ensures: core/TmuxWindow.created(name: "dispatch-main")
    ensures: MainSessionFocused(user: user)

    @guidance
        -- Creates the main-session tmux window rooted at expand_tilde(dir) and
        -- focuses it. The directory is persisted under the "main_session.dir"
        -- setting as the default for the next open; the window identity itself
        -- is not persisted (it is a fixed constant name, re-derived via the
        -- live tmux liveness check in OpenMainSession).
}

------------------------------------------------------------
-- Surfaces
------------------------------------------------------------

surface TextInputField {
    facing user: User

    -- The shared single-line text buffer used by every InputMode that
    -- types free text into the app's shared input field: task title,
    -- epic title, base branch, todo title, todo quick-add, repo-path
    -- query, quick-dispatch query, and filter-preset name. Task/epic
    -- DESCRIPTION is NOT this surface (it opens an external $EDITOR).
    -- SearchTasks and ManagedFeedConfig use separate buffers and are
    -- intentionally not on this surface yet.

    -- buffer is the text; caret is a CHARACTER index into buffer (the
    -- text insertion point). Both start empty/zero.
    let buffer = ""
    let caret = 0

    exposes:
        buffer
        caret

    provides:
        -- Insert char AT THE CARET (not appended); caret advances by one.
        -- ensures: buffer = insert_char(buffer, caret, char); caret = caret + 1
        TypeChar(user, char)

        -- Delete the char immediately before the caret; caret moves back
        -- one. No-op at caret 0 (guarded).
        -- ensures: buffer = delete_before(buffer, caret); caret = caret - 1
        Backspace(user)
            when caret > 0

        -- Delete key: delete the char AT the caret; caret unchanged.
        -- No-op at end of buffer (guarded).
        -- ensures: buffer = delete_at(buffer, caret)
        DeleteForward(user)
            when caret < len(buffer)

        -- Move the caret one char left, clamped to 0.
        -- ensures: caret = max(0, caret - 1)
        CursorLeft(user)

        -- Move the caret one char right, clamped to len(buffer).
        -- ensures: caret = min(len(buffer), caret + 1)
        CursorRight(user)

        -- Move the caret one word left. A word char is alphanumeric or
        -- underscore; every other char (whitespace, punctuation, path
        -- separators like / - .) is a boundary, so this steps through
        -- path segments.
        -- ensures: caret = word_boundary_left(buffer, caret)
        CursorWordLeft(user)

        -- Move the caret one word right (same word/boundary rule).
        -- ensures: caret = word_boundary_right(buffer, caret)
        CursorWordRight(user)

        -- Jump the caret to the start of the buffer.
        -- ensures: caret = 0
        CursorHome(user)

        -- Jump the caret to the end of the buffer.
        -- ensures: caret = len(buffer)
        CursorEnd(user)

    @guarantee CaretInBounds
        -- caret is always within 0..=len(buffer) after any operation.
        -- Every caret motion clamps to this range and every buffer edit
        -- keeps the caret inside the (possibly resized) buffer.

    @guarantee PrefillLandsAtEnd
        -- When a field is opened prefilled with an existing value
        -- (editing a todo title, copy-task repo path, default base
        -- branch), the caret starts at len(buffer) — the end — not at 0.

    @guarantee CaretMoveRepaints
        -- A caret motion that changes caret is an observable state change
        -- and must force a redraw even though buffer is unchanged.
        -- Otherwise the rendered caret would not visibly move.

    @guarantee WordMotionWhitespaceAndPunctuation
        -- Word motion breaks on whitespace AND punctuation/path
        -- separators (word char = alphanumeric or `_`). A word jump in a
        -- path with no spaces moves segment-by-segment; in a space-less
        -- token it moves to the boundary. Deliberate — matches
        -- readline/editor default behaviour.

    @guidance
        -- Key bindings: Left/Right move the caret one char; Ctrl+Left/Right
        -- move one word (with Alt+Left/Right and the readline Alt+B / Alt+F
        -- as tmux-safe fallbacks, since some terminals drop the Ctrl
        -- modifier); Home/End jump to the buffer ends; Delete forward-deletes.
        -- Typing and Backspace act AT THE CARET, not at the end of the buffer.
        -- The field is rendered with a reversed block cell at the caret and
        -- horizontal scrolling that keeps the caret visible when the buffer
        -- is wider than the field.
        -- The caret is a Unicode scalar (char) index, so a move or delete can
        -- split a grapheme cluster (combining marks, ZWJ emoji sequences) but
        -- never a UTF-8 codepoint. Grapheme-aware motion is out of scope here.
        -- The insert/delete/word-boundary mechanics (insert_char,
        -- delete_before, delete_at, word_boundary_left/right) are shared UI
        -- helpers documented in docs/conventions.md, not domain logic.
}

surface RepoPathPicker {
    facing user: User

    let saved = core/SavedRepoPaths
    let query = ""
    let cursor = 0

    -- Fuzzy subsequence match: every character of lowercased query
    -- appears in the lowercased path as a forward subsequence.
    -- Empty query matches all saved paths.
    let filtered = saved where fuzzy_subsequence(lowercase(query), lowercase(path))

    -- When query is non-empty and is not an exact match for any item
    -- in filtered, an additional NewPath(query) entry is appended.
    -- This lets the user dispatch to a brand-new repo path even when
    -- the query fuzzy-matches existing paths.
    let new_entry = query != "" and not (exists p in filtered where p.path = query)
    let effective = if new_entry: filtered + {NewPath(query)} else: filtered

    exposes:
        query
        effective
        cursor

    provides:
        -- Typing inserts the char into query at the query's text caret
        -- (character/caret mechanics follow the TextInputField surface)
        -- and resets the LIST cursor to 0. The list cursor is distinct
        -- from the text caret; any query edit resets it.
        -- ensures: query inserts char at its text caret (see TextInputField); cursor = 0
        TypeChar(user, char)

        -- Backspace deletes the char BEFORE the query's text caret
        -- (mechanics follow TextInputField) and resets the list cursor to 0.
        -- ensures: query deletes char before its text caret (see TextInputField); cursor = 0
        Backspace(user)
            when query != ""

        -- Up/Down arrows move the cursor within effective (wrapping).
        -- effective = filtered + optional NewPath(query) entry at end.
        -- No printable character is a navigation alias — letters such as
        -- j/k are typed into query, not interpreted as nav commands.
        -- ensures: cursor = (cursor + 1) mod effective.count
        CursorDown(user)
            when effective.count > 0

        -- ensures: cursor = (cursor - 1 + effective.count) mod effective.count
        CursorUp(user)
            when effective.count > 0

        -- Enter: select item at cursor position in effective.
        -- When cursor points to the NewPath(query) entry, the typed
        -- query is dispatched as a new (unsaved) repo path.
        -- When effective is empty (query is empty and no repos are
        -- saved), Confirm is a no-op.
        -- ensures: if effective.count > 0: SelectedPath(nth(effective, cursor).path)
        Confirm(user)
            when effective.count > 0

        -- Escape dismisses the picker without selecting
        Dismiss(user)

    @guarantee CursorResetOnEntry
        -- cursor is always 0 when the picker is first displayed.
        -- This ensures the most-recently-used path is pre-selected.

    @guarantee NoPrintableShortcut
        -- No printable character (letter, digit, punctuation) is a
        -- navigation or selection shortcut. Every printable character
        -- is appended to query via TypeChar; navigation goes through
        -- the arrow keys; selection goes through Enter. This contract
        -- is shared by every InputMode that renders this picker —
        -- in particular it forbids the historical j/k nav alias and
        -- the historical 1-9 instant-select shortcut, both of which
        -- broke fuzzy filtering on paths containing those characters.

    @guidance
        -- This surface appears during task creation (InputRepoPath),
        -- epic creation (InputEpicRepoPath), main-session repo set
        -- (MainSessionDir), and quick dispatch (QuickDispatch). It
        -- replaces a plain text input with a fuzzy-filtered list of
        -- previously-used repo paths. The filtered list is ordered by
        -- recency (most recent first). When the user has not typed
        -- anything, all saved paths are shown, letting them pick with
        -- a single keystroke.
        --
        -- The `cursor` exposed by this surface is the LIST cursor (an index
        -- into `effective`, moved by Up/Down and reset to 0 on any query
        -- change). It is distinct from the query's single-line TEXT CARET,
        -- which is moved by Left/Right (and Ctrl/Alt+Left/Right for words,
        -- Home/End) and edits the query in place. The query's text editing
        -- follows the TextInputField surface: the query gains forward-delete
        -- (Delete) and caret motions from it, and TypeChar/Backspace act at
        -- the text caret rather than at the end. Text-caret motion does not
        -- change the query, so it does NOT reset the list cursor; only query
        -- edits (TypeChar/Backspace/Delete) do. Caret editing is shared UI
        -- mechanics documented in docs/conventions.md, not domain logic.
}

surface BaseBranchPicker {
    facing user: User

    -- The base-branch field of the manual "new task" form (InputBaseBranch
    -- step). It mirrors RepoPathPicker, but its candidate list is the
    -- most-recently-used base branches for the repo the user already chose
    -- earlier in the same flow, rather than the global set of repo paths.
    --
    -- selected_repo is the repo_path confirmed at the preceding InputRepoPath
    -- step; the picker scopes its history to that repo. history is the
    -- per-repo most-recently-used list, ordered most-recent-first. The whole
    -- board's history is preloaded once at startup (a single
    -- list-all-base-branches read, mirroring the repo-path preload) and kept
    -- in memory keyed by repo_path; this surface reads the slice for
    -- selected_repo.
    let selected_repo = ""
    let history = core/SavedRepoBranches where repo_path = selected_repo

    -- query starts prefilled with the most-recently-used branch for
    -- selected_repo (history.first.branch), falling back to the form's prior
    -- default base branch ("main" / config.default_branch) when the repo has
    -- no history yet. See the PrefillFromHistory guarantee.
    let query = ""
    let cursor = 0

    -- Fuzzy subsequence match: every character of lowercased query appears in
    -- the lowercased branch as a forward subsequence. Empty query matches all
    -- of the repo's remembered branches.
    let filtered = history where fuzzy_subsequence(lowercase(query), lowercase(branch))

    -- When query is non-empty and is not an exact match for any remembered
    -- branch in filtered, an additional NewBranch(query) entry is appended, so
    -- the user can free-type a brand-new branch even when the query
    -- fuzzy-matches existing history entries.
    let new_entry = query != "" and not (exists b in filtered where b.branch = query)
    let effective = if new_entry: filtered + {NewBranch(query)} else: filtered

    exposes:
        query
        effective
        cursor

    provides:
        -- Typing inserts the char into query at the query's text caret
        -- (character/caret mechanics follow the TextInputField surface) and
        -- resets the LIST cursor to 0. The list cursor is distinct from the
        -- text caret; any query edit resets it.
        -- ensures: query inserts char at its text caret (see TextInputField); cursor = 0
        TypeChar(user, char)

        -- Backspace deletes the char BEFORE the query's text caret (mechanics
        -- follow TextInputField) and resets the list cursor to 0.
        -- ensures: query deletes char before its text caret (see TextInputField); cursor = 0
        Backspace(user)
            when query != ""

        -- Up/Down arrows move the cursor within effective (wrapping).
        -- effective = filtered + optional NewBranch(query) entry at end.
        -- No printable character is a navigation alias.
        -- ensures: cursor = (cursor + 1) mod effective.count
        CursorDown(user)
            when effective.count > 0

        -- ensures: cursor = (cursor - 1 + effective.count) mod effective.count
        CursorUp(user)
            when effective.count > 0

        -- Enter: select item at cursor position in effective. When cursor
        -- points to the NewBranch(query) entry, the typed query is used as the
        -- task's base branch. When effective is empty, Confirm is a no-op.
        -- ensures: if effective.count > 0: SelectedBranch(nth(effective, cursor).branch)
        Confirm(user)
            when effective.count > 0

        -- Escape dismisses the picker without selecting
        Dismiss(user)

    @guarantee PrefillFromHistory
        -- When the field is opened, query is prefilled with the
        -- most-recently-used branch for selected_repo (history.first.branch)
        -- and the text caret lands at the end (per TextInputField's
        -- PrefillLandsAtEnd). When selected_repo has no history, query falls
        -- back to the form's prior default base branch — the current draft
        -- value, or "main" (config.default_branch) when the draft is empty.
        -- Because the prefill is a non-empty query, effective initially shows
        -- only the synthetic NewBranch(query) entry unless the prefill exactly
        -- matches a remembered branch (which it does when drawn from history).

    @guarantee CursorResetOnEntry
        -- cursor is always 0 when the picker is first displayed, so the
        -- prefilled / most-recently-used branch is pre-selected.

    @guarantee EmptyHistoryShowsOnlyNewEntry
        -- When selected_repo has no remembered branches, history and filtered
        -- are empty; effective contains only the NewBranch(query) entry for
        -- whatever is typed (same empty-state as RepoPathPicker with no saved
        -- paths). Confirm submits the typed value as the base branch.

    @guarantee NoPrintableShortcut
        -- No printable character (letter, digit, punctuation) is a navigation
        -- or selection shortcut. Every printable character is appended to
        -- query via TypeChar; navigation goes through the arrow keys;
        -- selection goes through Enter. Shared verbatim with RepoPathPicker.

    @guidance
        -- This surface is the base-branch counterpart of RepoPathPicker, shown
        -- during the manual task-creation form's InputBaseBranch step (and the
        -- copy-task flow, which reuses the same step). It replaces the former
        -- plain text field that defaulted to "main". Interaction is identical
        -- to RepoPathPicker: typing fuzzy-filters the repo's remembered
        -- branches live, arrow keys move through the list, Enter selects (or
        -- free-types a new branch when nothing matches).
        --
        -- The `cursor` exposed here is the LIST cursor (an index into
        -- `effective`, moved by Up/Down and reset to 0 on any query change),
        -- distinct from the query's single-line TEXT CARET (moved by
        -- Left/Right, Ctrl/Alt+Left/Right, Home/End) which edits the query in
        -- place via the TextInputField surface. Text-caret motion does not
        -- reset the list cursor; only query edits do.
        --
        -- Confirming this step emits BaseBranchUsed(selected_repo, <branch>)
        -- as part of finish_task_creation, recording the chosen branch into
        -- the repo's history (see RecordBaseBranch). Quick dispatch and MCP
        -- create_task never render this surface and never record history.
}

surface DispatchingFeedback {
    facing user: User

    -- This surface tracks tasks that are mid-dispatch — between the
    -- user pressing Enter / Shift+D and the dispatch worker reporting
    -- success or failure. Set membership and per-task start time are
    -- implementation-internal (`app.dispatching` HashSet plus a
    -- sibling start-time map); the surface contract is the visible
    -- behaviour of the status bar and card line-2 indicator.

    @guarantee StickyUntilEmpty
        -- status_text persists across Tick events while `dispatching` is
        -- non-empty. The 5-second STATUS_MESSAGE_TTL that applies to ad-hoc
        -- status messages is bypassed for dispatching feedback.

    @guarantee ClearedWhenEmpty
        -- status_text becomes null the moment `dispatching` drains,
        -- regardless of how the last entry was removed (Dispatched,
        -- DispatchFailed, or watchdog timeout).

    @guarantee DispatchingTimeout
        -- A task that remains in `dispatching` for more than 60 seconds is
        -- removed by the next Tick and a "dispatch timed out" failure toast
        -- is shown. Defence-in-depth against a stuck dispatch worker
        -- (e.g. an agent panic that escapes catch_unwind).

    @guarantee DeletedTaskPruned
        -- If a task referenced in `dispatching` is deleted from the task
        -- list (e.g. via `d`), the next Tick removes the stale ID so the
        -- status text never references a vanished task.

    @guarantee SinglePathMutation
        -- Mutation of `dispatching` flows through a single helper so the
        -- sticky status text is always kept in sync with set membership.
        -- Routing through `app.update(MarkDispatching)` from another
        -- update handler is forbidden (recursive update hazard).

    @guidance
        -- Dispatch is asynchronous: the worker runs `git fetch origin
        -- <base_branch>`, creates the worktree and tmux window, then
        -- starts the agent. On a slow network this takes several seconds.
        -- The DispatchingFeedback surface gives the user continuous
        -- evidence that the work is in flight rather than a non-responsive
        -- UI. It is rendered in two places: the status bar (full
        -- status_text) and each affected task card's secondary line
        -- (spinner glyph + "dispatching…"). Once `dispatching` is empty
        -- the status bar reverts to its idle state and cards return to
        -- their normal indicator.
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

-- RunningTaskHasWorktree: Tasks dispatched via DispatchTask or ClaimTaskViaMcp
-- always have a worktree. However, manual forward movement (m key) can move a
-- task to running without provisioning a worktree. The dispatch flow is the
-- canonical path; manual moves are overrides.

-- BranchHistoryCapped: no repo retains more than
-- config.max_base_branches_per_repo remembered base branches. This is a
-- property of the write operation (RecordBaseBranch prunes on every write),
-- not something any caller enforces.
invariant BranchHistoryCapped {
    for b in core/SavedRepoBranches:
        (core/SavedRepoBranches where repo_path = b.repo_path).count
            <= config.max_base_branches_per_repo
}
