-- allium: 3
-- dispatch.allium
--
-- Scope: Agent dispatch and lifecycle management
-- Includes: Task, Epic, dispatch, finish/merge, archive, agent health, MCP constraints
-- Excludes:
--   - TUI rendering, keyboard input, selection state (UI implementation)
--   - ReviewBoard view mode and ReviewPr entities (separate concern: inbound PR review)
--   - SecurityBoard view mode and SecurityAlert entities (separate concern: vulnerability triage)
--   - Git worktree creation mechanics (infrastructure)
--   - Tmux subprocess commands (infrastructure)
--   - SQLite schema and migrations (persistence implementation)
--   - JSON-RPC protocol details (transport implementation)
--   - Slug generation, path expansion (implementation helpers)

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

-- The git worktree and tmux window are provisioned externally.
-- The spec treats them as opaque handles.

external entity Worktree {
    path: String
    branch: String
}

external entity TmuxWindow {
    name: String
}

------------------------------------------------------------
-- Enumerations
------------------------------------------------------------

enum TaskTag { bug | feature | chore | epic }

-- Legacy alias: "ready" maps to backlog
enum TaskStatus { backlog | running | review | done | archived }

-- SubStatus refines the parent status into a more precise state.
-- Valid combinations are constrained by SubStatus.is_valid_for(status).
-- When status changes, sub_status resets to SubStatus.default_for(new_status).
enum SubStatus {
    -- backlog / done / archived
    none

    -- running (and review where noted)
    active          -- agent is running normally
    needs_input     -- agent is blocked waiting for human interaction (Blocked visual column)
    stale           -- no output change detected beyond inactivity_timeout
    crashed         -- tmux window disappeared unexpectedly
    conflict        -- rebase/merge encountered a conflict (valid for both running and review)

    -- review
    awaiting_review   -- PR created, no review decision yet
                      -- UI splits this into two visual sections based on runtime state:
                      --   "awaiting review" — tmux window alive (agent still active)
                      --   "awaiting merge"  — tmux window gone (detached, just waiting for merge)
    changes_requested -- reviewer requested changes
    approved          -- PR approved, ready to merge
}

-- Valid SubStatus values per parent status (enforced by MCP; bypassed by CLI hooks):
--   backlog   : none
--   running   : active | needs_input | stale | crashed | conflict
--   review    : awaiting_review | changes_requested | approved | conflict
--   done      : none
--   archived  : none
--
-- Note: HookNotification sets status=review with sub_status=needs_input via the CLI
-- update path, which bypasses is_valid_for() validation. The UI renders
-- (review, needs_input) as the "Blocked" state. The Blocked visual column is
-- defined as (running, needs_input) in models.rs, but tasks produced by
-- HookNotification appear as (review, needs_input) in practice.

-- Default sub_status when transitioning to a new status:
--   backlog   -> none
--   running   -> active
--   review    -> awaiting_review
--   done      -> none
--   archived  -> none

------------------------------------------------------------
-- Entities and Variants
------------------------------------------------------------

entity Task {
    title: String
    description: String
    repo_path: String
    status: TaskStatus
    sub_status: SubStatus
    worktree: Worktree?
    tmux_window: TmuxWindow?
    plan: String?
    epic: Epic?
    pr_url: String?
    tag: TaskTag?
    sort_order: Integer?
    created_at: Timestamp
    updated_at: Timestamp

    transitions status {
        backlog -> running
        running -> review
        running -> backlog
        review -> done
        review -> running
        done -> review
        done -> archived
        -- Archive is accepted from any non-archived status
        backlog -> archived
        running -> archived
        review -> archived
        terminal: archived
    }

    -- Derived
    has_plan: plan != null
    is_stale: sub_status == stale
    is_crashed: sub_status == crashed
    is_epic: tag = epic
    pr_number: derived from pr_url  -- extracted at runtime, not persisted
}

entity Epic {
    title: String
    description: String
    repo_path: String
    status: TaskStatus
    plan: String?
    sort_order: Integer?
    created_at: Timestamp
    updated_at: Timestamp

    has_plan: plan != null

    subtasks: Task with epic = this
    active_subtasks: subtasks where status != archived
    subtask_statuses: active_subtasks -> status
}

entity TaskUsage {
    task: Task
    cost_usd: Float
    input_tokens: Integer
    output_tokens: Integer
    cache_read_tokens: Integer
    cache_write_tokens: Integer
    updated_at: Timestamp

    @guidance
        -- Uses accumulation semantics: one row per task, upserted on each
        -- report. Numeric fields (cost_usd, input_tokens, output_tokens,
        -- cache_read_tokens, cache_write_tokens) are summed with the
        -- existing values rather than replaced. updated_at reflects the
        -- time of the most recent report.
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    tick_interval: Duration = 2.seconds
    inactivity_timeout: Duration = 3.minutes
    status_message_expiry: Duration = 5.seconds
    notifications_enabled: Boolean = true
    pr_poll_interval: Duration = 30.seconds
    default_branch: String = detect_from_remote("main")
}

------------------------------------------------------------
-- VisualColumn
------------------------------------------------------------

-- The kanban board renders 8 visual columns, grouped under the 4 parent
-- statuses. Each visual column corresponds to a (parent_status, sub_status)
-- pair or set. Columns within the same parent group share a header.
--
-- Column layout (left to right):
--
--   # | Label            | parent_status | sub_statuses
--   --+------------------+---------------+------------------------------
--   0 | Backlog          | backlog       | none
--   1 | Active           | running       | active
--   2 | Blocked          | running       | needs_input
--   3 | Stale            | running       | stale, crashed, conflict
--   4 | PR Created       | review        | awaiting_review, conflict  (split into "awaiting review" / "awaiting merge" sections by detach state)
--   5 | Revise           | review        | changes_requested
--   6 | Approved         | review        | approved
--   7 | Done             | done          | none
--
-- Navigation (h/l) moves between visual columns.
-- Parent group boundaries are annotated in the column header.
-- A task's visual column is determined by (task.status, task.sub_status).
--
-- Note: HookNotification produces (review, needs_input) in practice,
-- which the UI renders as the Blocked state. The VisualColumn model
-- defines Blocked as (running, needs_input), which is the target model
-- for future alignment.

concept VisualColumn {
    label: String
    parent_status: TaskStatus
    sub_statuses: SubStatus[]

    -- A task belongs to this column when:
    --   task.status = parent_status and task.sub_status in sub_statuses
    contains(task): task.status = parent_status and task.sub_status in sub_statuses
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

-- == Task Creation ==

rule CreateTask {
    when: CreateTask(title, description, repo_path, plan?, epic?, tag?, sort_order?)

    ensures: Task.created(
        title: title,
        description: description,
        repo_path: repo_path,
        status: backlog,
        sub_status: SubStatus.default_for(backlog),
        plan: plan,
        epic: epic,
        tag: tag,
        sort_order: sort_order,
        created_at: now,
        updated_at: now
    )
}

rule CreateQuickTask {
    when: QuickDispatch(repo_path, epic_id?)

    ensures:
        let task = Task.created(
            title: "Quick task",
            description: "",
            repo_path: repo_path,
            status: backlog,
            sub_status: SubStatus.default_for(backlog),
            epic: if epic_id != null then Epic.find(epic_id) else null,
            created_at: now,
            updated_at: now
        )
        AgentDispatched(task: task, mode: quick)

    @guidance
        -- When invoked from the epic view, epic_id is set to the
        -- current epic, linking the quick task as a subtask.
}

-- == Dispatch ==

rule DispatchTask {
    when: DispatchTask(task)

    requires: task.status = backlog
    -- Tasks with a plan always dispatch. Tasks without a plan dispatch
    -- if their tag is bug, chore or unset. Epic and feature tags route
    -- to BrainstormTask and PlanTask respectively.
    requires: task.has_plan = true
              or task.tag not in {epic, feature}

    ensures: task.status = running
    ensures: task.sub_status = SubStatus.default_for(running)
    ensures: task.worktree = Worktree.created(
        path: task.repo_path + "/.worktrees/" + task.id + "-" + slugify(task.title),
        branch: task.id + "-" + slugify(task.title)
    )
    ensures: task.tmux_window = TmuxWindow.created(name: "task-" + task.id)
    ensures: AgentLaunched(task: task, mode: standard)
}

rule BrainstormTask {
    when: BrainstormTask(task)

    requires: task.status = backlog
    requires: task.has_plan = false

    ensures: task.status = running
    ensures: task.sub_status = SubStatus.default_for(running)
    ensures: task.worktree = Worktree.created(
        path: task.repo_path + "/.worktrees/" + task.id + "-" + slugify(task.title),
        branch: task.id + "-" + slugify(task.title)
    )
    ensures: task.tmux_window = TmuxWindow.created(name: "task-" + task.id)
    ensures: AgentLaunched(task: task, mode: brainstorm)
}

rule PlanTask {
    when: PlanTask(task)

    requires: task.status = backlog
    requires: task.has_plan = false
    requires: task.tag = feature

    ensures: task.status = running
    ensures: task.sub_status = SubStatus.default_for(running)
    ensures: task.worktree = Worktree.created(
        path: task.repo_path + "/.worktrees/" + task.id + "-" + slugify(task.title),
        branch: task.id + "-" + slugify(task.title)
    )
    ensures: task.tmux_window = TmuxWindow.created(name: "task-" + task.id)
    ensures: AgentLaunched(task: task, mode: plan)

    @guidance
        -- Plan mode launches Claude with --permission-mode plan, which
        -- restricts the agent to writing an implementation plan without
        -- making code changes. This is the dispatch path for feature-
        -- tagged tasks that do not yet have a plan.
}

rule ResumeTask {
    when: ResumeTask(task)

    requires: task.status in {running, review}
    requires: task.worktree != null
    requires: task.tmux_window = null

    ensures: task.tmux_window = TmuxWindow.created(name: "task-" + task.id)
    ensures: task.status = running
    ensures: task.sub_status = SubStatus.default_for(running)
    ensures: AgentLaunched(task: task, mode: resume)
}

-- == Status Movement ==

rule MoveTaskForward {
    when: MoveTask(task, forward)

    requires: task.status != done
    requires: task.status != archived

    let next = next_status(task.status)

    -- Moving to Done requires explicit confirmation via ConfirmDone
    requires: next != done

    ensures: task.status = next
    ensures: task.sub_status = SubStatus.default_for(next)
    ensures: task.updated_at = now

    @guidance
        -- Manual movement (forward or backward) clears agent health
        -- tracking state (tmux output, staleness timer, crash detection,
        -- notification flags) for the task.
        -- sub_status is always reset to the default for the new status.
}

rule MoveTaskBackward {
    when: MoveTask(task, backward)

    requires: task.status != backlog
    requires: task.status != archived

    let prev = prev_status(task.status)

    -- Kill tmux window when moving backward, but preserve worktree for resume
    ensures: task.status = prev
    ensures: task.sub_status = SubStatus.default_for(prev)
    ensures: task.tmux_window = null
    ensures: task.updated_at = now

    @guidance
        -- Manual movement (forward or backward) clears agent health
        -- tracking state (tmux output, staleness timer, crash detection,
        -- notification flags) for the task.
        -- sub_status is always reset to the default for the new status.
}

rule ConfirmDone {
    when: ConfirmDone(task)

    requires: task.status = review

    ensures: task.status = done
    ensures: task.sub_status = SubStatus.default_for(done)
    ensures: task.tmux_window = null
    ensures: task.updated_at = now

    @guidance
        -- Batch forward-move of a multi-select that includes Review tasks
        -- splits the operation: non-Review tasks move immediately, while
        -- Review tasks are collected and confirmed together via a single
        -- prompt. Each confirmed task is individually guarded by review
        -- status before transitioning to done.
}

-- == Detach Tmux ==

rule DetachTmux {
    when: DetachTmux(task)

    requires: task.status = review
    requires: task.tmux_window != null

    ensures: task.tmux_window = null
    ensures:
        if task.sub_status in {stale, crashed}:
            task.sub_status = SubStatus.default_for(review)

    @guidance
        -- Kills the tmux window for a review task while preserving
        -- the worktree. The agent is gone but the branch remains for
        -- PR review or later resume. Clears agent health tracking
        -- (staleness timer, crash detection). Stale/Crashed sub_status
        -- is reset to the review default (awaiting_review); other
        -- sub_statuses (e.g. awaiting_review, approved) are preserved.
        -- Available via the TUI (d key) on review tasks. Supports
        -- batch operation on multi-selected tasks.
}

-- == PR Workflow ==

rule CreatePr {
    when: CreatePr(task)

    requires: task.status = running or task.status = review
    requires: task.worktree != null

    ensures: task.pr_url != null
    ensures: task.updated_at = now

    @guidance
        -- Pushes the branch to origin and creates a GitHub PR using
        -- `gh pr create`. The task remains in review.
        -- PRs are created as drafts (--draft flag) to avoid triggering
        -- review requests before the agent's work is fully reviewed.
}

rule MergePr {
    when: MergePr(task)

    requires: task.status = review
    requires: task.pr_url != null
    requires: task.sub_status = approved

    ensures: PrMerged(task: task)

    @guidance
        -- Human-initiated merge of an approved PR via the TUI (M key).
        -- Runs `gh pr merge --merge` on the task's pr_url.
        -- On success, fires PrMerged which transitions the task to done.
        -- On failure, the error is shown in the status bar without
        -- changing task state.
}

rule PollPrStatus {
    when: Tick

    for task in Tasks where status = review and pr_url != null
                           and sub_status != conflict:

        ensures: PrMerged(task: task)
        ensures:
            let decision = PrReviewDecision(task)
            let new_sub = match decision {
                approved          => SubStatus.approved
                changes_requested => SubStatus.changes_requested
                _                 => SubStatus.awaiting_review
            }
            if task.sub_status != new_sub:
                task.sub_status = new_sub

    @guidance
        -- Runs during each tick for review tasks with a pr_url.
        -- Polls GitHub every pr_poll_interval (30s) via `gh pr view`
        -- to check merge status and review decision.
        -- Fires PrMerged when the PR is merged.
        -- Updates sub_status to reflect the current review decision:
        --   approved | changes_requested | awaiting_review.
        -- PRs closed without merging are silently ignored by the poll
        -- loop. The task remains in review and requires manual
        -- intervention (move to done or re-dispatch).
}

rule PrMerged {
    when: PrMerged(task)

    requires: task.status = review

    ensures: task.status = done
    ensures: task.sub_status = SubStatus.default_for(done)
    ensures: task.tmux_window = null
    ensures: task.updated_at = now
    ensures:
        if notifications_enabled:
            DesktopNotification(task: task, urgency: normal, about: pr_merged)

    @guidance
        -- This is an automatic transition triggered by PR status polling.
        -- It bypasses the ConfirmDone human confirmation because the PR
        -- merge itself is the human confirmation (via GitHub review process).
}

-- == Wrap Up ==

rule WrapUpRebase {
    when: WrapUp(task, rebase)

    -- Available from any running or review task with a worktree.
    requires: task.status = review or task.status = running
    requires: task.worktree != null

    let branch = task.worktree.branch

    ensures:
        if task.sub_status = conflict:
            task.sub_status = SubStatus.default_for(task.status)
    ensures: BranchRebased(branch: branch, onto: config.default_branch)
    ensures: task.tmux_window = null
    ensures: task.status = done
    ensures: task.sub_status = SubStatus.default_for(done)
    ensures: task.updated_at = now

    @guidance
        -- Optimistically clears conflict sub_status before attempting the
        -- rebase, so the task is no longer visually flagged while the
        -- rebase runs in the background.
        -- Runs `git fetch origin && git rebase origin/<default_branch>`
        -- in the task's worktree directory, then fast-forwards the
        -- default branch to the rebased branch. Uses the same
        -- finish_task path as FinishTaskSuccess. The operation runs
        -- in background via ProcessRunner; the tmux window is killed
        -- on completion. Available from both the TUI (W then r) and
        -- MCP (wrap_up tool with action "rebase").
}

rule WrapUpPr {
    when: WrapUp(task, pr)

    -- Available from any running or review task with a worktree.
    requires: task.status = review or task.status = running
    requires: task.worktree != null

    ensures: task.pr_url != null
    ensures: task.status = review
    ensures: task.sub_status = SubStatus.default_for(review)
    ensures: task.updated_at = now

    @guidance
        -- Pushes the branch to origin and creates a GitHub PR as a
        -- draft (`gh pr create --draft`) to avoid triggering review
        -- requests before the agent's work is fully reviewed. The task
        -- transitions to review and PR status polling (PollPrStatus)
        -- takes over from there.
        -- The operation runs in background via ProcessRunner.
        -- Available from both the TUI (W then p) and MCP (wrap_up
        -- tool with action "pr").
        -- When invoked via MCP and the task has an active tmux window,
        -- a `/code-review {pr_url}` command is injected into the tmux
        -- session after PR creation, triggering the agent to perform
        -- a self-review.
}

-- == Finish (Merge) ==

rule FinishTaskSuccess {
    when: FinishTask(task)

    requires: task.status = review
    requires: task.worktree != null

    let branch = task.worktree.branch

    -- Preconditions verified at execution time:
    -- repo root must be on the default branch
    -- merge must succeed (no conflicts)

    ensures: BranchMerged(branch: branch, into: config.default_branch)
    ensures: task.tmux_window = null
    ensures: task.status = done
    ensures: task.sub_status = SubStatus.default_for(done)
    ensures: task.updated_at = now

    @guidance
        -- The implementation rebases the task branch onto the default
        -- branch (after pulling latest from origin), then fast-forwards
        -- the default branch to the rebased branch.
        -- Worktree is preserved after finish.
        -- It will be cleaned up when the task is archived.
        -- If another active task shares the same worktree, the worktree
        -- is detached from this task but not removed from disk.
}

rule FinishTaskConflict {
    when: RebaseConflict(task)

    -- Fires when FinishTask's or WrapUpRebase's rebase encounters a conflict.
    -- The rebase is aborted and the task is marked with conflict sub_status.
    -- The task may be in either running or review status at this point,
    -- so conflict is a valid sub_status for both parent statuses.

    ensures: task.sub_status = conflict
    ensures: UserInformed(about: rebase_conflict, task: task)

    @guidance
        -- Conflict has the highest visual column priority (0, above
        -- crashed at 1). It appears in the Stale visual column alongside
        -- stale and crashed tasks.
        -- Conflict is valid for both running and review tasks: review
        -- tasks hit it during FinishTask (merge via TUI), running tasks
        -- hit it during WrapUpRebase.
        -- Staleness detection skips conflict tasks (they are not
        -- re-evaluated for inactivity).
        -- PR review polling skips overwriting conflict sub_status.
        -- Wrap-up rebase clears conflict optimistically before rebasing.
}

-- == Archive ==

rule ArchiveTask {
    when: ArchiveTask(task)

    requires: task.status != archived

    ensures: task.status = archived
    ensures:
        if task.worktree != null:
            not exists task.worktree
    ensures: task.worktree = null
    ensures: task.tmux_window = null
    ensures: task.updated_at = now

    @guidance
        -- Removes the git worktree and tmux window if present.
        -- Best-effort branch deletion.
        -- The TUI typically restricts archive to Done tasks,
        -- but the handler accepts any non-archived task.
}

rule DeleteTask {
    when: DeleteTask(task)

    requires: task.status = archived

    ensures:
        if task.worktree != null:
            not exists task.worktree
    ensures: not exists task

    @guidance
        -- Permanent removal. Only accessible from the archive view.
        -- Worktree and branch are cleaned up best-effort.
        -- The archived-status precondition is enforced by the TUI input
        -- layer (archive view only shows archived tasks), not by the
        -- handler itself.
}

-- == Agent Health ==

rule DetectStaleAgent {
    -- Fires when a running task's tmux output stops changing beyond
    -- inactivity_timeout and the task is not already stale or crashed.
    when: task.status = running
          and task.tmux_window != null
          and time_since_last_output(task) > inactivity_timeout
          and task.sub_status not in {stale, crashed, conflict}

    ensures: task.sub_status = stale
    ensures:
        if notifications_enabled:
            DesktopNotification(
                task: task,
                urgency: normal,
                about: agent_stale
            )

    @guidance
        -- Evaluated on each tick for all running tasks with a tmux window.
        -- Escalation only: Crashed is not downgraded to Stale.
        -- When activity resumes (new tmux output arrives), sub_status
        -- is reset to active by the TmuxOutput handler.
}

rule DetectCrashedAgent {
    -- Fires when the tmux window disappears for a running task.
    when: WindowGone(task)

    requires: task.status = running

    ensures: task.sub_status = crashed
    ensures:
        if notifications_enabled:
            DesktopNotification(
                task: task,
                urgency: urgent,
                about: agent_crashed
            )

    @guidance
        -- Triggered by the WindowGone message, which is sent when the
        -- runtime detects that the task's tmux window no longer exists.
        -- The tmux_window field is NOT cleared for crashed tasks, so that
        -- the window name remains available for the ConfirmRetry prompt.
        -- When activity resumes (TmuxOutput or RetryResume), sub_status
        -- is reset to active.
        -- For non-running tasks (e.g. review tasks), window closure
        -- silently clears task.tmux_window = null without changing
        -- sub_status or sending notifications. This is the normal exit
        -- path for review agents and detached sessions.
}

rule RecoverFromStale {
    -- When tmux output arrives for a running task with stale or crashed
    -- sub_status, the agent is alive again. Reset sub_status to active.
    when: TmuxOutput(task)

    requires: task.status = running
    requires: task.sub_status in {stale, crashed}

    ensures: task.sub_status = active

    @guidance
        -- Evaluated when new tmux output is detected and the output
        -- content has changed since the last capture. This is the
        -- counterpart to DetectStaleAgent and DetectCrashedAgent:
        -- activity evidence reverses the health degradation.
}

-- == Notifications ==

rule NotifyNeedsInput {
    when: task: Task.sub_status transitions_to needs_input

    requires: task.status = running

    ensures:
        if notifications_enabled:
            DesktopNotification(
                task: task,
                urgency: urgent,
                about: needs_input
            )

    @guidance
        -- Notifications are deduplicated: each notification fires at most
        -- once per transition to needs_input. The notified state is
        -- cleared when sub_status leaves needs_input, allowing
        -- re-notification on a subsequent re-entry.
        -- The task is in running/needs_input (Blocked visual column),
        -- set by HookNotification when the agent raises a notification.
}

rule NotifyReview {
    when: task: Task.status transitions_to review

    ensures:
        if notifications_enabled:
            DesktopNotification(
                task: task,
                urgency: normal,
                about: status_review
            )

    @guidance
        -- Notifications are gated by a user-togglable notifications_enabled
        -- setting (N key in TUI). When disabled, no notifications are sent.
        -- Notifications are deduplicated: each notification fires at most
        -- once per transition to review. The notified state is cleared
        -- when the task leaves review status.
}

rule ClearNeedsInput {
    -- When HookPreToolUse fires, update_status_if(running, running) resets
    -- sub_status to active via the auto-reset behavior.
    when: HookFired(hook: pre_tool_use, task: task)

    requires: task.sub_status = needs_input

    ensures: task.sub_status = SubStatus.default_for(running)  -- i.e. active

    @guidance
        -- sub_status = needs_input is set by HookNotification when the agent
        -- raises a notification. It is cleared when the agent resumes and
        -- HookPreToolUse fires, which calls:
        --   dispatch update <id> running
        -- The update_status_if auto-reset sets sub_status = active.
        -- This allows re-notification if the agent raises another notification.
}

rule RetryResume {
    when: RetryResume(task)

    requires: task.status = running
    requires: task.worktree != null

    ensures:
        if task.tmux_window != null:
            OldTmuxWindow.killed(window: task.tmux_window)
    ensures: task.sub_status = active
    ensures: task.tmux_window = TmuxWindow.created(name: "task-" + task.id)
    ensures: AgentLaunched(task: task, mode: resume)

    @guidance
        -- If the task already has a tmux window (e.g. a crashed or stale
        -- session), the existing window is killed before creating a fresh
        -- one. This tears down the old process cleanly.
}

rule RetryFresh {
    when: RetryFresh(task)

    requires: task.status = running

    -- Destroys existing worktree, resets to backlog, then re-dispatches
    ensures:
        if task.worktree != null:
            not exists task.worktree
    ensures: task.worktree = null
    ensures: task.tmux_window = null
    ensures: task.status = backlog
    ensures: task.sub_status = SubStatus.default_for(backlog)
    ensures: AgentLaunched(task: task, mode: standard)

    @guidance
        -- RetryFresh dispatches directly via the standard dispatch
        -- path, bypassing the DispatchTask rule's has_plan precondition.
        -- This means a task without a plan will be dispatched in
        -- standard mode rather than brainstorm mode.
}

-- == MCP Constraints ==

rule UpdateTaskViaMcp {
    when: McpUpdateTask(task, status?, sub_status?, plan?, title?, description?,
                        repo_path?, sort_order?, pr_url?, tag?, epic_id?)

    requires: status != null or sub_status != null or plan != null or title != null
              or description != null or repo_path != null
              or sort_order != null or epic_id != null

    -- Cannot set status to done or archived via MCP
    requires: status != done
    requires: status != archived

    -- sub_status must be valid for the task's current (or new) status
    requires:
        if sub_status != null:
            let effective_status = if status != null then status else task.status
            sub_status.is_valid_for(effective_status)

    ensures:
        if status != null: task.status = status
    ensures:
        if sub_status != null: task.sub_status = sub_status
        else if status != null: task.sub_status = SubStatus.default_for(status)
    ensures:
        if plan != null: task.plan = plan
    ensures:
        if title != null: task.title = title
    ensures:
        if description != null: task.description = description
    ensures:
        if repo_path != null: task.repo_path = repo_path
    ensures:
        if sort_order != null: task.sort_order = sort_order
    ensures:
        if pr_url != null: task.pr_url = pr_url
    ensures:
        if tag != null: task.tag = tag
    ensures:
        if epic_id != null: task.epic = Epic.find(epic_id)
    ensures: task.updated_at = now
}

rule ClaimTaskViaMcp {
    when: McpClaimTask(task, worktree, tmux_window)

    requires: task.status = backlog
    requires: worktree.path starts_with task.repo_path

    ensures: task.status = running
    ensures: task.sub_status = SubStatus.default_for(running)
    ensures: task.worktree = worktree
    ensures: task.tmux_window = tmux_window
    ensures: task.updated_at = now

    @guidance
        -- The implementation derives the repo root from the worktree path
        -- by stripping the /.worktrees/<slug> suffix. This is stricter than
        -- a simple starts_with check: the repo root must exactly match
        -- task.repo_path.
}

rule UpdateEpicViaMcp {
    when: McpUpdateEpic(epic, title?, description?, status?, plan?, sort_order?, repo_path?)

    requires: title != null or description != null or status != null
              or plan != null or sort_order != null or repo_path != null

    -- Cannot set status to archived via MCP
    requires: status != archived

    ensures:
        if title != null: epic.title = title
    ensures:
        if description != null: epic.description = description
    ensures:
        if status != null: epic.status = status
    ensures:
        if plan != null: epic.plan = plan
    ensures:
        if sort_order != null: epic.sort_order = sort_order
    ensures:
        if repo_path != null: epic.repo_path = repo_path
    ensures: epic.updated_at = now
}

rule ReportUsageViaMcp {
    when: McpReportUsage(task, cost_usd, input_tokens, output_tokens, cache_read_tokens?, cache_write_tokens?)

    ensures: TaskUsage.accumulate(
        task: task,
        cost_usd: cost_usd,
        input_tokens: input_tokens,
        output_tokens: output_tokens,
        cache_read_tokens: cache_read_tokens ?? 0,
        cache_write_tokens: cache_write_tokens ?? 0,
        updated_at: now
    )

    @guidance
        -- Upserts a single TaskUsage row for the given task. If a row
        -- already exists, numeric fields are summed with existing values.
        -- cache_read_tokens and cache_write_tokens default to zero when
        -- omitted by the caller.
}

rule SendMessageViaMcp {
    when: McpSendMessage(from_task, to_task, body)

    requires: from_task != null
    requires: to_task != null
    requires: to_task.worktree != null
    requires: to_task.tmux_window != null

    ensures: MessageDelivered(
        from: from_task,
        to: to_task,
        path: to_task.worktree + "/.claude-messages/" + from_task.id + "-" + timestamp() + ".md"
    )
    ensures: TmuxNotificationSent(to: to_task, about: message_received)

    @guidance
        -- Inter-agent messaging. An agent writes a message file into the
        -- target agent's worktree under .claude-messages/ and injects a
        -- tmux notification telling the target to read and delete it.
        -- The TUI shows a brief envelope flash on the target task's card
        -- via the message_flash tracking state.
        -- Both tasks must exist. The target must have an active worktree
        -- and tmux window (i.e. a running agent). The sender has no
        -- such constraint — it only needs to exist.
}

rule DispatchNextViaMcp {
    when: McpDispatchNext(epic)

    -- Intentionally looser than the TUI DispatchEpicSubtask rule:
    -- does not require epic.status = backlog. This allows running
    -- agents to dispatch sibling subtasks regardless of epic status.

    ensures:
        let candidates = epic.subtasks where status = backlog
        let next = sort_by_order(candidates).first
        if next != null:
            if next.has_plan:
                AgentLaunched(task: next, mode: implementation)
            else if next.tag = epic:
                AgentLaunched(task: next, mode: brainstorm)
            else if next.tag = feature:
                AgentLaunched(task: next, mode: plan)
            else:
                AgentLaunched(task: next, mode: standard)

    @guidance
        -- MCP tool for agents to dispatch the next backlog subtask of
        -- their epic. Uses the same dispatch mode routing as the TUI's
        -- DispatchEpicSubtask (plan/tag based). The task is transitioned
        -- to running with a provisioned worktree and tmux window.
        -- When no backlog subtasks remain, returns an informational
        -- message without error.
}

-- == Hook-Based Status Transitions ==
-- Claude Code hooks (PreToolUse, Stop, Notification) bridge the agent
-- session lifecycle to task status. These rules describe the CLI hook
-- script installed by `dispatch setup`.

rule HookPreToolUse {
    when: PreToolUse(task, tool_name)

    -- Skip dispatch MCP tool calls: these are management operations
    -- (get_task, wrap_up, update_task, etc.), not implementation work.
    -- Without this filter, wrap-up fails because get_task and wrap_up
    -- calls clobber review status before the handler can check it.
    requires: not tool_name starts_with "mcp__dispatch__"

    ensures: task.status = running
    ensures: task.sub_status = SubStatus.default_for(running)

    @guidance
        -- Fires on every non-dispatch tool use. The unconditional
        -- transition is correct: backlog -> running on first dispatch,
        -- review -> running on session resume, running -> running is
        -- a no-op. Only done/archived tasks should not be modified,
        -- but agents are never dispatched into done/archived worktrees.
        -- The sub_status reset to active (default for running) also
        -- clears needs_input when the agent resumes after a notification.
}

rule HookStop {
    when: Stop(task)

    requires: task.status = running

    ensures: task.status = review
    ensures: task.sub_status = SubStatus.default_for(review)
}

rule HookNotification {
    when: HookFired(hook: notification, task: task)
    requires: task.status = running

    ensures: task.sub_status = needs_input

    @guidance
        -- HookNotification fires when the agent raises a notification
        -- (e.g. a permission prompt). The hook calls:
        --   dispatch update <id> running --only-if running --sub-status needs_input
        -- This sets sub_status=needs_input while keeping status=running.
        -- The task appears in the Blocked visual column (running, needs_input).
        -- When the agent resumes, HookPreToolUse fires and update_status_if
        -- resets sub_status back to active (default for running).
}

-- == Epics ==

rule CreateEpic {
    when: CreateEpic(title, description?, repo_path, sort_order?)

    ensures: Epic.created(
        title: title,
        description: description,
        repo_path: repo_path,
        status: backlog,
        sort_order: sort_order,
        created_at: now,
        updated_at: now
    )
}

rule DispatchEpicPlanning {
    when: DispatchEpic(epic)

    requires: epic.status = backlog
    requires: !epic.has_plan
    requires: epic.active_subtasks.count = 0

    -- Creates a planning subtask and dispatches a planning agent.
    -- The planning agent brainstorms and writes an implementation plan
    -- for this epic.
    ensures:
        let planning_task = Task.created(
            title: "Plan: " + epic.title,
            description: "Planning subtask for epic: " + epic.title + "\n\n" + epic.description,
            repo_path: epic.repo_path,
            status: backlog,
            sub_status: SubStatus.default_for(backlog),
            epic: epic,
            created_at: now,
            updated_at: now
        )
        AgentLaunched(task: planning_task, mode: epic_planning)

    @guidance
        -- The planning task is dispatched directly via epic_planning
        -- mode, bypassing the standard DispatchTask flow. This is
        -- because the planning task has no plan — the agent's job is
        -- to create one. The dispatch provisions a worktree and tmux
        -- window and transitions the task to Running.
        -- When an epic has no plan but already has active subtasks,
        -- neither this rule nor DispatchEpicSubtask applies. The TUI
        -- handles this gracefully by showing "Epic has subtasks but
        -- no plan" without taking any action.
}

rule DispatchEpicSubtask {
    when: DispatchEpic(epic)

    requires: epic.status = backlog
    requires: epic.has_plan

    -- Dispatches the next backlog subtask of this epic, ordered by
    -- sort_order ascending (nulls treated as task ID, tie-broken by id ascending).
    -- If the subtask has a plan, it is dispatched for implementation.
    -- If not, it is dispatched for brainstorming.
    ensures:
        let candidates = epic.active_subtasks where status = backlog
        let next = sort_by_order(candidates).first
        if next != null:
            if next.has_plan:
                AgentLaunched(task: next, mode: implementation)
            else if next.tag = epic:
                AgentLaunched(task: next, mode: brainstorm)
            else if next.tag = feature:
                AgentLaunched(task: next, mode: plan)
            else:
                AgentLaunched(task: next, mode: standard)

    @guidance
        -- Routing is based on the subtask's plan and tag:
        --   has_plan        → implementation mode
        --   tag = epic    → brainstorm mode
        --   tag = feature → plan mode
        --   other           → standard mode (dispatch without plan)
        -- When no backlog subtasks remain, the TUI shows a status
        -- message instead of dispatching. This rule only fires when
        -- there is at least one backlog subtask.
}

rule EpicBatchWrapUp {
    when: EpicBatchWrapUp(epic, action)

    -- action: rebase | pr

    let review_tasks = epic.subtasks where status = review and worktree != null

    requires: review_tasks.count > 0

    ensures:
        for task in sort_by_order(review_tasks):
            if action = rebase:
                WrapUpRebase(task)
            else:
                WrapUpPr(task)

    @guidance
        -- Sequences rebase or PR creation across all review tasks in an
        -- epic that have a worktree. Tasks are processed one at a time in
        -- sort_order. On success, the next task is processed automatically.
        -- On conflict or failure, the queue pauses and reports the failing
        -- task — the user can resolve the conflict and resume or cancel.
        -- The MergeQueue tracks progress (completed count, current task,
        -- failed task) and can be cancelled at any time (Esc).
}

rule MoveEpicForward {
    when: MoveEpicStatus(epic, forward)

    requires: epic.status != done
    requires: epic.status != archived

    let next = next_status(epic.status)

    ensures: epic.status = next
    ensures: epic.updated_at = now
    ensures:
        if next = done:
            for task in epic.subtasks where tmux_window != null:
                task.tmux_window = null

    @guidance
        -- Uses the same next() progression as tasks:
        --   backlog -> running -> review -> done.
        -- Done and archived are terminal for forward movement.
        -- When moving to done, all subtask tmux windows are killed
        -- to clean up active agent sessions.
}

rule MoveEpicBackward {
    when: MoveEpicStatus(epic, backward)

    requires: epic.status != backlog
    requires: epic.status != archived

    let prev = prev_status(epic.status)

    ensures: epic.status = prev
    ensures: epic.updated_at = now

    @guidance
        -- Uses the same prev() progression as tasks:
        --   done -> review -> running -> backlog.
        -- Backlog and archived are terminal for backward movement.
}

rule ConfirmArchiveEpic {
    when: ConfirmArchiveEpic(epic)

    requires:
        epic.active_subtasks.count = 0
        or epic.active_subtasks.all(t => t.status = done)

    ensures: ConfirmationShown(epic, "Archive epic and all subtasks?")
}

rule ArchiveEpic {
    when: ArchiveEpic(epic)

    ensures:
        for task in epic.active_subtasks:
            ArchiveTask(task)
    ensures: not exists epic
}

rule DeleteEpic {
    when: DeleteEpic(epic)

    -- Deletes epic and all linked subtasks
    ensures:
        for task in epic.subtasks:
            not exists task
    ensures: not exists epic

    @guidance
        -- Worktrees and tmux windows are cleaned up best-effort for
        -- subtasks that have them before deletion.
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

@invariant RunningTaskHasWorktree
    -- Tasks dispatched via DispatchTask, BrainstormTask, or ClaimTaskViaMcp
    -- always have a worktree. However, manual forward movement (m key)
    -- can move a task to running without provisioning a worktree.
    -- The dispatch flow is the canonical path; manual moves are overrides.

@invariant DoneRequiresHumanConfirmation
    -- The Done status transition requires explicit human confirmation
    -- via the TUI. MCP tools cannot set status to done or archived.
    -- This is enforced in the McpUpdateTask rule preconditions and
    -- the ConfirmDone rule requiring review status.
    -- Exception: PrMerged transitions are automatic because the PR
    -- merge on GitHub constitutes human confirmation via the code
    -- review process. WrapUpRebase is human-initiated (TUI W+r or
    -- MCP wrap_up tool) and transitions directly to done.

@invariant DispatchMcpToolsAreTransparent
    -- Dispatch MCP tool calls (get_task, wrap_up, update_task, etc.)
    -- must not trigger automatic status transitions. They are management
    -- operations, not implementation work. The PreToolUse hook filters
    -- them out to prevent clobbering review status during wrap-up.
    -- However, non-MCP tools (Bash, Read, etc.) still fire PreToolUse
    -- and can set a review task to running. The wrap_up handler
    -- accepts any running or review task with a worktree.

@invariant EpicStatusRecalculation
    -- Epic status is persisted and recalculated via recalculate_epic_status.
    -- It moves both forward and backward to always reflect subtask reality.
    -- Derivation logic (checked in priority order):
    --   no active subtasks            => backlog
    --   all active subtasks done      => done
    --   any active subtask in review  => review
    --   any active subtask running    => running
    --   otherwise                     => backlog
    -- The derived status is compared to the current epic.status; it is
    -- applied whenever the derived status differs from the current status.
    --
    -- Epic substatus (display label for epic cards):
    --   backlog + no plan             => unplanned
    --   backlog + has plan            => planned
    --   running + any subtask blocked => "N blocked" (N = count of subtasks
    --     with sub_status in {needs_input, stale, crashed, conflict})
    --   running + no blocked          => active
    --   review + active merge         => wrapping up
    --   review + no active merge      => in review
    --   done/archived                 => done
    --
    -- Epic cards show colored status indicators (●N) for each non-zero
    -- subtask count by parent status, using the column palette colors.

@invariant SubStatusConsistency
    -- A task's sub_status must always be valid for its parent status:
    --   sub_status.is_valid_for(status) = true
    -- This is enforced at every status transition: when status changes,
    -- sub_status is reset to SubStatus.default_for(new_status) before
    -- being persisted. Individual handlers may then set a more specific
    -- sub_status (e.g., DetectStaleAgent sets stale, HookNotification
    -- sets needs_input) only after the reset.

@invariant SubStatusAutoreset
    -- Whenever task.status changes, task.sub_status is reset to
    -- SubStatus.default_for(new_status). This ensures that no invalid
    -- (status, sub_status) combinations are ever persisted.
    -- Every rule that changes status must also reset sub_status.
    -- Exception: rules that set status and then immediately set a
    -- specific sub_status override the default (e.g., HookNotification
    -- sets status=review then sub_status=needs_input).

------------------------------------------------------------
-- Open Questions
------------------------------------------------------------

-- Q1: Should stale/crashed detection trigger automatic status changes
--     (e.g., moving back to Backlog), or should it remain advisory-only
--     as it is today?
