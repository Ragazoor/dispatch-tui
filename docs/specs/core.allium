-- allium: 3
-- core.allium
--
-- Scope: Shared domain model for the dispatch system
-- Includes: External entities, enumerations, core entities, config, VisualColumn and FlattenedView concepts
-- Excludes: Rules, invariants (see tasks.allium, dispatch.allium, agent-health.allium,
--           pr-workflow.allium, split-pane.allium, mcp-task-tools.allium, epics.allium,
--           learnings.allium)

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

-- The git worktree and tmux window are provisioned externally.
-- The spec treats them as opaque handles.

external entity Worktree {
    path: String
    branch: String
}

external entity TmuxWindow {
    name: String
}

external entity TmuxPane {
    id: String       -- tmux pane identifier (e.g., "%42")
}

------------------------------------------------------------
-- Enumerations
------------------------------------------------------------

enum TaskTag { bug | feature | chore | pr_review | research | fix | dependabot }

-- UrlType classifies the single URL attached to a Task (see TaskUrl).
-- The type is stored explicitly rather than guessed from the URL string at
-- render time. Only pr-typed urls are polled for PR merge/close (see
-- pr-workflow.allium: PollPrStatus).
enum UrlType { pr | security_alert | issue | other }

-- FeedRole is the routing role of an epic within a PR-review feed hierarchy.
-- `none` is the default for ordinary epics; the other roles tag a sub-epic as a
-- destination bucket for PR items routed by feed signals (see feeds.allium: Signal).
enum FeedRole { none | reviews_parent | my_reviews | team_reviews | bots | cve }

enum TipsShowMode { always | new_only | never }

-- Legacy alias: "ready" maps to backlog
enum TaskStatus { backlog | running | review | done | archived }

-- SubStatus refines the parent status into a more precise state.
-- Valid combinations are constrained by SubStatus.is_valid_for(status).
-- When status changes, sub_status resets to SubStatus.default_for(new_status).
enum SubStatus {
    -- backlog / done / archived
    none

    -- running (and review where noted)
    active          -- agent is running normally
    needs_input     -- agent is blocked waiting for human interaction (Blocked visual column)
    stale           -- no PreToolUse hook event seen for longer than inactivity_timeout (time since last_pre_tool_use_at)
    crashed         -- tmux window disappeared unexpectedly
    conflict        -- rebase/merge encountered a conflict (valid for both running and review)

    -- review
    awaiting_review   -- PR created, no review decision yet
                      -- UI splits this into two visual sections based on runtime state:
                      --   "awaiting review" — tmux window alive (agent still active)
                      --   "awaiting merge"  — tmux window gone (detached, just waiting for merge)
    changes_requested -- reviewer requested changes
    approved          -- PR approved, ready to merge
}

-- Valid SubStatus values per parent status (enforced in the DB by a CHECK
-- constraint and in-code via SubStatus.is_valid_for):
--   backlog   : none
--   running   : active | needs_input | stale | crashed | conflict
--   review    : awaiting_review | changes_requested | approved | conflict
--   done      : none
--   archived  : none
--
-- Note: HookNotification only fires when task.status = running, setting
-- sub_status = needs_input. The resulting (running, needs_input) state
-- renders as the "Blocked" visual column. Legacy (review, needs_input)
-- rows from older hook behaviour were normalised to (review, awaiting_review)
-- by migration v16.

-- Default sub_status when transitioning to a new status:
--   backlog   -> none
--   running   -> active
--   review    -> awaiting_review
--   done      -> none
--   archived  -> none

-- LearningScope identifies what context a learning applies to.
-- Dispatch retrieval unions: user + repo:<this_repo> + epic:<this_epic> (if set).
-- task scope carries task-specific outcomes, retrieved on demand.
enum LearningScope { user | repo | epic | task }

-- LearningKind categorises what was learned.
-- procedural learnings, once approved, are injected as prompt-prefix instructions
-- ahead of the normal learnings section.
enum LearningKind {
    pitfall              -- a failure mode; agents should avoid or handle carefully
    convention           -- preferred code pattern or style in this context
    preference           -- the user's explicit working preference
    tool_recommendation  -- recommended tool or library for a given problem
    procedural           -- injected verbatim into matching dispatch prompts once approved
    landscape            -- codebase/system overview (service maps, module responsibilities)
}

-- LearningStatus controls whether an entry is active in retrieval.
-- New entries land as approved; humans can reject or archive via the TUI.
-- needs_review is set automatically when an agent returns a `wrong` verdict
-- for a previously approved entry; such entries surface in the human curation
-- queue and are excluded from prompt injection and query_learnings results
-- (treated like archived/rejected for retrieval purposes).
enum LearningStatus { approved | needs_review | rejected | archived }

-- VerdictKind captures an agent's evaluation of a retrieved learning, submitted
-- via the rate_learning MCP tool at any point during a task.
--   helped  — the learning applied and was useful (acts like an upvote)
--   wrong   — the learning misled the agent or is no longer accurate;
--             an approved learning routes to needs_review on receipt of `wrong`
enum VerdictKind { helped | wrong }

-- RetrievalSource records how a learning was surfaced to a task's agent.
--   prompt_injection — included in the tiered "Validated knowledge" block
--                      prepended to the dispatch prompt
--   procedural       — prepended verbatim as a procedural-prefix instruction
--   query_learnings  — returned by an explicit query_learnings MCP call
enum RetrievalSource { prompt_injection | procedural | query_learnings }

-- WrapUpMode records the preferred wrap-up path for a task, set at creation
-- time by the user or agent. When set, the /wrap-up skill honours it instead
-- of prompting the user.
--   rebase — rebase the task branch onto base_branch and fast-forward it
--   pr     — agent authors and creates a draft PR (no git ops done by dispatch)
--   done   — close without any git operations; task moves to Done directly
enum WrapUpMode { rebase | pr | done }

------------------------------------------------------------
-- Storage Boundary Validation
------------------------------------------------------------

-- Any entity read from storage whose enum fields contain an unrecognised
-- string value must fail the read operation with an error rather than
-- silently defaulting to a fallback variant.
--
-- Rationale: silent defaults mask data-integrity bugs (corrupt migrations,
-- manual DB edits, schema drift) and produce subtly wrong in-memory state
-- that is hard to trace back to the real cause. A hard read error surfaces
-- the problem immediately. The TUI and MCP error-display paths already
-- handle DB errors gracefully, so a hard error is safe.
--
-- This applies to all enum columns: TaskStatus, SubStatus, TaskTag,
-- WrapUpMode, LearningKind, LearningScope, LearningStatus, TipsShowMode.
-- It also applies to JSON-encoded columns (e.g. labels, tags): malformed
-- JSON must return an error rather than an empty list.

------------------------------------------------------------
-- Entities and Variants
------------------------------------------------------------

-- TaskUrl is the single typed URL attached to a Task. The url_type is stored
-- explicitly (not inferred from the string at render time), so the system
-- knows whether the URL is a PR, security alert, issue, or something else.
value TaskUrl {
    url: String
    url_type: UrlType
}

entity Task {
    title: String
    description: String
    repo_path: String
    status: TaskStatus
    sub_status: SubStatus
    worktree: Worktree?
    tmux_window: TmuxWindow?
    plan_path: String?    -- filesystem path to the implementation plan file
    epic: Epic?
    url: TaskUrl?    -- subsumes the former pr_url: the single typed URL attached to this task
    tag: TaskTag?
    sort_order: Integer?  -- shared namespace for feed-driven and user-set ordering; lower sorts first via COALESCE(sort_order, id) ASC
    labels: Set<String> = {}  -- free-form badges rendered on the card's second line; set by feed scripts via FeedItem.labels or by future TUI editors
    base_branch: String = "main" -- the branch this task rebases onto / targets for PRs
    external_id: String?  -- stable identifier for tasks sourced from a feed epic (see feeds.allium); null for hand-created tasks. Unique per (epic, external_id) when set.
    last_pre_tool_use_at: Timestamp?  -- wallclock of the most recent PreToolUse hook; null when the agent has never tooled (or after Stop)
    last_notification_at: Timestamp?  -- wallclock of the most recent Notification hook; null when no notification is pending (or after Stop)
    pr_learnings_gate_shown_at: Timestamp?  -- set once when the PrLearningsGate fires; null means the gate has never fired for this task
    wrap_up_mode: WrapUpMode?  -- preferred wrap-up path; null means decide at wrap-up time
    created_at: Timestamp
    updated_at: Timestamp

    transitions status {
        backlog -> running
        running -> review
        running -> backlog
        running -> done
        review -> done
        review -> running
        done -> review
        done -> archived
        -- Archive is accepted from any non-archived status
        backlog -> archived
        running -> archived
        review -> archived
        terminal: archived
    }

    -- Derived
    has_plan: plan_path != null
    is_stale: sub_status = stale
    is_crashed: sub_status = crashed
    is_detached: worktree != null and tmux_window = null
                 and status in {running, review}
                 and sub_status != conflict
    -- pr_number is parsed from the trailing numeric segment of url.url, but
    -- only when the url is pr-typed; otherwise null. Not persisted; computed
    -- on demand.
    pr_number: if url != null and url.url_type = pr: pr_number_from_url(url.url) else: null
}

entity Epic {
    title: String
    description: String
    status: TaskStatus
    plan_path: String?    -- filesystem path to the implementation plan file
    sort_order: Integer?
    auto_dispatch: Boolean = false
    parent: Epic?         -- null for root epics; set for nested sub-epics
    feed_command: String?           -- shell command that emits FeedItem JSON (see feeds.allium); null for non-feed epics
    feed_interval_secs: Integer?    -- per-epic poll cadence in seconds; null falls back to config.default_feed_interval
    group_by_repo: Boolean = false      -- when true, feed tasks are grouped into sub-epics by repo name (see feeds.allium)
    feed_role: FeedRole = none      -- routing role within a feed hierarchy; `none` for ordinary epics (see feeds.allium: Signal)
    created_at: Timestamp
    updated_at: Timestamp

    has_plan: plan_path != null
    is_root: parent = null
    is_feed: feed_command != null

    -- DB-level invariant from migration v65: at most one sub-epic per
    -- (parent, feed_role) when feed_role != none. Ordinary epics
    -- (feed_role = none) are exempt — any number may share a parent.
    -- Enforced in the DB by a partial unique index on (parent_id, feed_role)
    -- WHERE feed_role != 'none'.
    invariant UniqueFeedRolePerParent {
        for a in Epics:
            for b in Epics:
                a != b and a.feed_role != none and a.parent = b.parent
                    implies (a.feed_role != b.feed_role or b.feed_role = none)
    }

    subtasks: Task with epic = this
    active_subtasks: subtasks where status != archived
    subtask_statuses: active_subtasks -> status

    sub_epics: Epic with parent = this
    active_sub_epics: sub_epics where status != archived

    -- Heterogeneous set used for status recalculation and dispatch ordering.
    -- Combines active tasks and active sub-epics; each element contributes
    -- its .status value to the parent's recalculated status.
    active_children: active_subtasks + active_sub_epics
}

entity SavedRepoPath {
    path: String             -- filesystem path, unique across all saved paths
    last_used: Timestamp     -- updated on each use; drives recency ordering
    verify_command: String?  -- single-line shell command run by agents before declaring work complete, e.g. "cargo test"

    invariant VerifyCommandSingleLine {
        verify_command = null or not (verify_command.contains("\n") or verify_command.contains("\r"))  -- short-circuits: rhs only evaluated when verify_command != null
    }
}

-- Learning captures knowledge a dispatched agent discovered. Entries land as
-- approved immediately and are injected into future dispatch prompts for the
-- matching scope; humans curate the active pool by rejecting or archiving entries
-- via the TUI knowledge-base panel.
entity Learning {
    kind: LearningKind
    summary: String          -- one-sentence digest; injected into dispatch prompts
    detail: String?          -- extended context; shown in TUI review panel
    scope: LearningScope
    scope_ref: String?       -- qualifies the scope:
                             --   scope=repo    → repo_path of the target repository
                             --   scope=epic    → string form of epic_id
                             --   scope=task    → string form of task_id
                             --   scope=user    → null (no qualifier needed)
    tags: Set<String>        -- free-form labels for filtering (e.g. "rust", "testing")
    status: LearningStatus
    source_task: Task?       -- the task whose agent proposed this entry; null for human-authored entries
    upvote_count: Integer -- times an agent confirmed this learning as applicable
    last_upvoted_at: Timestamp?
    created_at: Timestamp
    updated_at: Timestamp

    transitions status {
        approved -> rejected
        approved -> archived
        approved -> needs_review     -- system-driven: a `wrong` verdict on an
                                     -- approved learning flags it for human curation
        needs_review -> approved     -- human-driven: curator confirms the entry is fine
        needs_review -> rejected     -- human-driven: curator removes the entry
        needs_review -> archived     -- human-driven: curator archives the entry
        terminal: rejected, archived
    }

    -- Derived
    is_active: status = approved

    -- True when this learning is relevant to the given task's dispatch.
    -- task-scoped learnings are excluded from auto-injection; they surface
    -- via query_learnings on demand (see learnings.allium).
    applies_to_dispatch(task):
        status = approved
        and (
            scope = user
            or (scope = repo and scope_ref = task.repo_path)
            or (scope = epic and task.epic != null and scope_ref = str(task.epic.id))
        )

    invariant ScopeRefConsistency {
        (scope = user implies scope_ref = null)
        and (scope != user implies scope_ref != null)
    }
}

-- Retrieval records a single occasion on which a Learning was surfaced for a
-- task. One row is inserted per surfacing event, so repeated exposure
-- accumulates as separate rows. Used to drive rate_learning verdict validation
-- (a verdict's learning_id must have a matching retrieval row for the same
-- task) and to support telemetry on which entries actually fire.
entity Retrieval {
    task: Task
    learning: Learning
    source: RetrievalSource
    retrieved_at: Timestamp
}

-- Todo is a lightweight, ordered checklist item independent of the task board.
-- sort_order gives an explicit, user-controllable ordering and done marks
-- completion. The view sorts done items below open ones.
-- id is the stable identifier (TodoId in implementing code); modelled as
-- Integer here, matching Tip.id — the only other persisted entity in this
-- file that declares an explicit id. (Task/Epic/Learning leave identity
-- implicit and reference it via `.id`.)
entity Todo {
    id: Integer
    title: String
    done: Boolean
    sort_order: Integer
    created_at: Timestamp

    @guidance
        -- Lifecycle (rules live with behaviour, as in tasks.allium; recorded
        -- here as guidance because core.allium carries no rule blocks):
        --
        -- CreateTodo: a new Todo is appended at the end of the list. Its
        --   sort_order is strictly greater than every existing Todo's
        --   sort_order (e.g. max(sort_order) + 1), and done is false.
        --
        -- ToggleTodoDone: toggling flips done (false -> true, true -> false).
        --   No other field changes. The rendered list sorts done items below
        --   open items; relative order within each group follows sort_order.
        --
        -- ReorderTodo: reordering swaps a Todo's sort_order with that of the
        --   adjacent Todo in the desired direction. Exactly two rows change;
        --   all other Todos are untouched. A reorder past either end is a no-op.
        --
        -- ClearDoneTodos: clearing removes every Todo whose done is true.
        --   Open Todos (done = false) are untouched.
}

-- A rate_learning call evaluates a retrieved learning. The verdict is no
-- longer persisted (migration v62 dropped the learning_verdicts table); the
-- VerdictKind enum still describes the in-flight effects applied on receipt:
--   helped → increments learning.upvote_count and updates last_upvoted_at
--   wrong  → if the learning is approved, transitions it to needs_review
-- See learnings.allium for the rule that applies these effects.

-- SplitPane is a runtime-only UI concept (not persisted) that tracks
-- whether the TUI is displaying a task's tmux window as a side pane.
-- It is modelled here because task lifecycle events (finish, PR creation)
-- must coordinate with split pane state.

entity SplitPane {
    active: Boolean = false
    focused: Boolean = true
    pane: TmuxPane?
    pinned_task: Task?

    @guidance
        -- At most one task can be pinned at a time.
        -- When active is true, pane must be non-null.
        -- pinned_task may be null (empty shell in the pane).
        -- focused tracks whether the TUI pane has tmux focus.
        -- Driven by crossterm FocusGained/FocusLost events
        -- (requires tmux `focus-events on`). Defaults to true.
        -- Reset to true on split entry and exit.
}

-- TipsState persists the user's tips preferences across sessions.
-- There is exactly one row in the DB (singleton).
entity TipsState {
    seen_up_to: Integer    -- highest tip id shown in any previous session; 0 = never shown
    show_mode: TipsShowMode

    @guidance
        -- Persisted to a single-row `tips_state` DB table (migration v36).
        -- seen_up_to acts as a watermark: any Tip with id > seen_up_to is "new".
        -- Updated on tips overlay close, reflecting the tip id viewed at that moment.
}

-- Tip is a runtime-only concept (embedded at compile time, never persisted).
-- Tips are loaded from numbered markdown files in src/tips/ via include_str!.
value Tip {
    id: Integer       -- numeric prefix from filename (e.g., 001 → 1)
    title: String     -- extracted from the first ## heading in the file
    body: String      -- everything after the first ## heading

    is_new(state): id > state.seen_up_to
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    tick_interval: Duration = 2.seconds
    inactivity_timeout: Duration = 10.minutes
    status_message_expiry: Duration = 5.seconds
    notifications_enabled: Boolean = false
    pr_poll_interval: Duration = 30.seconds
    default_feed_interval: Duration = 30.seconds   -- default cadence for feed epics with no explicit feed_interval_secs (see feeds.allium)
    mcp_port: Integer = 3142                         -- MCP server port (override via DISPATCH_PORT env var)
    -- Fallback when the repo has no origin/HEAD symbolic-ref.
    -- Runtime code inspects `git symbolic-ref refs/remotes/origin/HEAD`
    -- first and only falls back to this literal when detection fails.
    default_branch: String = "main"
    tips_show_mode: TipsShowMode = always

    -- Staleness thresholds used by card age rendering and Staleness::from_age.
    fresh_threshold: Duration = 3.days
    aging_threshold: Duration = 7.days
    weeks_threshold: Duration = 14.days

    -- When true, the MCP wrap_up response includes a nudge asking the agent
    -- to propose learnings before finishing. Prompt encouragement only;
    -- agents may wrap up without proposing. (see learnings.allium: WrapUpReflection)
    learning_reflection_enabled: Boolean = true
}

------------------------------------------------------------
-- VisualColumn
------------------------------------------------------------

-- The kanban board has two separate index spaces:
--
-- 1. VisualColumn indices (0–7): 8 sub-columns for task-status rendering,
--    each corresponding to a (parent_status, sub_status) pair or set.
--
-- 2. Navigation column indices (0–5): the h/l cursor positions. Running and
--    Review sub-columns are grouped under a single navigation position each.
--
-- VisualColumn layout (task-status rendering, left to right):
--
--   vcol# | Label            | parent_status | sub_statuses
--   ------+------------------+---------------+------------------------------
--       0 | Backlog          | backlog       | none
--       1 | Active           | running       | active
--       2 | Blocked          | running       | needs_input
--       3 | Stale            | running       | stale, crashed, conflict
--       4 | PR Created       | review        | awaiting_review, conflict  (split into "awaiting review" / "awaiting merge" sections by detach state)
--       5 | Revise           | review        | changes_requested
--       6 | Approved         | review        | approved
--       7 | Done             | done          | none
--
-- Navigation column layout (h/l cursor, left to right):
--
--   nav# | Label            | kind         | vcol range
--   -----+------------------+--------------+----------
--      0 | Backlog          | task-status  | vcol 0
--      1 | Running          | task-status  | vcols 1–3
--      2 | Review           | task-status  | vcols 4–6
--      3 | Done             | task-status  | vcol 7
--      4 | Archive          | edge         | —
--
-- Edge column (Archive):
--   - Archive (nav index 4) is the rightmost navigation column. It is only
--     rendered when it has keyboard focus (dynamic visibility). When focused
--     it shows archived tasks; when unfocused it is invisible.
--   - The edge column has no parent_status or sub_statuses; it is
--     outside the task-status model.
--
-- Navigation:
--   - h/l (or Left/Right) moves the cursor between nav indices 0–4.
--   - At nav index 0 (Backlog), h/Left is a no-op (already at leftmost edge).
--   - At nav index 4 (Archive), l/Right is a no-op (already at rightmost edge).
--   - h/Left closes the Archive column (navigates left to Done).
--   - In ViewMode::Epic the nav index is clamped to [0, 3]: Archive is not
--     reachable from the epic view.
--   - The edge column persists across data refreshes: a RefreshTasks event
--     does not move the cursor out of the edge column.
--   - Parent group boundaries are annotated in the column header.
--   - A task's visual column is determined by (task.status, task.sub_status).

value VisualColumn {
    label: String
    parent_status: TaskStatus
    sub_statuses: List<SubStatus>

    -- A task belongs to this column when:
    --   task.status = parent_status and task.sub_status in sub_statuses
    contains(task): task.status = parent_status and task.sub_status in sub_statuses
}

------------------------------------------------------------
-- FlattenedView
------------------------------------------------------------

-- The task board has two rendering modes: the default hierarchical mode
-- and a flattened mode that surfaces every descendant task of the
-- current scope directly into its visual column, bypassing the
-- epic/sub-epic grouping.
--
-- Intent: when work is spread across nested epics, users often need to
-- see at a glance which tasks are running, blocked, or awaiting review
-- without drilling into each epic individually. The flattened mode
-- answers that need without changing any task data.
--
-- Scope: determined by the current view.
--   - Main board view: scope is every non-archived task that passes the
--     active repo filter, regardless of epic membership or depth.
--   - Epic view: scope is every non-archived task whose epic chain
--     (epic_id, then epic.parent, recursively) roots at the current
--     epic, plus any task directly under it. The repo filter still
--     applies.
--
-- Rendering:
--   - Task cards appear in their normal visual column, determined by
--     (task.status, task.sub_status), exactly as in hierarchical mode.
--   - Epic cards are not rendered in flattened mode — neither root
--     epics on the board nor sub-epics inside an epic view.
--   - Task cards belonging to an epic show the epic's id (rendered
--     in a distinguishing colour) appended to the card's indicator
--     line, so epic membership remains visible on the card.
--
-- State model:
--   - Flattened is a single board-level boolean, toggled by the user.
--   - The value is preserved as the user navigates into sub-epics and
--     back out: drilling down or exiting an epic does not change it.
--   - It is session-scoped and does not persist across app restarts.
--
-- Interaction:
--   - Task-card actions (dispatch, go-into-task, expand-description)
--     behave identically in both modes. A flattened task card always
--     acts on the task itself, never on its ancestor epic.
--   - To navigate into an epic, the user first turns flattened mode
--     off; epic cards then become visible and selectable.

value FlattenedView {
    active: Boolean

    -- In flattened mode, the board renders only tasks in scope, never
    -- epics. In hierarchical mode (active = false), rendering follows
    -- the default rules (root epics on the board, sub-epics and direct
    -- tasks inside each epic view).
    renders_epics: not active

    -- A task is in scope for the current view when flattened is active.
    in_scope(task, view):
        not task.archived
        and task.repo_path in view.active_repo_filter
        and (view.is_board or task.is_descendant_of(view.current_epic))
}

-- == Only Active Filter ==

-- only_active_filter:
--   When view.only_active is true, only tasks where tmux_window is set
--   are included in tasks_for_current_view. This filter is applied in
--   addition to the repo filter.
--   The filter is toggled via the [f] overlay's "Active sessions only"
--   row (cursor position 0, Space to toggle).
--   The filter is session-scoped and does not persist across app restarts.

-- == Title Search Filter ==

-- title_search_filter:
--   When view.search_query is non-empty, only tasks whose title matches the
--   query are included in tasks_for_current_view. Match is a case-insensitive
--   forward subsequence (every query char appears in the title, in order),
--   the same predicate used by the repo-path picker (fuzzy_matches). An empty
--   query matches every task. This filter is applied in addition to the repo
--   filter and the only-active filter (logical AND).
--   Lifecycle: the [/] key opens a live search bar and the board narrows as
--   the user types. [Enter] keeps the query active and closes the bar (the
--   filter persists, with a [/query] indicator shown on the board). [Esc]
--   in the bar restores the query that was active before the bar opened.
--   [Esc] on the board (bar closed) with an active query clears it.
--   The query is session-scoped and does not persist across app restarts.
--   Cursor re-clamping on query change is covered by selection_preservation.

-- == Cursor Selection Preservation ==

-- selection_preservation:
--   When the cursor has an anchor (a task or epic ID) and column items are recomputed
--   (on any status change, task movement, filter change, or data refresh), the cursor
--   position is resolved by locating the anchor item in the new item list.
--
--   If the anchor item is found: the cursor moves to the item's new column and row,
--   following the item if it changed columns.
--
--   If the anchor item is not present (deleted or moved outside board scope): the cursor
--   clamps to the nearest valid position in the current column.
--
--   When the cursor is on the select-all column header (on_select_all = true), the anchor
--   is None and the header state is preserved across refreshes.
