-- allium: 3
-- tasks.allium
--
-- Scope: Task lifecycle, agent health, hooks, notifications, split pane, MCP task tools
-- Excludes: Epic lifecycle (see epics.allium), domain model (see core.allium)

use "./core.allium" as core

------------------------------------------------------------
-- Rules
------------------------------------------------------------

-- == Task Creation ==

rule CreateTask {
    when: CreateTask(title, description, repo_path, plan?, epic?, tag?, sort_order?, base_branch?)

    ensures: core/Task.created(
        title: title,
        description: description,
        repo_path: repo_path,
        status: backlog,
        sub_status: core/SubStatus.default_for(backlog),
        plan_path: plan,
        epic: epic,
        tag: tag,
        sort_order: sort_order,
        base_branch: base_branch ?? config.default_branch,
        created_at: now,
        updated_at: now
    )

    @guidance
        -- base_branch is set from user input during TUI task creation
        -- (InputBaseBranch step). If omitted (e.g. quick-dispatch), it
        -- defaults to config.default_branch (usually "main").
        -- When invoked from the epic view, epic is set to the
        -- current epic, auto-linking the new task as a subtask.
}

rule CreateQuickTask {
    when: QuickDispatch(repo_path, epic_id?)

    ensures:
        let task = core/Task.created(
            title: "Quick task",
            description: "",
            repo_path: repo_path,
            status: backlog,
            sub_status: core/SubStatus.default_for(backlog),
            epic: if epic_id != null then core/Epic.find(epic_id) else null,
            base_branch: detect_default_branch(repo_path),
            created_at: now,
            updated_at: now
        )
        AgentLaunched(task: task, mode: quick)

    @guidance
        -- Triggered by the Shift+D (capital D) TUI key. When no saved
        -- repo paths exist, the key is a no-op. When exactly one saved
        -- repo path exists, it is used directly. When multiple saved
        -- paths exist, a picker (InputMode::QuickDispatch) is shown,
        -- which renders the shared RepoPathPicker surface (see below).
        -- Per the picker's NoPrintableShortcut guarantee, j/k and
        -- digits filter; they do not navigate or select.
        -- When invoked from the epic view, epic_id is set to the
        -- current epic, linking the quick task as a subtask.
        -- The task title defaults to "Quick task"; the agent is expected
        -- to rename the task via update_task once the user describes the
        -- goal. The quick-dispatch agent uses a dedicated prompt that
        -- asks the user what they want to achieve, then instructs the
        -- agent to write a plan in docs/plans/ and attach it.
        -- base_branch is resolved from `git symbolic-ref
        -- refs/remotes/origin/HEAD` against repo_path, falling back to
        -- "main" when origin/HEAD is unavailable. This prevents
        -- dispatch failures on repos whose default branch is not main.
        -- AgentLaunched fires immediately after creation; the task
        -- transitions through the same dispatch path as DispatchTask
        -- (Backlog -> Running, worktree and tmux window provisioned).
}

rule RecordRepoPath {
    when: RepoPathUsed(path)

    ensures: core/SavedRepoPath.created_or_updated(
        path: path,
        last_used: now
    )

    @guidance
        -- Fires whenever a repo path is used to create a task or epic
        -- through the TUI:
        --   - TUI task creation (after InputBaseBranch submission)
        --   - TUI quick-dispatch (Shift+D)
        --   - TUI epic creation
        -- The path is first expand_tilde'd. If a SavedRepoPath with
        -- the same path already exists, last_used is bumped to now;
        -- otherwise a new record is created.
        -- Not fired for MCP task creation (create_task tool) — that
        -- skips repo path persistence. (There is no CLI for task
        -- creation; tasks are created exclusively via MCP.) Cap
        -- enforcement (maximum stored paths) is an implementation
        -- detail and not specified here.
}

-- == Dispatch ==

rule DispatchTask {
    when: DispatchTask(task)

    requires: task.status = backlog
    -- Tasks with a plan always dispatch. Tasks without a plan dispatch
    -- unless they carry a tag that routes to a dedicated agent
    -- (pr_review, research, fix, dependabot).
    requires: task.has_plan = true
              or task.tag not in {pr_review, research, fix, dependabot}

    ensures: task.status = running
    ensures: task.sub_status = core/SubStatus.default_for(running)
    ensures: task.last_pre_tool_use_at = now
    ensures: task.worktree = core/Worktree.created(
        path: task.repo_path + "/.worktrees/" + task.id + "-" + slugify(task.title),
        branch: task.id + "-" + slugify(task.title)
    )
    ensures: task.tmux_window = core/TmuxWindow.created(name: "task-" + task.id)
    ensures: AgentLaunched(task: task, mode: standard)

    @guidance
        -- Before creating the worktree, `git fetch origin <base_branch>` is
        -- run in the repo root to update the remote-tracking ref. On success,
        -- the worktree branch is created from `origin/<base_branch>` so the
        -- agent starts from the latest remote state. On fetch failure (no
        -- origin remote, network error), the step is skipped silently and the
        -- worktree falls back to the local base branch.
        -- Specifically: `git worktree add -B <branch> <path> origin/<base_branch>`.
        -- If the worktree directory already exists on disk (pre-created),
        -- the fetch and git worktree add steps are both skipped.
        -- The launched Claude command includes a plugin-dir flag so
        -- the agent discovers dispatch plugin skills (e.g. /wrap-up).
        -- The agent prompt is prepended with a `git rebase <base>`
        -- preamble so the agent picks up latest base changes on first
        -- run (also useful when an agent is resumed after time passes).
        -- Task-agent dispatches launch Claude in auto mode by default —
        -- i.e. without a --permission-mode flag — so agents can edit
        -- files without per-edit approval. The Research agent is the
        -- sole exception: it launches with --permission-mode plan so
        -- investigation stays read-only. The prompt content — not the
        -- permission flag — differentiates the other modes. (Review and
        -- fix agents dispatched via MCP tools use --permission-mode
        -- acceptEdits instead.)

        -- == Unified prompt skeleton ==
        -- Every task-agent prompt produced by build_prompt /
        -- build_quick_dispatch_prompt / build_epic_planning_prompt has
        -- the same shape:
        --
        --   {rebase_preamble}              (git rebase <base> instruction)
        --   {worktree_preamble}            ("Always work from this
        --                                    worktree folder — do not
        --                                    `cd` to the parent repo
        --                                    or other directories.")
        --   {preamble}                     (one line, mode-specific)
        --   <blank>
        --   Task:                          (shared task_block, always)
        --     ID: ...
        --     Title: ...
        --     Description: ...
        --     EpicId: ...                  (only if task.epic != null)
        --   {epic sibling-communication}   (only if task.epic != null)
        --   <blank>
        --   {validated_knowledge}          (tiered learnings; see
        --                                    AugmentDispatchPromptWithLearnings)
        --   {repo_map}                     (optional ctags-derived structural
        --                                    summary; see AugmentDispatchPromptWithRepoMap.
        --                                    Empty when generation is disabled,
        --                                    the binary is missing, or the
        --                                    invocation fails / times out.)
        --   {mode_addendum}                (mode-specific block)
        --   <blank>
        --   {tdd_instruction}              (shared verbatim)
        --   {allium_instruction}           (shared verbatim)
        --   {mcp_tools_instruction}        (shared verbatim)
        --   {learning_tools_instruction}   (shared verbatim — points the
        --                                    agent at the action-checkpoint
        --                                    skills: /codebase-knowledge,
        --                                    /code-conventions,
        --                                    /test-conventions,
        --                                    /pr-workflow,
        --                                    /dispatch-workflow,
        --                                    /troubleshoot, /improvement,
        --                                    /lint, /learnings)
        --   {wrap_up_instruction}          (shared verbatim, universal)
        --
        -- DispatchTask emits one of two variants of build_prompt:
        --   * has_plan = false: preamble "Your task is:" and the addendum
        --     is plan_or_brainstorm_instruction (conditional: if vague
        --     use /brainstorming, else write the plan directly under
        --     docs/plans/ and attach via update_task).
        --   * has_plan = true: preamble "Your task is:" and the addendum
        --     references the plan path with a "review and ask permission
        --     before implementing" instruction.
        -- CreateQuickTask (build_quick_dispatch_prompt) is the exception:
        -- its preamble is "You are working interactively with the user."
        -- rather than "Your task is:" — quick dispatch begins as an
        -- interactive conversation where the agent elicits the goal
        -- before writing a plan.
        -- task_block does NOT include a Tag: line — tag is metadata for
        -- the kanban board, not for prompt context (it would invite the
        -- agent to over-fit on labels rather than the description).
        -- wrap_up_instruction is shared by every dispatched agent so the
        -- whole task lifecycle terminates the same way regardless of
        -- mode (the wording covers plan-attach, work-package-creation,
        -- and implementation completion).
        -- DispatchPrReviewTask and DispatchResearchTask are exceptions
        -- to the unified trailing block: their prompts include only
        -- {mcp_tools_instruction} and omit tdd, allium, learning_tools,
        -- and wrap_up. DispatchFixTask uses the full trailing block.
}

rule DispatchPrReviewTask {
    when: DispatchPrReviewTask(task)

    requires: task.status = backlog
    requires: task.has_plan = false
    requires: task.tag = pr_review

    ensures: task.status = running
    ensures: task.sub_status = core/SubStatus.default_for(running)
    ensures: task.last_pre_tool_use_at = now
    ensures: task.worktree = core/Worktree.created(
        path: task.repo_path + "/.worktrees/" + task.id + "-" + slugify(task.title),
        branch: task.id + "-" + slugify(task.title)
    )
    ensures: task.tmux_window = core/TmuxWindow.created(name: "task-" + task.id)
    ensures: AgentLaunched(task: task, mode: pr_review)

    @guidance
        -- PR review mode: the agent extracts the PR URL from the task
        -- description, uses gh pr diff to assess the diff size, then
        -- runs /anthropic-review-pr:review-pr which orchestrates
        -- sub-reviewers (security, code-quality, test-coverage, performance,
        -- documentation). The agent makes no code changes.
        -- Uses --permission-mode plan (same as other task dispatches).
        -- Prompt note: build_pr_review_prompt emits a stripped-down
        -- trailing block — only {mcp_tools_instruction}, no tdd,
        -- allium, learning_tools, or wrap_up. The PR review flow is
        -- self-contained and terminates without the standard wrap-up.
        -- Although the shared {wrap_up_instruction} is omitted, the
        -- bespoke prompt body still includes the literal cue
        -- "When the review is complete, call wrap_up to finish this task."
        -- so the agent has an explicit termination signal
        -- (src/dispatch/prompts.rs).
}

rule DispatchDependabotTask {
    when: DispatchDependabotTask(task)

    requires: task.status = backlog
    requires: task.has_plan = false
    requires: task.tag = dependabot

    ensures: task.status = running
    ensures: task.sub_status = core/SubStatus.default_for(running)
    ensures: task.last_pre_tool_use_at = now
    ensures: task.worktree = core/Worktree.created(
        path: task.repo_path + "/.worktrees/" + task.id + "-" + slugify(task.title),
        branch: task.id + "-" + slugify(task.title)
    )
    ensures: task.tmux_window = core/TmuxWindow.created(name: "task-" + task.id)
    ensures: AgentLaunched(task: task, mode: dependabot)

    @guidance
        -- Source: feed scripts only. The TUI tag picker (src/tui/input.rs)
        -- intentionally does NOT bind a key to the Dependabot tag; tasks
        -- with this tag are created exclusively by feed scripts that emit
        -- tag: "dependabot" (e.g. scripts/fetch-dependabot.sh).
        --
        -- Dependabot mode: the agent vets a Dependabot PR (dep-only? bump
        -- kind? CI green? changelog?) and either auto-approves and enables
        -- auto-merge for low-risk bumps, or asks the user a specific
        -- question via chat for anything uncertain. Escalation is a chat
        -- question, NOT update_review_status (the pr_workflow_states
        -- pipeline is legacy and unread by the active UI).
        --
        -- Auto-merge policy (build_dependabot_review_prompt):
        --   * patch + CI green + dep-only -> auto-merge
        --   * minor + CI green + dep-only + clean changelog -> auto-merge
        --   * everything else -> ask user
        --
        -- Uses Claude's default permission mode (no --permission-mode flag) —
        -- the agent needs to run gh pr review/merge, so the read-only plan
        -- mode would be wrong here.
        -- Prompt note: build_dependabot_review_prompt emits a stripped-down
        -- trailing block — only {mcp_tools_instruction}, no tdd, allium,
        -- learning_tools, or wrap_up. The bespoke prompt body still
        -- includes "call wrap_up to finish this task" so the agent has an
        -- explicit termination signal.
}

rule DispatchResearchTask {
    when: DispatchResearchTask(task)

    requires: task.status = backlog
    requires: task.has_plan = false
    requires: task.tag = research

    ensures: task.status = running
    ensures: task.sub_status = core/SubStatus.default_for(running)
    ensures: task.last_pre_tool_use_at = now
    ensures: task.worktree = core/Worktree.created(
        path: task.repo_path + "/.worktrees/" + task.id + "-" + slugify(task.title),
        branch: task.id + "-" + slugify(task.title)
    )
    ensures: task.tmux_window = core/TmuxWindow.created(name: "task-" + task.id)
    ensures: AgentLaunched(task: task, mode: research)

    @guidance
        -- Research mode: the agent investigates the topic in the task
        -- description by reading code, docs, and external resources.
        -- It presents findings to the user and waits for instructions.
        -- The agent makes no code changes and does not wrap up autonomously.
        -- Uses --permission-mode plan (same as other task dispatches).
        -- Prompt note: build_research_prompt emits a stripped-down
        -- trailing block — only {mcp_tools_instruction}, no tdd,
        -- allium, learning_tools, or wrap_up. The research agent
        -- presents findings interactively and does not terminate via
        -- the standard wrap-up flow.
}

rule DispatchFixTask {
    when: DispatchFixTask(task)

    requires: task.status = backlog
    requires: task.has_plan = false
    requires: task.tag = fix

    ensures: task.status = running
    ensures: task.sub_status = core/SubStatus.default_for(running)
    ensures: task.last_pre_tool_use_at = now
    ensures: task.worktree = core/Worktree.created(
        path: task.repo_path + "/.worktrees/" + task.id + "-" + slugify(task.title),
        branch: task.id + "-" + slugify(task.title)
    )
    ensures: task.tmux_window = core/TmuxWindow.created(name: "task-" + task.id)
    ensures: AgentLaunched(task: task, mode: fix)

    @guidance
        -- Fix mode: the agent researches the CVE/vulnerability in the task
        -- description and applies a minimal targeted fix. Uses TDD where
        -- possible: write a failing test first, then fix, then verify.
        -- Creates a PR via gh pr create on completion.
        -- Uses --permission-mode plan (same as other task dispatches).
        -- Prompt note: build_fix_task_prompt emits the full unified
        -- trailing block (tdd + allium + mcp_tools + learning_tools +
        -- wrap_up), unlike PR-review and research dispatches.
}

rule ResumeTask {
    when: ResumeTask(task)

    requires: task.status in {running, review}
    requires: task.worktree != null
    requires: task.tmux_window = null

    ensures: task.tmux_window = core/TmuxWindow.created(name: "task-" + task.id)
    ensures: task.status = running
    ensures: task.sub_status = core/SubStatus.default_for(running)
    ensures: task.last_pre_tool_use_at = now
    ensures: AgentLaunched(task: task, mode: resume)
}

-- == Status Movement ==

rule MoveTaskForward {
    when: MoveTask(task, forward)

    requires: task.status != done
    requires: task.status != archived

    let next = next_status(task.status)

    -- Moving to Done requires explicit confirmation via ConfirmDone
    requires: next != done

    ensures: task.status = next
    ensures: task.sub_status = core/SubStatus.default_for(next)
    ensures: task.updated_at = now

    @guidance
        -- Manual movement (forward or backward) clears agent health
        -- tracking state (tmux output, crash detection,
        -- notification flags) for the task.
        -- sub_status is always reset to the default for the new status.
        -- Supports batch operation on multi-selected tasks. Batch forward
        -- splits when the selection includes Review tasks: non-Review
        -- tasks move immediately, Review tasks are collected for a single
        -- batch ConfirmDone prompt.
}

rule MoveTaskBackward {
    when: MoveTask(task, backward)

    requires: task.status != backlog
    requires: task.status != archived

    let prev = prev_status(task.status)

    -- Kill tmux window when moving backward, but preserve worktree for resume
    ensures: task.status = prev
    ensures: task.sub_status = core/SubStatus.default_for(prev)
    ensures: task.tmux_window = null
    ensures: task.updated_at = now

    @guidance
        -- Manual movement (forward or backward) clears agent health
        -- tracking state (tmux output, crash detection,
        -- notification flags) for the task.
        -- sub_status is always reset to the default for the new status.
        -- The worktree is preserved so the task can be resumed later
        -- via ResumeTask.
        -- Supports batch operation on multi-selected tasks.
}

rule ConfirmDone {
    when: ConfirmDone(task)

    requires: task.status = review

    ensures: task.status = done
    ensures: task.sub_status = core/SubStatus.default_for(done)
    ensures: task.tmux_window = null
    ensures: task.updated_at = now

    @guidance
        -- Confirmation prompt for the review -> done transition. Used by
        -- both single-task forward moves and BatchMoveForward. Each task
        -- is individually guarded by review status before transitioning.
}

-- == Batch Status Movement ==

rule BatchMoveForward {
    when: BatchMoveTasks(tasks, forward)

    -- Split: non-Review tasks move immediately via MoveTaskForward.
    -- Review tasks are collected and confirmed together via ConfirmDone.
    let non_review = tasks where status != review
    let review_tasks = tasks where status = review

    ensures:
        for task in non_review:
            MoveTaskForward(task)
    ensures:
        if review_tasks.count > 0:
            ConfirmDone(review_tasks)

    @guidance
        -- When all selected tasks are non-Review, they move forward
        -- without any confirmation prompt. When some are in Review,
        -- the non-Review tasks still move immediately while the Review
        -- tasks are held for a single batch confirmation. This avoids
        -- individual prompts per Review task.
}

rule BatchMoveBackward {
    when: BatchMoveTasks(tasks, backward)

    ensures:
        for task in tasks:
            MoveTaskBackward(task)
}

-- == Reorder ==

rule ReorderItem {
    when: ReorderItem(item, direction)
    -- item: Task or Epic in the current visual column
    -- direction: +1 (down) or -1 (up)

    let items = column_items(item)
    let current_index = items.index_of(item)
    let target_index = current_index + direction

    requires: target_index >= 0
    requires: target_index < items.count

    let target = items[target_index]
    let item_eff = item.sort_order ?? item.id
    let target_eff = target.sort_order ?? target.id

    ensures:
        if item_eff = target_eff:
            -- Equal effective values: offset the moved item by 1
            item.sort_order = item_eff + direction
            target.sort_order = target_eff
        else:
            -- Swap effective sort_order values
            item.sort_order = target_eff
            target.sort_order = item_eff

    @guidance
        -- Operates on both tasks and epics within the same visual
        -- column. The effective sort_order is sort_order ?? id
        -- (falling back to the item's database id when unset).
        -- Both updated sort_order values are persisted to the database.
        -- No-op when the item is already at the boundary of its column.
}

-- == Detach Tmux ==

rule DetachTmux {
    when: ConfirmDetachTmux(task)

    requires: task.tmux_window != null

    ensures: task.tmux_window = null
    ensures:
        if task.sub_status in {stale, crashed}:
            task.sub_status = core/SubStatus.default_for(task.status)

    @guidance
        -- Kills the tmux window for a task while preserving the
        -- worktree. The agent is gone but the branch remains for
        -- PR review or later resume. Clears agent health tracking
        -- (captured tmux output, crash detection). Only Stale/Crashed
        -- sub_statuses are reset to the default for the task's
        -- current status; all other sub_statuses are preserved.
        -- Allowed for any task with a tmux window: Running tasks
        -- have their live agent terminated; Review tasks lose their
        -- post-completion session. Triggered via the TUI (T key,
        -- uppercase). Always shows a confirmation prompt
        -- ("Detach tmux panel? [y/n]") before detaching, whether the
        -- target is a single task or a batch of multi-selected tasks.
}

rule BatchDetachTmux {
    when: BatchDetachTmux(tasks)

    -- Filters to tasks that have a tmux window, then detaches all.
    let detachable = tasks where tmux_window != null

    requires: detachable.count > 0

    ensures:
        for task in detachable:
            DetachTmux(task)

    @guidance
        -- Triggered via the TUI (T key, uppercase) when tasks are
        -- multi-selected. Shows a confirmation prompt with the count
        -- of detachable tasks ("Detach N tmux panels? [y/n]"). Tasks
        -- that lack a tmux window are silently
        -- filtered out before the prompt.
}

-- == PR Workflow ==

rule CreatePr {
    when: CreatePr(task)

    requires: task.status = running or task.status = review
    requires: task.worktree != null

    ensures: task.pr_url != null
    ensures: task.status = review
    ensures: task.sub_status = core/SubStatus.default_for(review)
    ensures: task.updated_at = now
    ensures: PrCreated(base: task.base_branch, head: task.worktree.branch)

    @guidance
        -- The PR-creation transition. The pr_url is supplied by the
        -- agent (via update_task) after the agent itself runs
        -- `gh pr create --draft`. Dispatch no longer drives the push
        -- or the gh invocation — see WrapUpPr for the rationale and
        -- the agent-side command sequence. The task always transitions
        -- to review with sub_status = awaiting_review regardless of
        -- the starting status (Running or Review).
}

rule MergePr {
    when: MergePr(task)

    requires: task.status = review
    requires: task.pr_url != null
    requires: task.sub_status = approved

    ensures: PrMerged(task: task)

    @guidance
        -- Human-initiated merge of an approved PR via the TUI.
        -- Bound to the [P] key (uppercase); [p] opens the PR URL in
        -- the browser instead. Selecting [P] on an approved review task
        -- enters the ConfirmMergePr confirmation prompt before the
        -- actual merge. Pressing [P] on a task that is not in review,
        -- has no PR URL, or is not approved sets an informational
        -- status message without prompting.
        -- Runs `gh pr merge --squash` on the task's pr_url.
        -- On success, fires PrMerged which transitions the task to done.
        -- On failure, the error is shown in the status bar via
        -- MergePrFailed without changing task state; sub_status remains
        -- approved so the user can retry.
        --
        -- Precondition enforced at TUI input layer; the merge runtime
        -- accepts any sub_status. Callers from new surfaces must
        -- replicate the guard.
}

rule PollPrStatus {
    when: Tick

    for task in core/Tasks where status = review and pr_url != null:

        -- Branch on GitHub's reported PR state:
        --   Merged -> fire PrMerged; no sub_status update
        --   Open   -> refresh sub_status from review_decision
        --   Closed -> no effect (silently ignored)
        ensures:
            let status = check_pr_status(task.pr_url)
            if status.state = merged:
                PrMerged(task: task)
            else if status.state = open and task.sub_status != conflict:
                let new_sub =
                    if status.review_decision = approved:
                        core/SubStatus.approved
                    else if status.review_decision = changes_requested:
                        core/SubStatus.changes_requested
                    else:
                        core/SubStatus.awaiting_review
                if task.sub_status != new_sub:
                    task.sub_status = new_sub

    @guidance
        -- Runs during each tick for review tasks with a pr_url. Polls
        -- GitHub every pr_poll_interval (30s) via `gh pr view` to check
        -- merge status and review decision.
        -- Merged PRs: fire PrMerged which transitions the task to done.
        -- Open PRs: update sub_status to reflect the current review
        -- decision (approved | changes_requested | awaiting_review).
        -- Tasks currently in sub_status = conflict are NOT overwritten
        -- by the review-decision update, so conflict state persists
        -- across polls until the user resolves it.
        -- Closed-without-merge PRs: silently ignored by the poll loop.
        -- The task remains in review and requires manual intervention
        -- (move to done or re-dispatch).
}

rule PrMerged {
    when: PrMerged(task)

    requires: task.status = review

    ensures: task.status = done
    ensures: task.sub_status = core/SubStatus.default_for(done)
    ensures: task.tmux_window = null
    ensures: task.updated_at = now
    ensures:
        if notifications_enabled:
            DesktopNotification(task: task, urgency: normal, about: pr_merged)

    @guidance
        -- This is an automatic transition triggered by PR status polling.
        -- It bypasses the ConfirmDone human confirmation because the PR
        -- merge itself is the human confirmation (via GitHub review process).
        -- The Review Board UI has been removed; no board cleanup side effect fires.
        -- Like other status-changing rules, the underlying patch flow
        -- (src/service/tasks/crud.rs) triggers EpicStatusRecalculation on
        -- the parent epic when the task belongs to one.
}

-- == Wrap Up ==

rule WrapUpRebase {
    when: WrapUp(task, rebase)

    -- Available from any running or review task with a worktree.
    requires: task.status = review or task.status = running
    requires: task.worktree != null

    let branch = task.worktree.branch

    ensures:
        if task.sub_status = conflict:
            task.sub_status = core/SubStatus.default_for(task.status)
    ensures: BranchRebased(branch: branch, onto: task.base_branch)
    ensures: task.updated_at = now

    @guidance
        -- WrapUpRebase is the rebase mechanic only — it does NOT change
        -- task.status or kill the tmux window. The Done transition for
        -- the MCP path is owned by ExitSession (the agent must call
        -- exit_session to close its session, which marks the task done
        -- and kills tmux). The TUI path (W then r) emits FinishTask and
        -- is governed by FinishTaskSuccess, which keeps its own Done
        -- transition independent of this rule.
        --
        -- Optimistically clears conflict sub_status before attempting the
        -- rebase, so the task is no longer visually flagged while the
        -- rebase runs in the background.
        -- Steps (all via finish_task in dispatch.rs):
        --   1. Verify the repo root is on task.base_branch; abort if not.
        --   2. If origin remote exists, `git pull origin <base_branch>`
        --      in the repo root (skipped when no remote is configured).
        --   3. `git rebase <base_branch>` from the task's worktree.
        --      On conflict: abort the rebase and emit RebaseConflict.
        --   4. `git merge --ff-only <branch>` in the repo root to
        --      fast-forward the base branch to the rebased branch.
        -- The worktree is preserved after a successful rebase (cleaned
        -- up only on archive). The MCP wrap_up handler calls finish_task
        -- with tmux_window=None so the agent's session stays alive until
        -- it explicitly calls exit_session. Available from both the TUI
        -- (W then r) and MCP (wrap_up tool with action "rebase").
        --
        -- Shared-worktree TUI fast-path: when the TUI Finish path (W+r)
        -- detects that another active task shares the same worktree,
        -- it bypasses rebase / fast-forward entirely. Instead it patches
        -- the task to clear worktree and tmux_window and emits
        -- FinishComplete, advancing the task directly to Done. The MCP
        -- wrap_up handler has no equivalent shared-worktree check —
        -- it always invokes finish_task and attempts the rebase. This
        -- asymmetry is intentional: the MCP path is agent-driven and
        -- expects an isolated worktree per task.
}

rule WrapUpPr {
    when: WrapUp(task, pr)

    -- Available from any running or review task with a worktree.
    requires: task.status = review or task.status = running
    requires: task.worktree != null

    ensures: task.pr_url != null
    ensures: task.status = review
    ensures: task.sub_status = core/SubStatus.default_for(review)
    ensures: task.updated_at = now
    ensures: PrCreated(base: task.base_branch, head: task.worktree.branch)

    @guidance
        -- Agent-driven PR creation. The /wrap-up skill instructs the
        -- agent to inspect its own diff, draft a title and body that
        -- reflect the actual work, run
        --   git push -u origin <branch>
        --   gh pr create --draft --base <task.base_branch>
        --     --head <owner>:<branch> --repo <owner>/<repo>
        --     --title <agent-authored> --body <agent-authored>
        -- and then call MCP update_task with pr_url=<url> and
        -- status=review to trigger this rule. The --head uses the
        -- owner:branch format so `gh` resolves the branch in the same
        -- repo as --repo (rather than the authenticated user's
        -- namespace). The PR base is task.base_branch (not hardcoded
        -- "main"). PR status polling (PollPrStatus) takes over once
        -- the URL is recorded.
        --
        -- Rationale: previously dispatch's Rust code ran `gh pr create`
        -- using task.title and task.description for the title and body.
        -- That body was set at task-creation time and rarely matched
        -- the work actually shipped. Letting the agent author the PR
        -- after implementation produces materially better PRs.
        --
        -- The MCP wrap_up tool no longer accepts action="pr"; the
        -- TUI W+p shortcut and the epic-merge MergeAction::Pr have
        -- both been removed. Rebase remains as a TUI/MCP path (see
        -- WrapUpRebase). The tmux window is preserved across PR
        -- creation so the agent can continue working (e.g., self-review).
}

-- == Split Pane Lifecycle ==
--
-- When a task lifecycle event clears or replaces a task's tmux window,
-- the split pane must be updated if that task is currently pinned.
-- The pane is never destroyed — its content is respawned as a fresh
-- shell so that split mode remains active without visual disruption.

rule SplitPaneRespawnOnWindowCleared {
    -- Fires whenever a lifecycle event clears a pinned task's tmux_window.
    -- The trigger is the clearing of task.tmux_window, not the specific
    -- event type. This covers all paths:
    --   - WrapUpRebase / FinishTaskSuccess (rebase completes → Done)
    --   - PrMerged (PR merged on GitHub → Done)
    --   - ConfirmDone (manual Review → Done)
    --   - ArchiveTask (any status → Archived)
    --   - RetryResume (old window killed, new dispatch starts)
    --
    -- NOT triggered by WrapUpPr — the tmux window stays alive after PR
    -- creation so the agent can continue working (e.g., self-review).
    -- NOT triggered by failure paths (FinishTaskConflict, PrFailed) —
    -- the pane should keep showing the agent session for inspection.

    when: task.tmux_window cleared
    requires: split_pane.active = true
    requires: split_pane.pinned_task = task

    ensures: split_pane.pinned_task = null
    ensures: split_pane.active = true
    ensures: split_pane.pane = RespawnedPane(split_pane.pane)

    @guidance
        -- The pane content is replaced in-place using tmux respawn-pane,
        -- which kills the current process and starts a fresh shell without
        -- destroying the pane itself. This avoids the flicker that would
        -- occur from a kill-then-recreate sequence.
        --
        -- Handlers that also emit KillTmuxWindow for the old window name
        -- are harmless — the window no longer exists as a standalone window
        -- (it was absorbed into the pane via join-pane), so the kill is a
        -- no-op. The respawn handles the actual cleanup.
        --
        -- If the pane was already closed externally, the respawn
        -- degrades gracefully to SplitPaneClosed (full reset).
}

-- == Split Pane Focus Border ==
--
-- When split mode is active, the TUI renders a thin border around its
-- entire area. The border color indicates whether the TUI pane has focus:
-- cyan when focused, dim when the agent pane has focus.
-- Requires tmux `focus-events on` for crossterm to receive focus events.

rule SplitPaneFocusBorder {
    when: split_pane.active = true

    ensures: TUI renders Borders::ALL around entire area
    ensures: border_color = CYAN when split_pane.focused = true
    ensures: border_color = BORDER when split_pane.focused = false

    @guidance
        -- The border is only rendered during split mode. Normal single-pane
        -- usage has no border. FocusChanged events update split_pane.focused
        -- only when split is active — otherwise they are ignored.
}

-- == Jump to Agent Window ([g] key) ==
--
-- Pressing [g] on a task jumps tmux focus to that task's agent window.
-- In the normal case this is a standalone tmux window. When the task is
-- currently pinned in the split pane, the pane is targeted directly.

rule JumpToAgentWindow {
    when: UserAction([g], task)
    requires: task.tmux_window != null

    ensures: tmux_focus = task.tmux_window

    @guidance
        -- [g] jumps to the agent's window. In the normal case (no split, or
        -- split active but a different task is pinned), this calls
        -- tmux select-window on task.tmux_window.
        --
        -- Edge case: when the task is the currently pinned split-pane task,
        -- its pane has been joined into the dispatch window via join-pane and
        -- the original standalone window no longer exists. In this case [g]
        -- calls tmux select-pane on split_pane.right_pane_id instead.
        --
        -- Contrast with [G], which peeks at the window in-place without
        -- transferring focus.
}

-- == Pin Task in Split Pane ([G] key) ==
--
-- Pressing [G] on a task in split mode pins that task's tmux window into the
-- right pane without transferring tmux focus. The user stays on the TUI board.
-- Outside split mode [G] is a no-op.

rule PinTaskInSplitPane {
    when: UserAction([G], task)
    requires: split_pane.active = true
    requires: task.tmux_window != null

    ensures: split_pane.pinned_task = task
    ensures: split_pane.pane = task.tmux_window
    ensures: split_pane.focused = unchanged  -- focus does NOT transfer

    @guidance
        -- When the selected task is already pinned, the action is a no-op.
        -- When a different task is pinned, the pane content is swapped in-place
        -- via tmux swap-pane. The old content is returned to a standalone window.
        --
        -- No tmux select-pane is called — the TUI pane retains focus throughout.
        -- [g] (lowercase) is the complementary "take over the window" action.
        --
        -- Outside split mode [G] emits no commands.
}

-- == Finish (Merge) ==

rule FinishTaskSuccess {
    when: FinishTask(task)

    requires: task.status = review
    requires: task.worktree != null

    let branch = task.worktree.branch

    -- Preconditions verified at execution time:
    -- repo root must be on task.base_branch
    -- merge must succeed (no conflicts)

    ensures: BranchMerged(branch: branch, into: task.base_branch)
    ensures: task.tmux_window = null
    ensures: task.status = done
    ensures: task.sub_status = core/SubStatus.default_for(done)
    ensures: task.updated_at = now

    @guidance
        -- Same finish_task path as WrapUpRebase. The implementation
        -- rebases the task branch onto task.base_branch (after pulling
        -- latest from origin), then fast-forwards task.base_branch to
        -- the rebased branch, then kills the tmux window.
        -- Worktree is preserved after finish; it will be cleaned up
        -- when the task is archived. If another active task shares the
        -- same worktree, the worktree is detached from this task but
        -- not removed from disk.
}

rule FinishTaskConflict {
    when: RebaseConflict(task)

    -- Fires when FinishTask's or WrapUpRebase's rebase encounters a conflict.
    -- The rebase is aborted and the task is marked with conflict sub_status.
    -- The task may be in either running or review status at this point,
    -- so conflict is a valid sub_status for both parent statuses.

    ensures: task.sub_status = conflict
    ensures: UserInformed(about: rebase_conflict, task: task)

    @guidance
        -- Conflict has the highest visual column priority (0, above
        -- crashed at 1). It appears in the Stale visual column alongside
        -- stale and crashed tasks.
        -- Conflict is valid for both running and review tasks: review
        -- tasks hit it during FinishTask (merge via TUI), running tasks
        -- hit it during WrapUpRebase.
        -- Staleness detection skips conflict tasks (they are not
        -- re-evaluated for inactivity).
        -- PR review polling skips overwriting conflict sub_status.
        -- Wrap-up rebase clears conflict optimistically before rebasing.
}

-- == Archive ==

rule ArchiveTask {
    when: ArchiveTask(task)

    requires: task.status != archived

    ensures: task.status = archived
    ensures:
        if task.worktree != null:
            not exists task.worktree
    ensures: task.worktree = null
    ensures: task.tmux_window = null
    ensures: task.updated_at = now

    @guidance
        -- Removes the git worktree and tmux window if present.
        -- Best-effort branch deletion.
        -- If another active task shares the same worktree, the
        -- worktree is detached from this task but not removed
        -- from disk (same shared-worktree logic as FinishTaskSuccess).
        -- The TUI typically restricts archive to Done tasks,
        -- but the handler accepts any non-archived task.
}

rule BatchArchive {
    when: BatchArchive(tasks, epics)

    -- Archives selected tasks and epics in one operation.
    -- Tasks are archived unconditionally (same as ArchiveTask).
    -- Epics with non-done active subtasks are skipped.

    ensures:
        for task in tasks:
            ArchiveTask(task)
    ensures:
        for epic in epics:
            if epic.active_subtasks.all(t => t.status = done)
               or epic.active_subtasks.count = 0:
                ArchiveEpic(epic)

    @guidance
        -- Triggered from the TUI (x key) when tasks or epics are
        -- multi-selected. Shows a count-based confirmation prompt before
        -- proceeding. Skipped epics (those with non-done subtasks) are
        -- reported in the status bar.
}

rule DeleteTask {
    when: DeleteTask(task)

    requires: task.status = archived

    ensures:
        if task.worktree != null:
            not exists task.worktree
    ensures: not exists task

    @guidance
        -- Permanent removal. Only accessible from the archive view.
        -- Worktree and branch are cleaned up best-effort.
        -- The archived-status precondition is enforced by the TUI input
        -- layer (archive view only shows archived tasks), not by the
        -- handler itself.
        --
        -- Archive navigation: the archive view is a hidden column to the
        -- right of Done. Press l from the Done column to reveal it; press
        -- h, Left, or Esc to return to Done. The archive is not shown as
        -- a regular kanban column — it appears as an overlay panel when
        -- the virtual archive column (index 4) is selected.
}

-- == Copy Task ==

rule CopyTask {
    when: CopyTask(source)

    ensures: core/Task.created(
        title: "Copy of: " + source.title,
        description: source.description,
        repo_path: confirmed_repo_path,  -- user confirms or edits before creation
        status: backlog,
        sub_status: core/SubStatus.default_for(backlog),
        tag: source.tag,
        created_at: now,
        updated_at: now
    )

    @guidance
        -- Copies a subset of fields from the source task. Fields that are
        -- NOT copied: plan, worktree, tmux_window, pr_url, epic, sort_order.
        -- The new task is a clean backlog item with no agent history.
        -- The user is prompted to confirm or edit the repo_path before the
        -- task is created (the source's repo_path is pre-filled as default).
}

-- == Editor ==

rule EditTask {
    when: EditTask(task)

    -- Opens $EDITOR with a structured file containing the task's
    -- title, description, repo_path, status, plan, tag, and base_branch.
    -- The sections are delimited by `--- SECTION ---` markers
    -- (TITLE, DESCRIPTION, REPO_PATH, STATUS, PLAN, TAG, BASE_BRANCH).
    -- The user edits the file; on save, fields are parsed back.
    -- Empty title/description/repo_path retain their previous values.
    -- Empty plan or tag clears the field. Status parses to the
    -- previous value on invalid input. Empty base_branch retains the
    -- previous value.

    ensures:
        let edited = EditorSession(task)
        if edited.title != "": task.title = edited.title
    ensures:
        if edited.description != "": task.description = edited.description
    ensures:
        if edited.repo_path != "": task.repo_path = edited.repo_path
    ensures:
        if edited.status != null:
            task.status = edited.status
            task.sub_status = core/SubStatus.default_for(edited.status)
    ensures:
        if edited.plan != "": task.plan_path = edited.plan
        else: task.plan_path = null
    ensures:
        if edited.tag != "": task.tag = edited.tag
        else: task.tag = null
    ensures:
        if edited.base_branch != "": task.base_branch = edited.base_branch
    ensures: task.updated_at = now

    @guidance
        -- Status changes via the editor bypass normal transition
        -- preconditions. The user can set any valid TaskStatus
        -- regardless of the current status or the transitions
        -- declared on Task. This is intentional: the editor is a
        -- power-user escape hatch for manual corrections.
        -- Sub_status is auto-reset to the default for the new status
        -- when status changes, per the SubStatusAutoreset invariant.
        -- The editor opens in a separate tmux window; tmux focus
        -- switches to that window while the TUI keeps running in
        -- its original window. On editor exit the window closes and
        -- focus returns to the TUI window. At most one editor
        -- session is live at a time — a second EditTask while an
        -- editor is already open is a no-op with a status message.
        -- A confirmation prompt (ConfirmEditTask) is shown before
        -- the editor is invoked.
}

-- == Agent Health ==

rule ClassifyAgentActivity {
    -- Derives sub_status for running tasks from hook event timestamps.
    -- ACTIVE_THRESHOLD = 2 minutes.
    when: tick

    requires: task.status = running
    requires: task.sub_status not in {crashed, conflict}

    ensures:
        if task.last_notification_at > task.last_pre_tool_use_at:
            task.sub_status = needs_input
        else if now - task.last_pre_tool_use_at <= 2.minutes:
            task.sub_status = active
        else:
            task.sub_status = stale

    @guidance
        -- Crashed and Conflict are orthogonal — set by DetectCrashedAgent
        -- and conflict detectors respectively, never overridden here.
        -- The wallclock Staleness enum (Fresh/Aging/Stale at 3d/7d) is
        -- independent — it decorates card ages.
        -- DispatchTask (and friends) stamp last_pre_tool_use_at = now on
        -- the transition into running so this classifier returns Active
        -- through the ACTIVE_THRESHOLD window before the agent's first
        -- real PreToolUse hook fires. Recovery from Stale → Active is
        -- driven entirely by fresh PreToolUse hook timestamps (and
        -- Notification timestamps for needs_input); there is no separate
        -- in-memory activity timer.
        -- Ownership invariant: only hook events (PreToolUse / Stop) and the
        -- Backlog→Running seed write last_pre_tool_use_at. Generic in-memory
        -- persists from the TUI (sort_order swaps, tick sub_status updates,
        -- editor saves) MUST NOT include this column — a stale in-memory
        -- snapshot would otherwise overwrite a fresher hook write and
        -- flick the task into Stale on the next tick.
}

rule DetectCrashedAgent {
    -- Fires when the tmux window disappears for a running task.
    when: WindowGone(task)

    requires: task.status = running

    ensures: task.sub_status = crashed
    ensures:
        if notifications_enabled:
            DesktopNotification(
                task: task,
                urgency: urgent,
                about: agent_crashed
            )

    @guidance
        -- Triggered by the WindowGone message, which is sent when the
        -- runtime detects that the task's tmux window no longer exists.
        -- The tmux_window field is NOT cleared for crashed tasks, so that
        -- the window name remains available for the ConfirmRetry prompt.
        -- Recovery from Crashed happens via RetryResume, which kills the
        -- old window, dispatches a fresh agent, and resets sub_status to
        -- active. ClassifyAgentActivity intentionally skips Crashed and
        -- Conflict so the human-actionable state is not silently masked
        -- by stale hook timestamps.
        -- For non-running tasks (e.g. review tasks), window closure
        -- silently clears task.tmux_window = null without changing
        -- sub_status or sending notifications. This is the normal exit
        -- path for review agents and detached sessions.
}

-- == Notifications ==

rule NotifyNeedsInput {
    when: task: core/Task.sub_status transitions_to needs_input

    requires: task.status = running

    ensures:
        if notifications_enabled:
            DesktopNotification(
                task: task,
                urgency: urgent,
                about: needs_input
            )

    @guidance
        -- Notifications are deduplicated: each notification fires at most
        -- once per transition to needs_input. The notified state is
        -- cleared when sub_status leaves needs_input, allowing
        -- re-notification on a subsequent re-entry. The clearing happens
        -- unconditionally, even when notifications are disabled, so that
        -- stale entries do not suppress notifications after re-enabling.
        -- The task is in running/needs_input (Blocked visual column),
        -- set by HookNotification when the agent raises a notification.
}

rule NotifyReview {
    when: task: core/Task.status transitions_to review

    ensures:
        if notifications_enabled:
            DesktopNotification(
                task: task,
                urgency: normal,
                about: status_review
            )

    @guidance
        -- Notifications are gated by a user-togglable notifications_enabled
        -- setting (N key in TUI). When disabled, no notifications are sent.
        -- Notifications are deduplicated: each notification fires at most
        -- once per transition to review. The notified state is cleared
        -- when the task leaves review status. The clearing happens
        -- unconditionally, even when notifications are disabled, so that
        -- stale entries do not suppress notifications after re-enabling.
}

rule ClearNeedsInput {
    -- When HookPreToolUse fires, update_status_if(running, running) resets
    -- sub_status to active via the auto-reset behavior.
    when: HookFired(hook: pre_tool_use, task: task)

    requires: task.sub_status = needs_input

    ensures: task.sub_status = core/SubStatus.default_for(running)  -- i.e. active

    @guidance
        -- sub_status = needs_input is set by HookNotification when the agent
        -- raises a notification. It is cleared when the agent resumes and
        -- HookPreToolUse fires, which calls:
        --   dispatch update <id> running
        -- The update_status_if auto-reset sets sub_status = active.
        -- This allows re-notification if the agent raises another notification.
}

rule RetryResume {
    when: RetryResume(task)

    requires: task.status = running
    requires: task.worktree != null

    ensures:
        if task.tmux_window != null:
            OldTmuxWindow.killed(window: task.tmux_window)
    ensures: task.sub_status = active
    ensures: task.last_pre_tool_use_at = now
    ensures: task.tmux_window = core/TmuxWindow.created(name: "task-" + task.id)
    ensures: AgentLaunched(task: task, mode: resume)

    @guidance
        -- If the task already has a tmux window (e.g. a crashed or stale
        -- session), the existing window is killed before creating a fresh
        -- one. This tears down the old process cleanly.
}

rule RetryFresh {
    when: RetryFresh(task)

    requires: task.status = running

    -- Destroys existing worktree, resets to backlog, then re-dispatches
    ensures:
        if task.worktree != null:
            not exists task.worktree
    ensures: task.worktree = null
    ensures: task.tmux_window = null
    ensures: task.status = backlog
    ensures: task.sub_status = core/SubStatus.default_for(backlog)
    ensures: AgentLaunched(task: task, mode: standard)

    @guidance
        -- RetryFresh dispatches directly via the standard dispatch
        -- path. The unified prompt skeleton handles both has_plan = true
        -- (review-and-implement) and has_plan = false (brainstorm-or-plan
        -- conditional) variants without any branch in this rule.
}

-- == MCP Task Tools ==
--
-- Note: this section is not exhaustive. Review and security tooling
-- (e.g., the update_review_status MCP tool) is specified in
-- docs/specs/review.allium.

rule UpdateTaskViaMcp {
    when: McpUpdateTask(task, status?, sub_status?, plan?, title?, description?,
                        repo_path?, sort_order?, pr_url?, tag?, epic_id?,
                        base_branch?, project_id?)

    requires: status != null or sub_status != null or plan != null or title != null
              or description != null or repo_path != null
              or sort_order != null or epic_id != null
              or pr_url != null or tag != null
              or base_branch != null or project_id != null

    -- project_id must refer to an existing project when provided
    requires:
        if project_id != null: Project.exists(project_id)

    -- Cannot set status to done or archived via MCP. This restriction
    -- is enforced at the MCP handler boundary, not in the service layer.
    -- Rationale: agents manage running work, humans mark completion.
    requires: status != done
    requires: status != archived

    -- sub_status must be valid for the task's current (or new) status
    requires:
        if sub_status != null:
            let effective_status = if status != null then status else task.status
            sub_status.is_valid_for(effective_status)

    ensures:
        if status != null: task.status = status
    ensures:
        if sub_status != null: task.sub_status = sub_status
        else if status != null: task.sub_status = core/SubStatus.default_for(status)
    ensures:
        if plan != null: task.plan_path = plan
    ensures:
        if title != null: task.title = title
    ensures:
        if description != null: task.description = description
    ensures:
        if repo_path != null: task.repo_path = expand_tilde(repo_path)
    ensures:
        if sort_order != null: task.sort_order = sort_order
    ensures:
        if pr_url != null:
            if pr_url = "":
                task.pr_url = null      -- empty string clears the PR URL
            else:
                task.pr_url = pr_url
    ensures:
        if tag != null: task.tag = tag
    ensures:
        if epic_id != null: task.epic = core/Epic.find(epic_id)
    ensures:
        if base_branch != null: task.base_branch = base_branch
    ensures:
        if project_id != null: task.project_id = project_id
    ensures: task.updated_at = now

    @guidance
        -- MCP update_task accepts status, sub_status, plan_path, title,
        -- description, repo_path, sort_order, pr_url, tag, epic_id,
        -- base_branch, and project_id. It does NOT accept worktree or
        -- tmux_window — those are owned by the dispatch flow and never
        -- set via MCP.
        -- Note: worktree and tmux_window ARE mutable through the internal
        -- Rust TaskService::update_task API (UpdateTaskParams defines
        -- them; see src/service/tasks/params.rs). The runtime uses that
        -- path for detach and claim flows. They are intentionally
        -- unreachable from MCP because the MCP handler does not parse
        -- those fields (src/mcp/handlers/tasks.rs).
        -- An empty-string pr_url clears the field (maps to FieldUpdate::Clear);
        -- any non-empty string sets it.
        -- When status or epic_id changes, the parent epic's status is
        -- recalculated (if a parent epic exists). Re-assigning a task
        -- from one epic to another triggers recalculation on both the
        -- old and new epic.
        -- project_id must refer to an existing project; an unknown ID
        -- returns a -32602 validation error.
}

rule CreateTaskViaMcp {
    when: McpCreateTask(title, repo_path, project_id, description?, plan?,
                        epic_id?, sort_order?, tag?, base_branch?)

    -- project_id is mandatory and must refer to an existing project
    requires: core/Project.exists(project_id)

    -- epic_id, when given, must refer to an existing epic
    requires:
        if epic_id != null: core/Epic.exists(epic_id)

    ensures: core/Task.created(
        title: title,
        description: description ?? "",
        repo_path: repo_path,
        status: backlog,
        sub_status: core/SubStatus.default_for(backlog),
        plan_path: plan,
        epic: if epic_id != null then core/Epic.find(epic_id) else null,
        tag: tag,
        sort_order: sort_order,
        base_branch: base_branch ?? config.default_branch,
        project_id: project_id,
        created_at: now,
        updated_at: now
    )

    @guidance
        -- project_id is required. The dispatched agent reads its own
        -- task's project from the dispatch prompt (ProjectId: <id>) and
        -- passes it on every create_task call so sub-tasks land in the
        -- same project as their parent task.
        -- An unknown project_id returns a -32602 validation error.
        -- Unlike the TUI CreateTask rule, this rule does not fire
        -- RecordRepoPath — MCP task creation skips repo path persistence.
        -- repo_path is expanded through expand_tilde before being
        -- stored (so "~/proj" becomes "$HOME/proj"), matching
        -- UpdateTaskViaMcp.
}

rule ListTasksViaMcp {
    when: McpListTasks(epic_id?, project_id?, repo_paths?, status?, caller_task_id?)

    ensures: returns Task records where
        (epic_id != null implies task.epic_id = epic_id)
        and (project_id != null implies task.project_id = project_id)
        and (repo_paths != null implies task.repo_path in repo_paths)
        and (status != null implies task.status in status else task.status != archived)
        and (caller_task_id != null implies task.id != caller_task_id)

    @guidance
        -- When caller_task_id is given and none of epic_id/project_id/repo_paths are set,
        -- auto-derive scope from the caller:
        --   caller.epic_id != null → filter by epic_id = caller.epic_id
        --   else                   → filter by project_id = caller.project_id
        -- Explicit scope filters always win over auto-derived scope.
        -- When caller_task_id is given alongside an explicit scope filter, the caller task
        -- is still excluded from results but no additional scope is derived.
        -- Output line per task: title, status/sub_status, tag, epic, then
        --   | PR: <pr_url>  (omitted when pr_url is null)
        --   | Goal: <plan goal>  (from **Goal:** line in plan file; falls back to
        --                         description preview ≤200 chars when plan absent/unreadable)
        -- Implemented in src/mcp/handlers/tasks.rs.
}

rule ListProjectsViaMcp {
    when: McpListProjects()

    ensures: returns list of all core/Project records ordered by sort_order

    @guidance
        -- Returns all projects (including the default one) so agents can
        -- look up a project_id by name before calling update_task or
        -- update_epic.
}

rule ClaimTaskViaMcp {
    when: McpClaimTask(task, worktree, tmux_window)

    requires: task.status = backlog

    -- Repo root derived from the worktree by stripping the
    -- `/.worktrees/<slug>` suffix must exactly match task.repo_path.
    -- This is stricter than a simple starts_with check: worktrees
    -- pointing at another repository with a similar prefix are rejected.
    requires: repo_from_worktree(worktree.path) = task.repo_path

    ensures: task.status = running
    ensures: task.sub_status = core/SubStatus.default_for(running)
    ensures: task.last_pre_tool_use_at = now
    ensures: task.worktree = worktree
    ensures: task.tmux_window = tmux_window
    ensures: task.updated_at = now

    @guidance
        -- repo_from_worktree splits on "/.worktrees/" and returns the
        -- prefix; when the path does not contain "/.worktrees/", the
        -- full path is returned (so a user's repo root is accepted as-is).
        -- On mismatch, the service returns a Validation error naming
        -- the task's repo_path and the caller's derived repo root.
        -- last_pre_tool_use_at is seeded so ClassifyAgentActivity sees a
        -- recent activity stamp through the ACTIVE_THRESHOLD window before
        -- the agent's first PreToolUse hook fires — without that, the
        -- freshly running task flickers into Stale on the next tick.
}

rule ReportUsageViaMcp {
    when: McpReportUsage(task, input_tokens, output_tokens, cache_read_tokens?, cache_write_tokens?)

    ensures: core/TaskUsage.accumulate(
        task: task,
        input_tokens: input_tokens,
        output_tokens: output_tokens,
        cache_read_tokens: cache_read_tokens ?? 0,
        cache_write_tokens: cache_write_tokens ?? 0,
        updated_at: now
    )

    @guidance
        -- Upserts a single TaskUsage row for the given task. If a row
        -- already exists, numeric fields are summed with existing values.
        -- cache_read_tokens and cache_write_tokens default to zero when
        -- omitted by the caller.
}

rule DispatchNextViaMcp {
    when: McpDispatchNext(epic)

    -- Select the first backlog subtask of the epic, ordered by
    -- sort_order (nulls fall back to id), then by id.
    let next = epic.subtasks where status = backlog
        ordered_by (sort_order ?? id, id)
        .first

    ensures:
        if not epic.auto_dispatch:
            UserInformed(about: auto_dispatch_disabled, epic: epic)
        else if next = null:
            UserInformed(about: no_backlog_tasks, epic: epic)
        else:
            DispatchTask(next)

    @guidance
        -- When epic.auto_dispatch is false, the call returns an
        -- informational message without dispatching. Otherwise the
        -- next backlog subtask is chosen deterministically: sort_order
        -- ascending with id tiebreaker, nulls using id as fallback.
        -- If no backlog subtasks remain, the call is a no-op with an
        -- informational message. A DB error reading auto_dispatch does
        -- not block dispatch; the flag defaults to treated-as-true on
        -- read failure (fail-open). Returns success immediately; the
        -- dispatch runs in the background via spawn_blocking.
        -- Internally delegates to the same dispatch logic as DispatchTaskViaMcp:
        -- a single DispatchTask call, since the unified prompt skeleton
        -- handles both has_plan branches without tag-based routing.
}

rule DispatchTaskViaMcp {
    when: McpDispatchTask(task)

    requires: task.status = backlog

    ensures: DispatchTask(task)

    @guidance
        -- Returns an error if task.status != backlog.
        -- A single DispatchTask call covers both has_plan = true
        -- (with-plan prompt) and has_plan = false (brainstorm-or-plan
        -- prompt) variants — the prompt builder branches internally.
        -- Unlike DispatchNextViaMcp, this call is synchronous: it waits for
        -- worktree creation and agent launch to complete before returning.
        -- On success, the worktree path and tmux window are returned to the caller.
        -- On failure (e.g. worktree creation or tmux launch error), the error is
        -- returned immediately and the task remains in backlog status.
}

rule SwapSplitPane {
    when: UserAction([G], task)
    requires: split_pane.active = true
    requires: task.tmux_window != null
    requires: split_pane.pinned_task != task  -- no-op when already pinned

    ensures:
        if split_pane.pinned_task != null:
            -- Swap: the currently pinned task's pane is returned to a
            -- standalone window, and the new task's window is joined
            -- into the split pane.
            SplitPaneSwapped(
                new_task: task,
                old_task: split_pane.pinned_task
            )
        else:
            SplitPanePinned(task: task)
    ensures: split_pane.pinned_task = task
    ensures: split_pane.pane = task.tmux_window

    @guidance
        -- This rule specifies the swap case for [G]; the pin-empty case
        -- is covered by PinTaskInSplitPane. When the pane already holds
        -- a different task's window, the old window is swapped out via
        -- tmux swap-pane and returned to the standalone window list.
        -- tmux focus is NOT transferred — the TUI pane retains focus
        -- throughout the swap.
}

rule SendMessageViaMcp {
    when: McpSendMessage(from_task, to_task, body)

    requires: from_task != null
    requires: to_task != null
    requires: to_task.worktree != null
    requires: to_task.tmux_window != null

    ensures: MessageDelivered(
        from: from_task,
        to: to_task,
        path: to_task.worktree + "/.claude-messages/" + from_task.id + "-" + timestamp_ms() + ".md"
    )
    ensures: TmuxNotificationSent(to: to_task, about: message_received)

    @guidance
        -- Inter-agent messaging. An agent writes a message file into the
        -- target agent's worktree under .claude-messages/, using a
        -- filename of `<from_task.id>-<unix_epoch_millis>.md`. The file
        -- contents begin with `[Message from task <id>: "<title>"]`
        -- followed by the body text.
        -- After writing the file, a tmux notification is injected via
        -- `tmux send-keys` telling the target to read and delete the
        -- file. If send-keys fails, the message file is removed and
        -- an error is returned to the caller.
        -- The TUI shows a brief envelope flash on the target task's card
        -- (message_flash tracking state, cleared after 3 seconds) via
        -- the MessageSent MCP event and the MessageReceived message.
        -- Both tasks must exist. The target must have an active worktree
        -- and tmux window (i.e. a running agent). The sender has no
        -- such constraint — it only needs to exist.
}

-- == Hook-Based Status Transitions ==
-- Claude Code hooks (PreToolUse, Stop, Notification) bridge the agent
-- session lifecycle to task status. These rules describe the CLI hook
-- script installed by `dispatch setup`.

rule HookPreToolUse {
    when: PreToolUse(task, tool_name)

    -- Skip dispatch MCP tool calls: these are management operations
    -- (get_task, wrap_up, update_task, etc.), not implementation work.
    -- Without this filter, wrap-up fails because get_task and wrap_up
    -- calls clobber review status before the handler can check it.
    requires: not tool_name starts_with "mcp__dispatch__"

    ensures: task.status = running
    ensures: task.sub_status = core/SubStatus.default_for(running)
    ensures: task.last_pre_tool_use_at = now

    @guidance
        -- Fires on every non-dispatch tool use. The unconditional
        -- transition is correct: backlog -> running on first dispatch,
        -- review -> running on session resume, running -> running is
        -- a no-op. Only done/archived tasks should not be modified,
        -- but agents are never dispatched into done/archived worktrees.
        -- The sub_status reset to active (default for running) also
        -- clears needs_input when the agent resumes after a notification.
}

rule HookStop {
    when: Stop(task)

    requires: task.status = running

    ensures: task.status = review
    ensures: task.sub_status = core/SubStatus.default_for(review)
    ensures: task.last_pre_tool_use_at = null
    ensures: task.last_notification_at = null
}

rule HookNotification {
    when: HookFired(hook: notification, task: task)
    requires: task.status = running

    ensures: task.sub_status = needs_input
    ensures: task.last_notification_at = now

    @guidance
        -- HookNotification fires when the agent raises a notification
        -- (e.g. a permission prompt). The hook calls:
        --   dispatch update <id> running --only-if running --sub-status needs_input
        -- This sets sub_status=needs_input while keeping status=running.
        -- The task appears in the Blocked visual column (running, needs_input).
        -- When the agent resumes, HookPreToolUse fires and update_status_if
        -- resets sub_status back to active (default for running).
        --
        -- CLI surface note: `dispatch update <id> <status> [--only-if X]
        -- [--sub-status Y] [--needs-input]` is a non-MCP, human/hook-driven
        -- entry point implemented by cli_update_task. Unlike the MCP
        -- update_task tool — which blocks transitions into `done` and
        -- `archived` so agents cannot self-promote past Review — the CLI
        -- accepts any TaskStatus value, including `done` and `archived`.
        -- This is intentional: Claude Code hooks and human operators use
        -- the CLI to drive lifecycle steps that agents must not perform
        -- on their own.
        --
        -- Flag deprecation: `--needs-input` is deprecated in favour of
        -- `--sub-status needs_input`. When both are present, `--sub-status`
        -- wins (resolved at src/main.rs Update arm). Hook scripts written
        -- before the sub-status flag existed continue to work unchanged.
}

-- == CLI surface ==

rule AttachPlanViaCli {
    when: CliAttachPlan(task, path)

    requires: task != null

    ensures: task.plan_path = path

    @guidance
        -- CLI command: `dispatch plan <id> <path>` attaches a plan file to
        -- an existing task by writing task.plan_path directly via
        -- db.patch_task. No status transition occurs; the plan attachment
        -- is decoupled from dispatch.
        -- Implementation: src/main.rs Commands::Plan match arm.
        -- Used by the /queue-plan slash command (and operators) to stage
        -- a plan onto a task before dispatching it.
}

-- @guidance: Other CLI subcommands (operator/diagnostic surfaces; not
-- modeled as separate rules because they do not mutate task domain state
-- beyond what existing rules already cover):
--   • `dispatch tui [--port] [--inactivity-timeout]` — primary entry
--     point launching the TUI (src/main.rs Commands::Tui).
--   • `dispatch list [--status <status>]` — diagnostic listing of tasks,
--     optionally filtered by status (src/main.rs Commands::List). Read-only.
--   • `dispatch uninstall [--yes] [--purge]` — destructive: removes the
--     dispatch MCP configuration from Claude Code; with `--purge` also
--     deletes the database and log files (src/main.rs Commands::Uninstall).
--     Operator-only — never invoked by agents or hooks.
--   • `dispatch update <id> <status> ...` — see HookNotification (above).
--   • `dispatch verify-feed <command>` — see VerifyFeed in feeds.allium.

-- == Learning ==
-- Rules governing the unified learning store: dispatch-prompt augmentation,
-- wrap-up reflection nudge, MCP capture/retrieval tools, and human review actions.
-- Storage and MCP implementation are deferred to WP3 and WP4 respectively.
-- Prompt injection is deferred to WP6; wrap-up nudge to WP8.

rule AugmentDispatchPromptWithLearnings {
    when: AgentLaunched(task, mode)

    requires: mode in {standard, resume, quick, epic_planning}

    let relevant = core/Learnings where applies_to_dispatch(task)

    ensures:
        if relevant.count > 0:
            DispatchPromptAugmented(task: task, learnings: relevant)

    @guidance
        -- Fires after every agent launch that creates a worktree session.
        -- relevant is the set of approved core/Learning records where
        -- applies_to_dispatch(task) = true (user + repo + epic scopes).
        -- scope_priority order (highest first): procedural, epic, repo, project, user.
        -- Procedural learnings are prepended as prompt-prefix instructions.
        -- Other kinds are collected under a "Relevant learnings" section.
        -- If relevant is empty, nothing is prepended and the rule still fires
        -- (DispatchPromptAugmented with empty learnings is a no-op).
        -- Implemented in dispatch_with_prompt() (src/dispatch.rs) in WP6.
        -- Until WP6 lands this rule is forward-looking: it documents intended
        -- behaviour so downstream work packages can plan against the spec.
}

rule AugmentDispatchPromptWithRepoMap {
    when: AgentLaunched(task, mode)

    requires: mode in {standard, resume, quick, epic_planning, pr_review, research, fix, dependabot}
    requires: config.repo_map_enabled = true

    let binary = CtagsBinary.detected_at_startup()
    let worktree = task.worktree.path
    let budget = config.repo_map_token_budget

    ensures:
        if binary != null and Generated(binary, worktree, budget) = success(map) and map != "":
            DispatchPromptAugmentedWithRepoMap(task: task, map: map)
            CacheWritten(path: worktree + "/.dispatch/repo-map.txt", contents: map)

    @guidance
        -- The repo map is a token-budgeted structural summary of the
        -- worktree, derived from `ctags -R --output-format=json` and grouped
        -- by file with kind-prefixed symbol lists. Files are ranked by symbol
        -- count descending. Per-file output is capped so a single large file
        -- cannot swallow the budget. Token count is proxied as `chars / 4`.
        -- Kinds are normalised to lowercase with spaces replaced by `-`
        -- (no language mapping table — that is deferred to a future T3 tier).
        --
        -- The Universal Ctags binary is detected ONCE at TUI startup
        -- (src/runtime/mod.rs::run_tui), trying `ctags` then
        -- `universal-ctags` and accepting only outputs whose `--version`
        -- begins with `Universal Ctags`. Exuberant Ctags (legacy) is
        -- rejected because its JSON output is incompatible. The detected
        -- binary is held on App and threaded through the dispatch path.
        --
        -- Generation runs at dispatch time (after provision_worktree,
        -- before prompt construction) with a 5-second watchdog. If the
        -- binary is absent (detection returned null), exits non-zero, or
        -- exceeds the timeout, the prompt is built without a repo-map
        -- block — dispatch never fails because of a missing or broken map.
        --
        -- The map is written to <worktree>/.dispatch/repo-map.txt for
        -- inspection. provision_worktree creates <worktree>/.dispatch/ and
        -- idempotently appends `.dispatch/` to <worktree>/.gitignore so the
        -- cache is never staged.
        --
        -- The cache is regenerated on every dispatch (no on-disk reuse) —
        -- worktrees are short-lived and the agent reads files for fresh
        -- detail anyway. Cache invalidation on file changes is deferred.
        --
        -- Implementation lives in src/dispatch/repo_map.rs. The injection
        -- point in the unified prompt skeleton sits between the validated
        -- knowledge block and the mode addendum.
}

rule WrapUpReflection {
    when: WrapUp(task, action)

    requires: config.learning_reflection_enabled = true
    requires: action = pr

    ensures: WrapUpReflectionNudged(task: task)

    @guidance
        -- The MCP wrap_up handler appends a reflection nudge to its response for
        -- the PR action only. For the rebase action, reflection is delegated to
        -- ExitSession (see below).
        -- Gated by config.learning_reflection_enabled (default: true).
        -- Implemented in handle_wrap_up() (src/mcp/handlers/tasks.rs).
}

rule ExitSession {
    when: ExitSession(task, has_learnings?)

    ensures:
        if has_learnings = null:
            ExitSessionAskedAboutLearnings(task: task)
        else if has_learnings = true:
            ExitSessionRecordPromptSent(task: task)
        else:
            ExitSessionCompleted(task: task)
            TmuxWindowKilled(task: task)
            task.status = done
            task.sub_status = core/SubStatus.default_for(done)
            task.tmux_window = null
            task.updated_at = now

    @guidance
        -- Stateless three-way dispatch driven by `has_learnings`:
        --
        -- has_learnings = null (omitted):
        --   Returns the structured reflection question (pitfall / convention /
        --   tool-tip categories) and instructs the agent to call again with
        --   has_learnings=true or has_learnings=false.
        --
        -- has_learnings = true:
        --   Returns the record_learning prompt listing kind / summary / scope
        --   parameters. The session remains open; the agent records each
        --   finding via record_learning, then calls exit_session(has_learnings=false)
        --   to close.
        --
        -- has_learnings = false:
        --   Closes the session: status=done, sub_status=default_for(done),
        --   tmux_window=null, kills the tmux window.
        --
        -- Epic status is recalculated after the close patch when task.epic_id is set.
        --
        -- No server-side state is kept between calls — every call's branch is
        -- determined purely by the parameter. Re-dispatch needs no special
        -- cleanup.
        --
        -- Implemented in handle_exit_session() (src/mcp/handlers/tasks.rs).
}

rule RecordLearningViaMcp {
    when: McpRecordLearning(task, kind, summary, scope, detail?, scope_ref?, tags?)

    requires: summary != ""
    requires: scope = user implies scope_ref = null
    requires: scope in {project, repo, epic, task} implies scope_ref != null

    ensures: core/Learning.created(
        kind: kind,
        summary: summary,
        detail: detail,
        scope: scope,
        scope_ref: scope_ref ?? default_scope_ref(task, scope),
        tags: tags ?? {},
        status: approved,
        source_task: task,
        upvote_count: 0,
        created_at: now,
        updated_at: now
    )

    @guidance
        -- Agents call this during task execution or at wrap-up to surface
        -- non-obvious learnings. Entries land as approved and are eligible
        -- for retrieval immediately; humans curate the active pool by
        -- rejecting or archiving entries in the TUI.
        -- default_scope_ref resolves when scope_ref is omitted:
        --   scope=project → str(task.project_id)
        --   scope=repo    → task.repo_path
        --   scope=epic    → str(task.epic_id), error if task has no epic
        --   scope=task    → str(task.id)
        --   scope=user    → null
        -- tags defaults to the empty set when omitted.
        -- The MCP response is enriched with up to 5 similar approved
        -- learnings (matching kind, scope, and scope_ref) and recommends
        -- calling upvote_learning on an existing entry instead of keeping
        -- a duplicate when one of the similar entries already captures the
        -- same knowledge. Source: src/mcp/handlers/learnings.rs.
}

rule QueryLearningsViaMcp {
    when: McpQueryLearnings(task, tag_filter?, limit?)

    ensures: returns approved core/Learning records where applies_to_dispatch(task),
             filtered to those whose tags intersect tag_filter (when tag_filter is provided),
             ordered by scope_priority(scope) then upvote_count desc,
             limited to min(limit ?? 20, 50)

    @guidance
        -- Retrieval unions: user + project:<task.project_id> + repo:<task.repo_path>
        -- + epic:<task.epic_id> (if task has an epic). task-scoped learnings are excluded from
        -- applies_to_dispatch; agents can reach them by calling this tool with
        -- an explicit tag_filter matching a task scope (WP5 episodic ingestion).
        -- scope_priority order (highest first): procedural, epic, repo, project, user.
        -- limit is capped at 50 to bound prompt size.
        -- Implemented in src/mcp/handlers/ in WP4.
}

rule UpvoteLearningViaMcp {
    when: McpUpvoteLearning(learning, task)

    requires: learning.status = approved

    ensures: learning.upvote_count = learning.upvote_count + 1
    ensures: learning.last_upvoted_at = now
    ensures: learning.updated_at = now

    @guidance
        -- Agents call this (MCP tool: upvote_learning) when they act on a
        -- learning and it proves correct. upvote_count is an evidence
        -- signal used to rank query results. No status change: an upvote
        -- strengthens an approved entry but does not alter its lifecycle.
        -- Implemented in src/mcp/handlers/learnings.rs.
}

-- == Learning Review ==
-- Human-facing TUI actions for curating the knowledge base.
-- Entries land as approved on creation (see RecordLearningViaMcp); humans
-- curate the active pool by rejecting, archiving, or editing entries.

rule RejectLearning {
    when: RejectLearning(learning)

    requires: learning.status = approved

    ensures: learning.status = rejected
    ensures: learning.updated_at = now
}

rule ArchiveLearning {
    when: ArchiveLearning(learning)

    requires: learning.status = approved

    ensures: learning.status = archived
    ensures: learning.updated_at = now
}

rule EditLearning {
    when: EditLearning(learning, summary?, detail?, kind?, tags?)

    requires: learning.status = approved
    requires: summary != null implies summary != ""

    ensures:
        if summary != null: learning.summary = summary
    ensures:
        if detail != null: learning.detail = detail
    ensures:
        if kind != null: learning.kind = kind
    ensures:
        if tags != null: learning.tags = tags
    ensures: learning.updated_at = now

    @guidance
        -- EditLearning follows the same editor pattern as EditTask: the TUI
        -- opens $EDITOR with a structured file containing the learning fields.
        -- Editing does not change status.
        -- Implemented in the TUI knowledge-base panel.
}

surface KnowledgeBaseReview {
    let learnings: [Learning] = core/Learnings where status = approved
                                ordered_by scope asc, created_at desc
    let selected: Integer = 0

    exposes:
        learnings
        selected

    provides:
        Navigate(delta: Integer)
            requires: learnings != []
            ensures: selected = clamp(selected + delta, 0, len(learnings) - 1)

        Reject(learning: Learning)
            requires: learning.status = approved
            ensures: RejectLearning(learning)

        Archive(learning: Learning)
            requires: learning.status = approved
            ensures: ArchiveLearning(learning)

        Edit(learning: Learning)
            requires: learning.status = approved
            ensures: EditLearning(learning)

        Close
            ensures: surface closed, previous view restored

    @guidance
        -- TUI knowledge-base panel (opened with `L`). Entries are approved
        -- on creation; the human's role is to reject, archive, or edit
        -- entries — there is no "approve" action because there is no
        -- proposed state. Key bindings: `x` reject, `A` archive, `e` edit.
}

------------------------------------------------------------
-- Surfaces
------------------------------------------------------------

surface RepoPathPicker {
    facing user: User

    let saved = core/SavedRepoPaths ordered_by last_used desc
    let query: String = ""
    let cursor: Integer = 0

    -- Fuzzy subsequence match: every character of lowercased query
    -- appears in the lowercased path as a forward subsequence.
    -- Empty query matches all saved paths.
    let filtered = saved where fuzzy_subsequence(lowercase(query), lowercase(path))

    exposes:
        query
        filtered
        cursor

    provides:
        -- Typing appends to query and resets cursor to 0
        TypeChar(user, char)
            ensures: query = query + char
            ensures: cursor = 0

        -- Backspace removes the last character of query
        Backspace(user)
            when query != ""
            ensures: query = remove_last(query)
            ensures: cursor = 0

        -- Up/Down arrows move the cursor within the filtered list
        -- (wrapping). No printable character is a navigation alias —
        -- letters such as j/k are typed into query, not interpreted as
        -- nav commands.
        CursorDown(user)
            when filtered.count > 0
            ensures: cursor = (cursor + 1) mod filtered.count

        CursorUp(user)
            when filtered.count > 0
            ensures: cursor = (cursor - 1 + filtered.count) mod filtered.count

        -- Enter: select filtered[cursor] if filtered is non-empty,
        -- otherwise use literal query as the path. (For pickers that do
        -- not allow free-form paths, e.g. the QuickDispatch picker
        -- variant, the empty-filtered branch is a no-op.)
        Confirm(user)
            ensures:
                if filtered.count > 0:
                    SelectedPath(filtered[cursor].path)
                else:
                    SelectedPath(query)

        -- Escape dismisses the picker without selecting
        Dismiss(user)

    @guarantee CursorResetOnEntry
        -- cursor is always 0 when the picker is first displayed.
        -- This ensures the most-recently-used path is pre-selected.

    @guarantee NoPrintableShortcut
        -- No printable character (letter, digit, punctuation) is a
        -- navigation or selection shortcut. Every printable character
        -- is appended to query via TypeChar; navigation goes through
        -- the arrow keys; selection goes through Enter. This contract
        -- is shared by every InputMode that renders this picker —
        -- in particular it forbids the historical j/k nav alias and
        -- the historical 1-9 instant-select shortcut, both of which
        -- broke fuzzy filtering on paths containing those characters.

    @guidance
        -- This surface appears during task creation (InputRepoPath),
        -- epic creation (InputEpicRepoPath), main-session repo set
        -- (MainSessionDir), and quick dispatch (QuickDispatch). It
        -- replaces a plain text input with a fuzzy-filtered list of
        -- previously-used repo paths. The filtered list is ordered by
        -- recency (most recent first). When the user has not typed
        -- anything, all saved paths are shown, letting them pick with
        -- a single keystroke.
}

surface DispatchingFeedback {
    facing user: User

    -- This surface tracks tasks that are mid-dispatch — between the
    -- user pressing Enter / Shift+D and the dispatch worker reporting
    -- success or failure. Set membership and per-task start time are
    -- implementation-internal (`app.dispatching` HashSet plus a
    -- sibling start-time map); the surface contract is the visible
    -- behaviour of the status bar and card line-2 indicator.

    @guarantee StickyUntilEmpty
        -- status_text persists across Tick events while `dispatching` is
        -- non-empty. The 5-second STATUS_MESSAGE_TTL that applies to ad-hoc
        -- status messages is bypassed for dispatching feedback.

    @guarantee ClearedWhenEmpty
        -- status_text becomes null the moment `dispatching` drains,
        -- regardless of how the last entry was removed (Dispatched,
        -- DispatchFailed, or watchdog timeout).

    @guarantee DispatchingTimeout
        -- A task that remains in `dispatching` for more than 60 seconds is
        -- removed by the next Tick and a "dispatch timed out" failure toast
        -- is shown. Defence-in-depth against a stuck dispatch worker
        -- (e.g. an agent panic that escapes catch_unwind).

    @guarantee DeletedTaskPruned
        -- If a task referenced in `dispatching` is deleted from the task
        -- list (e.g. via `d`), the next Tick removes the stale ID so the
        -- status text never references a vanished task.

    @guarantee SinglePathMutation
        -- Mutation of `dispatching` flows through a single helper so the
        -- sticky status text is always kept in sync with set membership.
        -- Routing through `app.update(MarkDispatching)` from another
        -- update handler is forbidden (recursive update hazard).

    @guidance
        -- Dispatch is asynchronous: the worker runs `git fetch origin
        -- <base_branch>`, creates the worktree and tmux window, then
        -- starts the agent. On a slow network this takes several seconds.
        -- The DispatchingFeedback surface gives the user continuous
        -- evidence that the work is in flight rather than a non-responsive
        -- UI. It is rendered in two places: the status bar (full
        -- status_text) and each affected task card's secondary line
        -- (spinner glyph + "dispatching…"). Once `dispatching` is empty
        -- the status bar reverts to its idle state and cards return to
        -- their normal indicator.
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

@invariant RunningTaskHasWorktree
    -- Tasks dispatched via DispatchTask or ClaimTaskViaMcp always have a
    -- worktree. However, manual forward movement (m key) can move a task
    -- to running without provisioning a worktree. The dispatch flow is
    -- the canonical path; manual moves are overrides.

@invariant DoneRequiresHumanConfirmation
    -- The Done status transition requires explicit human confirmation
    -- via the TUI. MCP tools cannot set status to done or archived.
    -- This is enforced in the McpUpdateTask rule preconditions and
    -- the ConfirmDone rule requiring review status.
    -- Exception: PrMerged transitions are automatic because the PR
    -- merge on GitHub constitutes human confirmation via the code
    -- review process. WrapUpRebase is human-initiated (TUI W+r or
    -- MCP wrap_up tool) and transitions directly to done.

@invariant DispatchMcpToolsAreTransparent
    -- Dispatch MCP tool calls (get_task, wrap_up, update_task, etc.)
    -- must not trigger automatic status transitions. They are management
    -- operations, not implementation work. The PreToolUse hook filters
    -- them out to prevent clobbering review status during wrap-up.
    -- However, non-MCP tools (Bash, Read, etc.) still fire PreToolUse
    -- and can set a review task to running. The wrap_up handler
    -- accepts any running or review task with a worktree.

@invariant SubStatusConsistency
    -- A task's sub_status must always be valid for its parent status:
    --   sub_status.is_valid_for(status) = true
    -- This is enforced at every status transition: when status changes,
    -- sub_status is reset to SubStatus.default_for(new_status) before
    -- being persisted. Individual handlers may then set a more specific
    -- sub_status (e.g., DetectStaleAgent sets stale, HookNotification
    -- sets needs_input) only after the reset.

@invariant SubStatusAutoreset
    -- Whenever task.status changes, task.sub_status is reset to
    -- SubStatus.default_for(new_status). This ensures that no invalid
    -- (status, sub_status) combinations are ever persisted.
    -- Every rule that changes status must also reset sub_status.
    -- Exception: rules that set a specific sub_status override the
    -- default (e.g., HookNotification keeps status=running and sets
    -- sub_status=needs_input; FinishTaskConflict keeps the parent
    -- status and sets sub_status=conflict).

@invariant SplitPaneStability
    -- When split mode is active, the pane must never be destroyed and
    -- recreated in response to task lifecycle events. Pane content is
    -- replaced in-place (respawn) to avoid visual flicker. The only
    -- operations that destroy the pane are explicit user actions:
    -- toggling split mode off (S key) or manually closing the pane.
    -- Lifecycle events (finish, PR creation) respawn the pane content
    -- and clear pinned_task, but keep active=true and pane intact.

------------------------------------------------------------
-- Open Questions
------------------------------------------------------------

-- Q1: Should stale/crashed detection trigger automatic status changes
--     (e.g., moving back to Backlog), or should it remain advisory-only
--     as it is today?

rule selection_preservation:
    When the cursor has an anchor (a task or epic ID) and column items are recomputed
    (on any status change, task movement, filter change, or data refresh), the cursor
    position is resolved by locating the anchor item in the new item list.

    If the anchor item is found: the cursor moves to the item's new column and row,
    following the item if it changed columns.

    If the anchor item is not present (deleted or moved outside board scope): the cursor
    clamps to the nearest valid position in the current column.

    When the cursor is on the select-all column header (on_select_all = true), the anchor
    is None and the header state is preserved across refreshes.
