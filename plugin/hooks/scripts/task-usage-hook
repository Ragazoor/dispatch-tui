#!/usr/bin/env bash
# task-usage-hook — Stop hook that reports token usage to the dispatch MCP server.
# Reads the session JSONL, sums tokens by model, computes cost, and calls report_usage.
# Failures are silent — usage reporting must never block agent shutdown.

set -euo pipefail

# ── 1. Read stdin and extract transcript_path ────────────────────────────────
input=$(cat)
transcript_path=$(echo "$input" | jq -r '.transcript_path // empty' 2>/dev/null || true)

if [[ -z "$transcript_path" || ! -f "$transcript_path" ]]; then
    exit 0
fi

# ── 2. Extract task ID from current git branch ───────────────────────────────
branch=$(git branch --show-current 2>/dev/null || echo "")
task_id=$(echo "$branch" | grep -oP '^\d+' || echo "")

if [[ -z "$task_id" ]]; then
    exit 0
fi

# ── 3. Parse JSONL: sum tokens per model, compute cost ───────────────────────
# Each relevant line has a `.usage` object and a `.model` string.
# Pricing (per million tokens): input, output, cache_read, cache_write
result=$(
    { grep '"usage"' "$transcript_path" 2>/dev/null || true; } \
    | jq -sc '
        def pricing(model):
            if (model | startswith("claude-opus-4"))    then {i: 15.0,  o: 75.0, cr: 1.50,  cw: 18.75}
            elif (model | startswith("claude-sonnet-4")) then {i: 3.0,   o: 15.0, cr: 0.30,  cw: 3.75}
            elif (model | startswith("claude-haiku"))   then {i: 0.80,  o: 4.0,  cr: 0.08,  cw: 1.0}
            else {i: 0.0, o: 0.0, cr: 0.0, cw: 0.0}
            end;

        reduce .[] as $line (
            {input: 0, output: 0, cache_read: 0, cache_write: 0, cost: 0.0};
            if $line.message.usage then
                ($line.message.usage.input_tokens              // 0) as $in  |
                ($line.message.usage.output_tokens             // 0) as $out |
                ($line.message.usage.cache_read_input_tokens   // 0) as $cr  |
                ($line.message.usage.cache_creation_input_tokens // 0) as $cw |
                pricing($line.message.model // "") as $p |
                .input      += $in  |
                .output     += $out |
                .cache_read += $cr  |
                .cache_write += $cw |
                .cost       += (($in * $p.i + $out * $p.o + $cr * $p.cr + $cw * $p.cw) / 1000000)
            else . end
        )
    ' 2>/dev/null || echo '{"input":0,"output":0,"cache_read":0,"cache_write":0,"cost":0}'
)

input_tokens=$(echo "$result"  | jq -r '.input')
output_tokens=$(echo "$result" | jq -r '.output')
cache_read=$(echo "$result"    | jq -r '.cache_read')
cache_write=$(echo "$result"   | jq -r '.cache_write')
cost_usd=$(echo "$result"      | jq -r '.cost')

# Skip if nothing was recorded
if [[ "$input_tokens" == "0" && "$output_tokens" == "0" ]]; then
    exit 0
fi

# ── 4. POST to the dispatch MCP server ──────────────────────────────────────
PORT="${DISPATCH_PORT:-3142}"

curl -s -X POST "http://localhost:${PORT}/mcp" \
    -H 'Content-Type: application/json' \
    -d "$(jq -n \
        --argjson task_id     "$task_id" \
        --argjson cost_usd    "$cost_usd" \
        --argjson input       "$input_tokens" \
        --argjson output      "$output_tokens" \
        --argjson cache_read  "$cache_read" \
        --argjson cache_write "$cache_write" \
        '{
            jsonrpc: "2.0", id: 1, method: "tools/call",
            params: {
                name: "report_usage",
                arguments: {
                    task_id: $task_id,
                    cost_usd: $cost_usd,
                    input_tokens: $input,
                    output_tokens: $output,
                    cache_read_tokens: $cache_read,
                    cache_write_tokens: $cache_write
                }
            }
        }'
    )" || true  # best-effort: never block on failure
