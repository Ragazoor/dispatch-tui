#!/usr/bin/env bash
# task-status-hook — Bridge between Claude Code hooks and dispatch.
#
# Installed alongside dispatch (or symlinked into PATH).
# Called by Claude Code PreToolUse, Stop, and Notification hooks with JSON on stdin.
# Extracts the task ID from the worktree directory name and forwards the event
# to `dispatch hook <id> <event>` which records the timestamp and applies the
# appropriate side effects.

set -euo pipefail

INPUT=$(cat)
CWD=$(echo "$INPUT" | jq -r '.cwd // empty')
EVENT=$(echo "$INPUT" | jq -r '.hook_event_name // empty')

# Extract task ID from the git branch name ({id}-{slug}). Branch lookup is
# more reliable than basename($CWD) because agents commonly cd into
# subdirectories of the worktree, which makes basename return something
# like "models" instead of "567-foo" and silently skips every hook.
ID=$(git -C "${CWD:-.}" branch --show-current 2>/dev/null | grep -oP '^\d+' || true)
if [ -z "$ID" ]; then
    # Fallback: walk up the cwd looking for a path segment that starts
    # with "<digits>-" (the standard dispatch worktree directory naming).
    path="${CWD:-}"
    while [ -n "$path" ] && [ "$path" != "/" ]; do
        name=$(basename "$path")
        if [[ "$name" =~ ^[0-9]+- ]]; then
            ID="${name%%-*}"
            break
        fi
        path=$(dirname "$path")
    done
fi
[ -z "$ID" ] && exit 0

case "$EVENT" in
    PreToolUse|PostToolUse)
        TOOL=$(echo "$INPUT" | jq -r '.tool_name // empty')
        # Skip dispatch MCP calls — management operations, not implementation work.
        # Without this, the wrap-up skill's get_task and wrap_up calls clobber review status.
        [[ "$TOOL" == mcp__dispatch__* ]] && exit 0
        dispatch hook "$ID" pre_tool_use
        ;;
    Stop)               dispatch hook "$ID" stop ;;
    Notification)
        # Forward the payload's notification_type as --kind so the Rust side
        # can distinguish a real block (permission_prompt/idle_prompt/
        # elicitation_dialog) from noise (auth_success) or a resolved
        # elicitation (elicitation_complete/elicitation_response). Absent on
        # older Claude Code — omitted, which the Rust side treats as needs_input.
        NOTIFICATION_TYPE=$(echo "$INPUT" | jq -r '.notification_type // empty')
        if [ -n "$NOTIFICATION_TYPE" ]; then
            dispatch hook "$ID" notification --kind "$NOTIFICATION_TYPE"
        else
            dispatch hook "$ID" notification
        fi
        ;;
    UserPromptSubmit)   dispatch hook "$ID" user_prompt_submit ;;
    *)                  exit 0 ;;
esac
